<!-- Rebuy — load after idle / first interaction to reduce PDP main-thread cost -->
<script>
  (function () {
    var loaded = false;
    function loadRebuy() {
      if (loaded) return;
      loaded = true;
      var s = document.createElement('script');
      s.async = true;
      s.src = 'https://cdn.rebuyengine.com/onsite/js/rebuy.js?shop={{ shop.permanent_domain }}';
      document.head.appendChild(s);
    }
    function onInteract() {
      loadRebuy();
    }
    ['scroll', 'pointerdown', 'keydown', 'touchstart'].forEach(function (evt) {
      window.addEventListener(evt, onInteract, { capture: true, passive: true, once: true });
    });
    if ('requestIdleCallback' in window) {
      requestIdleCallback(loadRebuy, { timeout: 3500 });
    } else {
      window.addEventListener('load', function () {
        setTimeout(loadRebuy, 2000);
      });
    }
  })();
</script>

<!-- Manual Widget Installs -->
{% if product %}
  <!-- PDP ATC Subscription Popup Upsell -->
  <div data-rebuy-id="160086" data-rebuy-shopify-product-ids="{{ product.id }}"></div>

  {%- assign rebuy_handle = product.handle -%}
  {%- if rebuy_handle == 'discovery-duo' -%}
    <div data-rebuy-id="226673"></div>
  {%- elsif rebuy_handle == 'ympossible-cream-light' -%}
    <div data-rebuy-id="226663"></div>
  {%- elsif rebuy_handle == 'ympossible-cream' -%}
    <div data-rebuy-id="222377"></div>
  {%- elsif rebuy_handle == 'ympossible-cream-light-refill' -%}
    <div data-rebuy-id="226954"></div>
  {%- elsif rebuy_handle == 'ympossible-cream-refill' -%}
    <div data-rebuy-id="226951"></div>
  {%- endif -%}
{% endif %}

{% if template == 'cart' %}
 <script>
    window.addEventListener("load", function () {
      if (!sessionStorage.getItem("cartReloaded")) {
        sessionStorage.setItem("cartReloaded", "true");
        setTimeout(function () {
          location.reload();
        }, 3000);
      } else {
        sessionStorage.removeItem("cartReloaded");
      }

      function triggerReloadAfterDelay() {
        clearTimeout(window.cartReloadTimeout);
        window.cartReloadTimeout = setTimeout(function () {
          location.reload();
        }, 3000);
      }

      document.querySelectorAll('.quantity__button').forEach(function (btn) {
        btn.addEventListener('click', triggerReloadAfterDelay);
      });
      document.querySelectorAll('.remove-item-btn').forEach(function (btn) {
        btn.addEventListener('click', triggerReloadAfterDelay);
      });
      document.querySelectorAll('.quantity__input').forEach(function (input) {
        input.addEventListener('change', triggerReloadAfterDelay);
        input.addEventListener('blur', triggerReloadAfterDelay);
      });
    });
  </script>
{% endif %}
