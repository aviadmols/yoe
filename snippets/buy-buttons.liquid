{%- comment %}BSS Login{% endcomment -%}{%- assign bss_product__has_only_default_variant = false %} {% assign _variants_count = 0 %} {% assign bss_product__first_available_variant = nil %} {% assign bss_product__selected_variant = nil %} {% assign bss_product__selected_or_first_available_variant = nil %} {% assign use_variant = true %} {% for variant in product.variants %} {% capture var %} {% render 'bss-lock-condition', scope: 'subject', subject: variant, subject_parent: product, bss_lock_action: 'handle-variant-default' %} {% endcapture %} {% if var contains "true" %} {% continue %} {% endif %} {% assign _variants_count = _variants_count | plus: 1 %} {% if bss_product__first_available_variant == nil and variant.available %} {% assign bss_product__first_available_variant = variant %} {% endif %} {% if bss_product__selected_variant == nil and variant.selected %} {% assign bss_product__selected_variant = variant %} {% endif %} {% if variant == product.selected_or_first_available_variant %} {% assign bss_product__selected_or_first_available_variant = product.selected_or_first_available_variant %} {% endif %} {% endfor %} {% if _variants_count == 1 %} {% assign bss_product__has_only_default_variant = true %} {% endif %} {% if bss_product__selected_or_first_available_variant == nil %} {% assign bss_product__selected_or_first_available_variant = bss_product__first_available_variant %} {% endif -%}{%- comment %}BSS-Login{% endcomment -%}
{% comment %}
  Renders product buy-buttons.
  Accepts:
  - product: {Object} product object.
  - block: {Object} passing the block information.
  - product_form_id: {String} product form id.
  - section_id: {String} id of section to which this snippet belongs.
  - show_pickup_availability: {Boolean} for the pickup availability. If true the pickup availability is rendered, false - not rendered (optional).

  Usage:
  {% render 'buy-buttons', block: block, product: product, product_form_id: product_form_id, section_id: section.id, show_pickup_availability: true %}
{% endcomment %}
<div {{ block.shopify_attributes }}>
  {%- if product != blank -%}
    {%- liquid
      assign gift_card_recipient_feature_active = false
      if block.settings.show_gift_card_recipient and product.gift_card?
        assign gift_card_recipient_feature_active = true
      endif

      assign show_dynamic_checkout = false
      if block.settings.show_dynamic_checkout and gift_card_recipient_feature_active == false
        assign show_dynamic_checkout = true
      endif
    -%}

    <product-form class="product-form" data-hide-errors="{{ gift_card_recipient_feature_active }}">
      <div class="product-form__error-message-wrapper" role="alert" hidden>
        <svg
          aria-hidden="true"
          focusable="false"
          class="icon icon-error"
          viewBox="0 0 13 13"
        >
          <circle cx="6.5" cy="6.50049" r="5.5" stroke="white" stroke-width="2"/>
          <circle cx="6.5" cy="6.5" r="5.5" fill="#EB001B" stroke="#EB001B" stroke-width="0.7"/>
          <path d="M5.87413 3.52832L5.97439 7.57216H7.02713L7.12739 3.52832H5.87413ZM6.50076 9.66091C6.88091 9.66091 7.18169 9.37267 7.18169 9.00504C7.18169 8.63742 6.88091 8.34917 6.50076 8.34917C6.12061 8.34917 5.81982 8.63742 5.81982 9.00504C5.81982 9.37267 6.12061 9.66091 6.50076 9.66091Z" fill="white"/>
          <path d="M5.87413 3.17832H5.51535L5.52424 3.537L5.6245 7.58083L5.63296 7.92216H5.97439H7.02713H7.36856L7.37702 7.58083L7.47728 3.537L7.48617 3.17832H7.12739H5.87413ZM6.50076 10.0109C7.06121 10.0109 7.5317 9.57872 7.5317 9.00504C7.5317 8.43137 7.06121 7.99918 6.50076 7.99918C5.94031 7.99918 5.46982 8.43137 5.46982 9.00504C5.46982 9.57872 5.94031 10.0109 6.50076 10.0109Z" fill="white" stroke="#EB001B" stroke-width="0.7">
        </svg>
        <span class="product-form__error-message"></span>
      </div>
  

      {% comment %} BSS Lock Begin Hide Add To Cart {% endcomment %} {% capture bss_lock_check %} {% render 'bss-lock-condition', scope: 'subject', subject: product, subject_parent: product, variable: 'price', get_content: true, bss_lock_action: 'bss_hide_atc' %} {% endcapture %} {% if bss_lock_check contains 'bss-hide-atc' %} {{ bss_lock_check }} {% endif %} {% comment %} BSS Lock End Hide Add To Cart {% endcomment %}{%- form 'product',
        product,
        id: product_form_id,
        class: 'form',
        novalidate: 'novalidate',
        data-type: 'add-to-cart-form'
       ,data-loop-product-id:product.id -%}
{% comment %}
  DO NOT modify this source code
  LOOP WIDGET CODE STARTS
{% endcomment %}
{%- liquid
  assign show_sub_extras = false
  if product.selling_plan_groups.size > 0
    if block.settings.show_subscription_benefits or block.settings.show_free_gifts
      assign show_sub_extras = true
    endif
  endif
-%}
{%- capture yoe_sub_extras_html -%}
  {%- if show_sub_extras -%}
    <div class="yoe-sub-extras">
      {%- if block.settings.show_subscription_benefits -%}
        <div class="yoe-sub-benefits-wrap">
          <ul class="yoe-sub-benefits">
            {%- if block.settings.subscription_benefit_1 != blank -%}
              <li>{{ block.settings.subscription_benefit_1 | escape }}</li>
            {%- endif -%}
            {%- if block.settings.subscription_benefit_2 != blank -%}
              <li>{{ block.settings.subscription_benefit_2 | escape }}</li>
            {%- endif -%}
            {%- if block.settings.subscription_benefit_3 != blank -%}
              <li>{{ block.settings.subscription_benefit_3 | escape }}</li>
            {%- endif -%}
          </ul>
          {%- if block.settings.subscription_reasons != blank -%}
            <details class="yoe-sub-readmore">
              <summary class="yoe-sub-readmore__toggle">
                <span class="yoe-sub-readmore__label yoe-sub-readmore__label--more">{{ block.settings.subscription_read_more_label | default: 'Read more' | escape }}</span>
                <span class="yoe-sub-readmore__label yoe-sub-readmore__label--less">{{ block.settings.subscription_read_less_label | default: 'Read less' | escape }}</span>
              </summary>
              <div class="yoe-sub-readmore__content rte">
                {{ block.settings.subscription_reasons }}
              </div>
            </details>
          {%- endif -%}
        </div>
      {%- endif -%}
      {%- if block.settings.show_free_gifts -%}
        {%- liquid
          assign gift_product = block.settings.free_gifts_product
          assign gift_image = block.settings.free_gifts_image
          if gift_product != blank
            assign gift_image = gift_product.featured_image | default: gift_product.images.first | default: gift_image
          endif
        -%}
        <div class="yoe-sub-gifts">
          {%- if block.settings.free_gifts_value != blank -%}
            <span class="yoe-sub-gifts__value"><strong>FREE</strong> <s>{{ block.settings.free_gifts_value | escape }}</s></span>
          {%- endif -%}
          {%- if gift_image != blank -%}
            {{ gift_image | image_url: width: 200 | image_tag:
              loading: 'lazy',
              widths: '100, 140, 200',
              sizes: '100px',
              class: 'yoe-sub-gifts__image',
              alt: block.settings.free_gifts_title
            }}
          {%- endif -%}
          <div class="yoe-sub-gifts__body">
            {%- if block.settings.free_gifts_title != blank -%}
              <span class="yoe-sub-gifts__title">{{ block.settings.free_gifts_title | escape }}</span>
            {%- endif -%}
            {%- if block.settings.free_gifts_text != blank -%}
              <p class="yoe-sub-gifts__text">{{ block.settings.free_gifts_text | escape }}</p>
            {%- endif -%}
          </div>
        </div>
      {%- endif -%}
    </div>
  {%- endif -%}
{%- endcapture -%}
{% assign template_exists = false %}
{% capture template_content %}
    {% render 'loop-subscriptions', type: 'product-widget', product: product %}
{% endcapture %}

{% if template_content contains 'Rendering loop-subscriptions' %}
  {% assign template_exists = true %}
{% endif %}

{% if template_exists %}
  {% render 'loop-subscriptions', type: 'product-widget', product: product, yoe_extras_html: yoe_sub_extras_html %}
{% endif %}
{% comment %}
  LOOP WIDGET CODE ENDS
{% endcomment %}

        {%- if product.selling_plan_groups.size > 0 and block.settings.lock_subscription_frequency -%}
          <style>
            #loop-subscription-container-{{ product.id }} .loop-subscription-group-selling-plans-container { display: none !important; }
          </style>
        {%- endif -%}

        <input
          type="hidden"
          name="id"
          value="{{ bss_product__selected_or_first_available_variant.id }}"
          disabled
          class="product-variant-id"
        >

        <script>
          (function () {
            var pid = {{ product.id | json }};
            var hasSub = {{ product.selling_plan_groups.size }} > 0;
            var lockEnabled = {{ block.settings.lock_subscription_frequency | default: false | json }};
            var matchText = {{ block.settings.locked_frequency_match | default: '4 weeks' | json }};
            var rx = new RegExp(String(matchText).replace(/[.*+?^${}()|[\]\\]/g, '\\$&'), 'i');

            var form, priceEl, subContainer, priceBlock;

            function visibleText(root, sel) {
              var found = '';
              if (!root) return found;
              root.querySelectorAll(sel).forEach(function (e) {
                if (e.getBoundingClientRect().height > 0) found = e.textContent.trim();
              });
              return found;
            }
            function subscribeSelected() {
              var one = document.getElementById('loop-one-time-purchase-' + pid);
              return !(one && one.checked);
            }

            // ----- Add-to-cart button price -----
            function currentPrice() {
              if (hasSub && subContainer) {
                if (!subscribeSelected()) {
                  return visibleText(subContainer, '.loop-one-time-purchase-option-price-amountl');
                }
                return visibleText(subContainer, '.loop-subscription-group-price-amount');
              }
              var t = visibleText(priceBlock, '.loop-one-time-purchase-option-price-amountl');
              if (t) return t;
              return visibleText(priceBlock, '.price-item--sale, .price-item--regular');
            }
            function updatePrice() {
              if (!priceEl) return;
              var p = currentPrice();
              if (p) p = p.replace(/US\$/g, '$');
              priceEl.textContent = p ? p : '';
            }

            // ----- Subscription frequency lock -----
            function desiredValue(container) {
              var v = null;
              container.querySelectorAll('.loop-selling-plan-selector').forEach(function (sel) {
                var opt = Array.prototype.find.call(sel.options, function (o) { return rx.test(o.textContent); });
                if (opt) v = opt.value;
              });
              return v;
            }
            // returns true when nothing more needs to be done
            function applyLock() {
              if (!lockEnabled || !hasSub || !subContainer) return true;
              if (!subscribeSelected()) return true;
              var desired = desiredValue(subContainer);
              if (!desired) return true;
              subContainer.querySelectorAll('.loop-selling-plan-selector').forEach(function (sel) {
                if (sel.value !== desired) { sel.value = desired; }
              });
              var sp = form.querySelector('input[name="selling_plan"]');
              if (sp && sp.value === desired) return true;
              subContainer.querySelectorAll('.loop-selling-plan-selector').forEach(function (sel) {
                sel.dispatchEvent(new Event('change', { bubbles: true }));
              });
              return false;
            }

            function tick() {
              var lockDone = applyLock();
              updatePrice();
              return lockDone;
            }

            function init() {
              form = document.querySelector('form[data-loop-product-id="' + pid + '"]');
              if (!form) return;
              priceEl = form.querySelector('.yoe-atc-price');
              subContainer = document.getElementById('loop-subscription-container-' + pid);
              priceBlock = document.getElementById('price-{{ section_id }}');

              if (subContainer) {
                new MutationObserver(updatePrice).observe(subContainer, { subtree: true, childList: true, characterData: true, attributes: true });
              }
              if (priceBlock) {
                new MutationObserver(updatePrice).observe(priceBlock, { subtree: true, childList: true, characterData: true });
              }

              var tries = 0;
              var iv = setInterval(function () {
                tries++;
                var lockDone = tick();
                if (tries > 60 || (lockEnabled && lockDone)) clearInterval(iv);
              }, 250);

              document.addEventListener('change', function (e) {
                if (!e.target) return;
                var isVariant = e.target.name === 'id' || (e.target.closest && e.target.closest('variant-radios'));
                if (e.target.name === 'loop_purchase_option' || isVariant) {
                  setTimeout(function () { applyLock(); updatePrice(); }, 80);
                }
              });

              updatePrice();
            }

            if (document.readyState === 'loading') {
              document.addEventListener('DOMContentLoaded', init);
            } else {
              init();
            }
          })();
        </script>

        {%- if gift_card_recipient_feature_active -%}
          {%- render 'gift-card-recipient-form', product: product, form: form, section: section -%}
        {%- endif -%}

        <div class="product-form__buttons">
          {%- liquid
            assign check_against_inventory = true
            if bss_product__selected_or_first_available_variant.inventory_management != 'shopify' or  bss_product__selected_or_first_available_variant.inventory_policy == 'continue'
              assign check_against_inventory = false
            endif
            if bss_product__selected_or_first_available_variant.quantity_rule.min > bss_product__selected_or_first_available_variant.inventory_quantity and check_against_inventory
              assign quantity_rule_soldout = true
            endif
          -%}
          <button
            id = "ProductSubmitButton-{{ section_id }}"
            type="submit"
            name="add"
            class="product-form__submit button button--full-width {% if show_dynamic_checkout %}button--secondary{% else %}button--primary{% endif %}"
            {% if bss_product__selected_or_first_available_variant.available == false or quantity_rule_soldout %}
              disabled
            {% endif %}
          >
            <span>
              {%- if bss_product__selected_or_first_available_variant.available == false or quantity_rule_soldout -%}
                {{ 'products.product.sold_out' | t }}
              {%- else -%}
                {{ 'products.product.add_to_cart' | t }}
              {%- endif -%}
            </span>
            <span class="yoe-atc-price" aria-hidden="true">
              {%- unless bss_product__selected_or_first_available_variant.available == false or quantity_rule_soldout -%}
                {{ bss_product__selected_or_first_available_variant.price | money | replace: 'US$', '$' }}
              {%- endunless -%}
            </span>
            <div class="loading-overlay__spinner hidden">
              <svg
                aria-hidden="true"
                focusable="false"
                class="spinner"
                viewBox="0 0 66 66"
                xmlns="http://www.w3.org/2000/svg"
              >
                <circle class="path" fill="none" stroke-width="6" cx="33" cy="33" r="30"></circle>
              </svg>
            </div>
          </button>
          {%- if show_dynamic_checkout -%}
            {{ form | payment_button }}
          {%- endif -%}
        </div>
      {%- endform -%}
    </product-form>
  {%- else -%}
    <div class="product-form">
      <div class="product-form__buttons form">
        <button
          type="submit"
          name="add"
          class="product-form__submit button button--full-width button--primary"
          disabled
        >
          {{ 'products.product.sold_out' | t }}
        </button>
      </div>
    </div>
  {%- endif -%}

  {%- if show_pickup_availability -%}
    {{ 'component-pickup-availability.css' | asset_url | stylesheet_tag }}

    {%- assign pick_up_availabilities = bss_product__selected_or_first_available_variant.store_availabilities
      | where: 'pick_up_enabled', true
    -%}

    <pickup-availability
      class="product__pickup-availabilities no-js-hidden quick-add-hidden"
      {% if bss_product__selected_or_first_available_variant.available and pick_up_availabilities.size > 0 %}
        available
      {% endif %}
      data-root-url="{{ routes.root_url }}"
      data-variant-id="{{ bss_product__selected_or_first_available_variant.id }}"
      data-has-only-default-variant="{{ bss_product__has_only_default_variant }}"
    >
      <template>
        <pickup-availability-preview class="pickup-availability-preview">
          {% render 'icon-unavailable' %}
          <div class="pickup-availability-info">
            <p class="caption-large">{{ 'products.product.pickup_availability.unavailable' | t }}</p>
            <button class="pickup-availability-button link link--text underlined-link">
              {{ 'products.product.pickup_availability.refresh' | t }}
            </button>
          </div>
        </pickup-availability-preview>
      </template>
    </pickup-availability>

    <script src="{{ 'pickup-availability.js' | asset_url }}" defer="defer"></script>
  {%- endif -%}
</div>
