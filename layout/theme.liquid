<script>
    (function() {
        // Only run on product pages
        if (!document.body.classList.contains('template-product')) return;

        function comparePrices() {
            // Find all price containers
            const containers = document.querySelectorAll('.loop-one-time-purchase-option-price-container, .loop-subscription-group-price-container');

            containers.forEach(function(container) {
                let regularPrice, finalPrice;

                // Check for one-time purchase prices
                const regularOneTime = container.querySelector('.loop-one-time-purchase-option-price-amount-original');
                const finalOneTime = container.querySelector('.loop-one-time-purchase-option-price-amount');

                // Check for subscription prices
                const regularSub = container.querySelector('.loop-subscription-group-price-amount-original');
                const finalSub = container.querySelector('.loop-subscription-group-price-amount');

                // Determine which set to use
                if (regularOneTime && finalOneTime) {
                    regularPrice = regularOneTime;
                    finalPrice = finalOneTime;
                } else if (regularSub && finalSub) {
                    regularPrice = regularSub;
                    finalPrice = finalSub;
                } else {
                    return; // Skip if no valid pair found
                }

                // Get text content and clean it
                const regularText = regularPrice.textContent.trim().replace(/\s+/g, '').replace('$', '');
                const finalText = finalPrice.textContent.trim().replace(/\s+/g, '').replace('$', '');

                // Compare prices
                if (regularText === finalText) {
                    // Same price - hide regular price
                    regularPrice.classList.add('loop-display-none');
                    regularPrice.classList.remove('loop-display-original');
                } else {
                    // Different prices - show regular price with styling
                    regularPrice.classList.add('loop-display-original');
                    regularPrice.classList.remove('loop-display-none');
                }
            });
        }

        // Run on page load
        if (document.readyState === 'loading') {
            document.addEventListener('DOMContentLoaded', comparePrices);
        } else {
            comparePrices();
        }

        // Re-run when variant changes (in case prices update)
        document.addEventListener('variant:change', comparePrices);

        // Fallback: observe DOM changes for dynamically loaded content
        const observer = new MutationObserver(comparePrices);
        observer.observe(document.body, {
            childList: true,
            subtree: true
        });

        // Stop observing after 5 seconds to prevent performance issues
        setTimeout(function() {
            observer.disconnect();
        }, 5000);
    })();
</script>

