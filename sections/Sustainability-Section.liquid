{% schema %}
{
  "name": "Sustainability Section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "SUSTAINABILITY"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "The Yoé production process and refillable packaging system are designed to minimize our carbon footprint and overall environmental impact throughout the product life cycle."
    },
    {
      "type": "image_picker",
      "id": "badge_1",
      "label": "Badge 1"
    },
    {
      "type": "image_picker",
      "id": "badge_2",
      "label": "Badge 2"
    },
    {
      "type": "image_picker",
      "id": "badge_3",
      "label": "Badge 3"
    },
    {
      "type": "header",
      "content": "Mobile Icons"
    },
    {
      "type": "image_picker",
      "id": "badge_mobile_1",
      "label": "Badge Icon"
    },
    {
      "type": "image_picker",
      "id": "badge_mobile_2",
      "label": "Badge Icon"
    },
    {
      "type": "image_picker",
      "id": "badge_mobile_3",
      "label": "Badge Icon"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button Text",
      "default": "LEARN MORE ABOUT IMPACT"
    },
    {
      "type": "header",
      "content": "Mobile Content"
    },
    {
      "type": "text",
      "id": "section_heading",
      "label": "Section Heading",
      "default": "SUSTAINABILITY FEATURES"
    },
    {
      "type": "text",
      "id": "feature_title_mobile_1",
      "label": "Feature Title",
      "default": "NO ADHESIVES"
    },
    {
      "type": "textarea",
      "id": "feature_text_mobile_1",
      "label": "Feature Description",
      "default": "Yoé emblem heat-fused into the cap, eliminating the need for adhesive."
    },
    {
      "type": "text",
      "id": "feature_title_mobile_2",
      "label": "Feature Title",
      "default": "ECO MATERIALS"
    },
    {
      "type": "textarea",
      "id": "feature_text_mobile_2",
      "label": "Feature Description",
      "default": "Packaging designed with sustainable, recyclable materials."
    },
    {
      "type": "text",
      "id": "feature_title_mobile_3",
      "label": "Feature Title",
      "default": "REFILL SYSTEM"
    },
    {
      "type": "textarea",
      "id": "feature_text_mobile_3",
      "label": "Feature Description",
      "default": "Refillable design reduces single-use packaging."
    },
    {
      "type": "text",
      "id": "feature_title_mobile_4",
      "label": "Feature Title",
      "default": "LOW CARBON"
    },
    {
      "type": "textarea",
      "id": "feature_text_mobile_4",
      "label": "Feature Description",
      "default": "Production process optimized for a minimal carbon footprint."
    },
    {
      "type": "text",
      "id": "feature_title_mobile_5",
      "label": "Feature Title",
      "default": "RECYCLABLE"
    },
    {
      "type": "textarea",
      "id": "feature_text_mobile_5",
      "label": "Feature Description",
      "default": "Designed for recyclability at end-of-life."
    },
    {
      "type": "image_picker",
      "id": "feature_image_1",
      "label": "Feature Image 1"
    },
    {
      "type": "image_picker",
      "id": "feature_image_2",
      "label": "Feature Image 2"
    },
    {
      "type": "image_picker",
      "id": "feature_image_3",
      "label": "Feature Image 3"
    }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "Feature Item",
      "settings": [
        {
          "type": "text",
          "id": "title_1",
          "label": "Feature Title"
        },
        {
          "type": "textarea",
          "id": "text_1",
          "label": "Feature Description"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Feature Image"
        },
        {
          "type": "text",
          "id": "title_2",
          "label": "Feature Title"
        },
        {
          "type": "textarea",
          "id": "text_2",
          "label": "Feature Description"
        }
      ]
    }
  ],
  "max_blocks": 5,
  "presets": [
    {
      "name": "Sustainability Section",
      "category": "Custom"
    }
  ]
}
{% endschema %}

<section class="sustainability-section">
    <div class="page-width">
        <div class="container-section-desktop">
            <div class="left-col">
                <h5 class="caption-section-heading">Delivery System</h5>
                <h2>{{ section.settings.heading }}</h2>
                <p>{{ section.settings.description }}</p>
                <div class="badges desktop-icon">
                    {% if section.settings.badge_1 != blank %}
                        <img src="{{ section.settings.badge_1 | img_url: 'master' }}" alt="badge 1">
                    {% endif %}
                    {% if section.settings.badge_2 != blank %}
                        <img src="{{ section.settings.badge_2 | img_url: 'master' }}" alt="badge 2">
                    {% endif %}
                    {% if section.settings.badge_3 != blank %}
                        <img src="{{ section.settings.badge_3 | img_url: 'master' }}" alt="badge 3">
                    {% endif %}
                </div>
                {% comment %} Mobile icons {% endcomment %}
                <div class="badges mobile-icon">
                    {% if section.settings.badge_mobile_1 != blank %}
                        <img src="{{ section.settings.badge_mobile_1 | img_url: 'master' }}" alt="badge 1">
                    {% endif %}
                    {% if section.settings.badge_mobile_2 != blank %}
                        <img src="{{ section.settings.badge_mobile_2 | img_url: 'master' }}" alt="badge 2">
                    {% endif %}
                    {% if section.settings.badge_mobile_3 != blank %}
                        <img src="{{ section.settings.badge_mobile_3 | img_url: 'master' }}" alt="badge 3">
                    {% endif %}
                </div>
                {% comment %} End here {% endcomment %}

                <a href="{{ section.settings.button_link }}" class="cta-btn">{{ section.settings.button_text }}</a>

            </div>
            <div class="right-col">
                {% for block in section.blocks %}
                    <div class="feature-item featured-item-{{ forloop.index }}">
                        <div class="feature-text">
                            <div class="content-section">
                                <h4>{{ block.settings.title_1 }}</h4>
                                <p>{{ block.settings.text_1 }}</p>
                            </div>
                        </div>
                        {% if block.settings.image != blank %}
                            <img src="{{ block.settings.image | img_url: 'master' }}"
                                 alt="{{ block.settings.title_1 }}">
                        {% endif %}
                        <div class="feature-text">
                            <h4>{{ block.settings.title_2 }}</h4>
                            <p>{{ block.settings.text_2 }}</p>
                        </div>
                    </div>
                {% endfor %}
            </div>
        </div>
    </div>
</section>

{% comment %} Mobile section {% endcomment %}
<section class="vertical-features-mobile-section">
    <div class="page-width">
        <div class="container-section-mobile">
            {% if section.settings.section_heading != blank %}
                <h2 class="section-heading">{{ section.settings.section_heading }}</h2>
            {% endif %}
            <div class="features-list">
                <div class="feature-item">
                    <div class="feature-text">
                        <h4>{{ section.settings.feature_title_mobile_1 }}</h4>
                        <p>{{ section.settings.feature_text_mobile_1 }}</p>
                    </div>
                    <div class="feature-text">
                        <h4>{{ section.settings.feature_title_mobile_2 }}</h4>
                        <p>{{ section.settings.feature_text_mobile_2 }}</p>
                    </div>
                    <div class="feature-text">
                        <h4>{{ section.settings.feature_title_mobile_3 }}</h4>
                        <p>{{ section.settings.feature_text_mobile_3 }}</p>
                    </div>
                    <div class="feature-text">
                        <h4>{{ section.settings.feature_title_mobile_4 }}</h4>
                        <p>{{ section.settings.feature_text_mobile_4 }}</p>
                    </div>
                    <div class="feature-text">
                        <h4>{{ section.settings.feature_title_mobile_5 }}</h4>
                        <p>{{ section.settings.feature_text_mobile_5 }}</p>
                    </div>

                </div>
                <div class="feature-image">
                    {% if section.settings.feature_image_1 != blank %}
                        <img src="{{ section.settings.feature_image_1 | img_url: 'master' }}" alt="Feature image 1">
                    {% endif %}
                    {% if section.settings.feature_image_2 != blank %}
                        <img src="{{ section.settings.feature_image_2 | img_url: 'master' }}" alt="Feature image 2">
                    {% endif %}
                    {% if section.settings.feature_image_3 != blank %}
                        <img src="{{ section.settings.feature_image_3 | img_url: 'master' }}" alt="Feature image 3">
                    {% endif %}
                </div>
            </div>
        </div>
    </div>
</section>
{% comment %} End here {% endcomment %}


