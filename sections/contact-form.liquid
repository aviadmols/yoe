    }
    .form-status__icon svg{
      width: 3.8646rem;
height: 6.10935rem;

    }

.split-section__content>div{
    max-width: 29rem;
    margin-left: auto;
    margin-right: auto;
}


    .split-section__icons {
    
    display: flex;
    flex-flow: nowrap;
    gap: 3rem;
    align-items: center;
    }

.split-section__text {
margin-bottom: 3rem;
}

.split-section__icons img 
{
    height: 3rem;
}


  </style>

