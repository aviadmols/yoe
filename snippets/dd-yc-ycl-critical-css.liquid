{%- comment -%} Inline critical CSS for discovery-duo-yc / ycl — reduces mobile CTA layout shift before full stylesheets load. {%- endcomment -%}
html.dd-yc-ycl-preloading {
  overflow: hidden;
}

html.dd-yc-ycl-preloading .dd-yc-ycl-preloader {
  opacity: 1;
  visibility: visible;
}

html.dd-yc-ycl-preloading #MainContent,
html.dd-yc-ycl-preloading .header_sections,
html.dd-yc-ycl-preloading .announcement-bar-section {
  opacity: 0;
}

html.dd-yc-ycl-ready #MainContent,
html.dd-yc-ycl-ready .header_sections,
html.dd-yc-ycl-ready .announcement-bar-section {
  opacity: 1;
  transition: opacity 0.4s ease;
}

