    <script>
      window.Shopify = window.Shopify || {};

      if (typeof Shopify.formatMoney !== 'function') {
        Shopify.formatMoney = (function() {
          var defaultFormat = {{ shop.money_format | json }};

          function formatWithDelimiters(cents, precision, thousands, decimal) {
            if (isNaN(cents) || cents === null) {
              return '0';
            }

            cents = (cents / 100.0).toFixed(precision);

            var parts = cents.split('.');
            var dollars = parts[0].replace(
              /(\d)(?=(\d\d\d)+(?!\d))/g,
              '$1' + (thousands || ',')
            );
            var c = parts[1] ? (decimal || '.') + parts[1] : '';

            return dollars + c;
          }

          return function(cents, format) {
            if (typeof cents === 'string') {
              cents = cents.replace('.', '');
            }

            var value = '';
            var moneyFormat = format || defaultFormat || '${{amount}}';
            var placeholderRegex = /\{\{\s*(\w+)\s*\}\}/;

            function formatValue(match, placeholder) {
              switch (placeholder) {
                case 'amount':
                  value = formatWithDelimiters(cents, 2);
                  break;
                case 'amount_no_decimals':
                  value = formatWithDelimiters(cents, 0);
                  break;
                case 'amount_with_comma_separator':
                  value = formatWithDelimiters(cents, 2, '.', ',');
                  break;
                case 'amount_no_decimals_with_comma_separator':
                  value = formatWithDelimiters(cents, 0, '.', ',');
                  break;
                default:
                  value = formatWithDelimiters(cents, 2);
              }

              return value;
            }

            return moneyFormat.replace(placeholderRegex, formatValue);
          };
        })();
      }
    </script>
