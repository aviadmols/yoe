{{ 'discovery-duo-refillable.css' | asset_url | stylesheet_tag }}

<section
  class="dd-refill"
  style="--dd-refill-padding-top: {{ section.settings.padding_top }}px; --dd-refill-padding-bottom: {{ section.settings.padding_bottom }}px;"
  aria-label="{{ section.settings.headline | default: 'Refillable, recyclable, responsible' | escape }}"
>
  <div class="dd-refill__inner">
    <header class="dd-refill__header">
      {%- if section.settings.eyebrow != blank -%}
        <span class="dd-refill__eyebrow">{{ section.settings.eyebrow }}</span>
      {%- endif -%}
      {%- if section.settings.headline != blank -%}
        <h2 class="dd-refill__headline">{{ section.settings.headline }}</h2>
      {%- endif -%}
      {%- if section.settings.subheadline != blank -%}
        <div class="dd-refill__subheadline">{{ section.settings.subheadline }}</div>
      {%- endif -%}
    </header>

    {%- if section.settings.desktop_image != blank or section.settings.mobile_image != blank -%}
      <div class="dd-refill__media">
        <picture>
          {%- if section.settings.mobile_image != blank -%}
            <source
              media="(max-width: 749px)"
              srcset="{{ section.settings.mobile_image | image_url: width: 750 }}"
            >
          {%- endif -%}
          {%- if section.settings.desktop_image != blank -%}
            {{ section.settings.desktop_image | image_url: width: 1800 | image_tag:
              loading: 'lazy',
              class: 'dd-refill__image',
              alt: section.settings.desktop_image.alt | default: section.settings.headline
            }}
          {%- endif -%}
        </picture>
      </div>
    {%- endif -%}

    {%- if section.blocks.size > 0 -%}
      <ul class="dd-refill__pillars">
        {%- for block in section.blocks -%}
          {%- if block.type == 'pillar' -%}
            <li class="dd-refill__pillar" {{ block.shopify_attributes }}>
              {%- if block.settings.icon != blank -%}
                <div class="dd-refill__pillar-icon">
                  {{ block.settings.icon | image_url: width: 120 | image_tag:
                    loading: 'lazy',
                    alt: ''
                  }}
                </div>
              {%- endif -%}
              {%- if block.settings.title != blank -%}
                <h3 class="dd-refill__pillar-title">{{ block.settings.title }}</h3>
              {%- endif -%}
              {%- if block.settings.description != blank -%}
                <p class="dd-refill__pillar-description">{{ block.settings.description }}</p>
              {%- endif -%}
            </li>
          {%- endif -%}
        {%- endfor -%}
      </ul>
    {%- endif -%}

    {%- if section.settings.cta_text != blank and section.settings.cta_url != blank -%}
      <div class="dd-refill__cta-wrap">
        <a class="dd-refill__cta" href="{{ section.settings.cta_url }}">
          {{ section.settings.cta_text }}
        </a>
      </div>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Discovery Duo – Refillable",
  "tag": "section",
  "class": "section-dd-refill",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Sustainability"
    },
    {
      "type": "text",
      "id": "headline",
      "label": "Headline",
      "default": "Refillable. Recyclable. Responsible."
    },
    {
      "type": "richtext",
      "id": "subheadline",
      "label": "Subheadline",
      "default": "<p>Our refillable system is designed to minimize our carbon footprint and the overall environmental impact of every product.</p>"
    },
    {
      "type": "header",
      "content": "Hero image (two-bottle landscape)"
    },
    {
      "type": "image_picker",
      "id": "desktop_image",
      "label": "Desktop image"
    },
    {
      "type": "image_picker",
      "id": "mobile_image",
      "label": "Mobile image"
    },
    {
      "type": "header",
      "content": "Call to action"
    },
    {
      "type": "text",
      "id": "cta_text",
      "label": "Button text",
      "default": "LEARN ABOUT OUR IMPACT"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "Button link"
    },
    {
      "type": "header",
      "content": "Section padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Top padding",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Bottom padding",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "default": 80
    }
  ],
  "blocks": [
    {
      "type": "pillar",
      "name": "Pillar",
      "limit": 4,
      "settings": [
        {
          "type": "image_picker",
          "id": "icon",
          "label": "Icon"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Refillable"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Description",
          "default": "Reusable bottles refill at home to reduce single-use packaging."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Discovery Duo – Refillable",
      "blocks": [
        { "type": "pillar", "settings": { "title": "Refillable", "description": "Reusable bottles refill at home to reduce single-use packaging." } },
        { "type": "pillar", "settings": { "title": "Recyclable", "description": "Glass + minimum 50% post-consumer recycled materials throughout." } },
        { "type": "pillar", "settings": { "title": "Responsible", "description": "No adhesives, metal-free pumps, optimized for recycling at end of life." } }
      ]
    }
  ]
}
{% endschema %}
