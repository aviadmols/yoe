<!-- Section Template -->
{% schema %}
{
  "name": "Yoe Parallax Banner",
  "settings": [
    {
      "type": "image_picker",
      "id": "desktop_banner_image",
      "label": "Desktop Banner Image"
    },
    {
      "type": "image_picker",
      "id": "mobile_banner_image",
      "label": "Mobile Banner Image"
    },
    {
      "type": "text",
      "id": "banner_title",
      "label": "Banner Title",
      "default": "Your Banner Title"
    },
    {
      "type": "textarea",
      "id": "banner_text",
      "label": "Banner Text",
      "default": "Your Banner Text"
    },
    {
      "type": "url",
      "id": "banner_button_link",
      "label": "Banner Button Link"
    },
    {
      "type": "text",
      "id": "banner_button_text",
      "label": "Banner Button Text",
      "default": "Click Here"
    }
  ],
  "presets": [
    {
      "name": "Yoe Parallax Banner",
      "category": "Custom"
    }
  ]
}
{% endschema %}

<style>
  .custom-parallax-banner {
    position: relative;
    overflow: hidden;
    margin: 0;
    padding-right: 1.75rem;
    padding-left: 1.75rem;
  }

.custom-parallax-banner__content {
    position: absolute;
    align-items: center;
    display: flex;
    top: 0;
    left: 6.4675rem;
    bottom: 0px;
    transform: 0;
    text-align: left;
}
  .custom-parallax-banner__image {
      background-position: center;
    background-repeat: no-repeat;
    background-size: cover;
    width: 100%;
    height: 35rem;
    padding-top: 0;
    position: relative;
    z-index: -1;
  }

  .desktop-only {
    display: none;
  }

  .mobile-only {
    display: block;
  }

  @media (min-width: 768px) {
    .desktop-only {
      display: block;
    }

    .mobile-only {
      display: none;
    }
  }
</style>

<div class="custom-parallax-banner  scroll-trigger animate--slide-in">
  <div class="custom-parallax-banner__image">
    <img class="desktop-only zoom-image" src="{{ section.settings.desktop_banner_image | img_url: '' }}" alt="">
    <img class="mobile-only zoom-image" src="{{ section.settings.mobile_banner_image | img_url: '' }}" alt="">
  </div>
  <div class="custom-parallax-banner__content">
<div class="custom-parallax-banner__content_banner_in">
    <h2>{{ section.settings.banner_title }}</h2>
    <p>{{ section.settings.banner_text }}</p>
    <a href="{{ section.settings.banner_button_link }}" class="button_full hover_gray">{{ section.settings.banner_button_text }}</a>
</div>
  </div>
</div>


