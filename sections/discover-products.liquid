{% schema %}
{
  "name": "Discover Products",
  "class": "Discover-Products",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "TWO MULTI-ACTION HERO CREAMS, TWO OPTIONS TO ACHIEVE ULTIMATE RESULTS."
    }
  ],
  "blocks": [
    {
      "type": "product",
      "name": "Product",
      "settings": [
        {
          "type": "product",
          "id": "product",
          "label": "Product"
        },
        {
          "type": "image_picker",
          "id": "product_image",
          "label": "Product Image"
        },
        {
          "type": "text",
          "id": "product_name",
          "label": "Product Name",
          "default": "YMPOSSIBLE CREAM"
        },
        {
          "type": "textarea",
          "id": "product_description",
          "label": "Product Description",
          "default": "Description of the product."
        },
        {
          "type": "text",
          "id": "hero_text",
          "label": "Hero Text",
          "default": "Ultra-Nourishing Multi-Action Hero Cream"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Discover Products",
      "category": "Products"
    }
  ]
}
{% endschema %}

<div class="hero-creams">
    <h2 class="text-heading">{{ section.settings.heading }}</h2>
    <div class="products">
        {% for block in section.blocks %}
            {% assign product = all_products[block.settings.product] %}
            {% if product %}
                {% assign sorted_variants = product.variants | sort: "price" | reverse %}
                {% assign highest_price_variant = sorted_variants.first %}

                <div class="product">
                    <a href="{{ product.url }}">
                        {% if block.settings.product_image != blank %}
                            <img src="{{ block.settings.product_image | img_url: 'master' }}" alt="{{ product.title }}">
                        {% elsif product.featured_image %}
                            <img src="{{ product.featured_image | img_url: 'master' }}" alt="{{ product.title }}">
                        {% endif %}
                    </a>
                    <div class="product__description rte quick-add-hidden">
                        <div class="product__title">
                            <h1>
                                {{ block.settings.product_name | default: product.title }}
                                {% if forloop.index == 2 %}
                                    <span class="light">LIGHT 8ml</span>
                                {% endif %}
                                {% if forloop.index == 1 %}
                                    <span class="light">8ml</span>
                                {% endif %}
                            </h1>

                            {% comment %} Review section {% endcomment %}
                            <div class="custom-review-stars">
                                {% render 'okendo-reviews-widget', product: product %}
                                {% render 'okendo-reviews-product-rating-summary', product: product %}
                            </div>

                        </div>
                        <p class="hero-subtitle">{{ block.settings.hero_text }}</p>
                        <p class="price">{{ highest_price_variant.price | money }}</p>


                        <div class="description_div">
                            <ul class="benefits-list">
                                {% assign benefits = block.settings.product_description | newline_to_br | split: '<br />' %}
                                {% for benefit in benefits %}
                                    {% if benefit != blank %}
                                        <li class="benefit-item">
                                            <svg xmlns="http://www.w3.org/2000/svg" width="19" height="14"
                                                 viewBox="0 0 19 14" fill="none">
                                                <path d="M1 6.5L6.66667 12L18 1" stroke="#666460" stroke-width="2"/>
                                            </svg>
                                            <span>{{ benefit | strip }}</span>
                                        </li>
                                    {% endif %}
                                {% endfor %}
                            </ul>
                        </div>

                        <p class="hero-subtitle">{{ block.settings.hero_text }}</p>

