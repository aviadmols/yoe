{% schema %}
{
  "name": "Discover Hero",
  "settings": [
    {
      "type": "image_picker",
      "id": "desktop_image",
      "label": "Desktop Image"
    },
    {
      "type": "image_picker",
      "id": "mobile_image",
      "label": "Mobile Image"
    },
    {
      "type": "html",
      "id": "title",
      "label": "Title"
    },
    {
      "type": "product",
      "id": "product",
      "label": "product"
    },
    {
      "type": "text",
      "id": "discount_code",
      "label": "Discount Code",
      "info": "Optional: Enter a discount code to apply when adding to cart"
    },
    {
      "type": "html",
      "id": "subtitle",
      "label": "Subtitle"
    },
    {
      "type": "html",
      "id": "label_text",
      "label": "Label Text",
      "default": "Available for a <strong>limited time</strong>",
      "info": "The text displayed above the title in the hero section"
    },
    {
      "type": "image_picker",
      "id": "icon_1",
      "label": "Icon 1"
    },
    {
      "type": "image_picker",
      "id": "icon_2",
      "label": "Icon 1"
    },
    {
      "type": "image_picker",
      "id": "icon_3",
      "label": "Icon 1"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button Text"
    },
    {
      "type": "text",
      "id": "after_cta_text",
      "label": "After CTA Text",
      "info": "Text displayed after the CTA button"
    }
  ],
  "presets": [
    {
      "name": "Discover Hero",
      "category": "Hero"
    }
  ]
}
{% endschema %}

<div class="discover-hero scroll-trigger animate--slide-in">
  <div class="discover-hero__image">
    <img src="{{ section.settings.desktop_image | img_url: 'master' }}"
         class="desktop-only"
         alt="{{ section.settings.title }}">
    <img src="{{ section.settings.mobile_image | img_url: 'master' }}"
         class="mobile-only"
         alt="{{ section.settings.title }}">
  </div>
  <div class="discover-hero__content  ">
    {% assign label_text = section.settings.label_text | default: "Available for a <strong>limited time</strong>" %}
    {% if label_text != blank %}
      <span class="label_hero">{{ label_text }}</span>
    {% endif %}
    <h1>{{ section.settings.title }}</h1>
    <h2>{{ section.settings.subtitle }}</h2>
<div class="mobile-only">
<ul class=" banner_badges_list">
  <li>{{ section.settings.icon_1 | img_url: 'master' | img_tag }}</li>
    <li>{{ section.settings.icon_2 | img_url: 'master' | img_tag }}</li>
    <li>{{ section.settings.icon_3 | img_url: 'master' | img_tag }}</li>
</ul>
</div>

      {% if section.settings.product %}
          <form method="post" action="/cart/add" class="discover-hero-cart-form" data-discover-hero-form="true" data-discount-code="{{ section.settings.discount_code }}">
              <input type="hidden" name="id" value="{{ section.settings.product.selected_or_first_available_variant.id }}">
              <button type="submit" class="product-form__submit product-hero-button button button--primary" data-hero-submit="true">
                  {{ section.settings.button_text }}
              </button>
          </form>
      {% endif %}
      {% if section.settings.after_cta_text != blank %}
          <p class="discover-hero__after-cta-text">{{ section.settings.after_cta_text }}</p>
      {% endif %}
  </div>

</div>

{% stylesheet %}

span.label_hero strong {
    padding-left: 4px;
}

.discover-hero .product-form__submit.product-hero-button{
    color: #FFF !important;
    background-color: #bd1e18 !important;
}

.product-hero-button {
    color: #FFF !important;
    background-color: #bd1e18 !important;
    opacity: 1;
    padding: 10px 30px;
    font-family: 'Open Sans Condensed', sans-serif;
    font-size: 18px;
    letter-spacing: 0.09em;
    line-height: 140%;
    text-transform: uppercase;
    margin: 0 auto;
    text-align: center;
}

.product-hero-button:hover {
    opacity: 0.9 !important;
}

.label_hero {
    color: #bd1e18;
    font-family: 'Open Sans Condensed';
    font-weight: 400;
    font-size: .70rem;
    line-height: 1.4;
    letter-spacing: .05rem;
    text-transform: uppercase;
    display: inline-flex;
    justify-content: center;
    align-items: center;
    width: auto;
    padding: 10px;
    height: 1.95rem;
    border-radius: .5rem;
    background-color: #fff;
}

.discover-hero__after-cta-text {
    color: #FFFFFF;
    font-family: "Open Sans";
    font-style: normal;
    font-weight: 400;
    font-size: 13.6px;
    line-height: 121%;
    margin-top: 1.1rem;
}

/* desktop only */
@media screen and (min-width: 768px) {
    .discover-hero__after-cta-text {
        color: #CF0000;
        color: color(display-p3 0.7424 0.1172 0.0956);
        font-size: 17.694px;
    }
}
.discover-hero h1 {
    color: #FFFFFF;
}

.discover-hero {
  position: relative;
  height: 100vh;
  width: 100%;
  overflow: hidden;
}

.discover-hero__image {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
}


.discover-hero__image img {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.discover-hero__content {
    max-width: 25rem;
    position: absolute;
    top: 50%;
    left: 0%;
    transform: translate(26%, -50%);
    text-align: left;
    color: #fff;
    width: 90%;
}

.discover-hero h1 {
    font-size: 2.3rem;
    font-weight: 600;
    line-height: 1.2;
    margin-top: 1.2rem;
    letter-spacing: .02em;
    margin-bottom: 0.6rem;
    font-variation-settings: "wdth" 80;
    font-family: Open Sans Condensed;
}

.desktop-only {
  display: block;
}

ul.banner_badges_list {
    display: flex;
    gap: 5px;
    padding: 0;
    list-style: none;
    justify-content: center;
}
.banner_badges_list li img {
    max-width: 90px;
}
.discover-hero h2 {
    font-family: Open Sans Condensed;
    font-size: 2.5rem;
    font-weight: 350;
    line-height: 115%;
    color: #fff;
    margin-bottom: 2rem;
    font-variation-settings: "wdth" 78;
    margin-top: 0;
    text-transform: uppercase;
    max-width: 22rem;
}

.discover-hero h2 s {
    position: relative;
    display: inline-block;
    text-decoration: none;
    font-size: 85%;
}

.discover-hero h2 s:before,
.discover-hero h2 s::before {
    content: "";
    border-top: 1.92px solid #BD1E18;
    position: absolute;
    top: 50%;
    left: 0;
    display: block;
    transform: rotate(20deg);
    width: 100%;
}


