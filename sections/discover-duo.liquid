{% schema %}
{
  "name": "Discover Duo",
  "settings": [
    {
      "type": "header",
      "content": "Hero Section"
    },
    {
      "type": "image_picker",
      "id": "desktop_image",
      "label": "Desktop Image"
    },
    {
      "type": "image_picker",
      "id": "mobile_image",
      "label": "Mobile Image"
    },
    {
      "type": "text",
      "id": "hero_title",
      "label": "Hero Title"
    },
    {
      "type": "text",
      "id": "hero_subtitle",
      "label": "Hero Subtitle"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button Text"
    },
    {
      "type": "header",
      "content": "Clinical Results Section"
    },
    {
      "type": "text",
      "id": "clinical_title",
      "label": "Clinical Results Title"
    },
    {
      "type": "image_picker",
      "id": "clinical_image",
      "label": "Clinical Results Image"
    },
    {
      "type": "header",
      "content": "Awards Section"
    },
    {
      "type": "text",
      "id": "awards_title",
      "label": "Awards Title"
    },
    {
      "type": "header",
      "content": "Products Section"
    },
    {
      "type": "text",
      "id": "products_title",
      "label": "Products Title"
    }
  ],
  "blocks": [
    {
      "type": "clinical_stat",
      "name": "Clinical Statistic",
      "settings": [
        {
          "type": "text",
          "id": "percentage",
          "label": "Percentage"
        },
        {
          "type": "text",
          "id": "description",
          "label": "Description"
        }
      ]
    },
    {
      "type": "award",
      "name": "Award",
      "settings": [
        {
          "type": "image_picker",
          "id": "award_logo",
          "label": "Award Logo"
        },
        {
          "type": "text",
          "id": "award_text",
          "label": "Award Text"
        }
      ]
    },
    {
      "type": "product",
      "name": "Product",
      "settings": [
        {
          "type": "image_picker",
          "id": "product_image",
          "label": "Product Image"
        },
        {
          "type": "text",
          "id": "product_title",
          "label": "Product Title"
        },
        {
          "type": "text",
          "id": "product_description",
          "label": "Product Description"
        },
        {
          "type": "url",
          "id": "product_link",
          "label": "Product Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Discover Duo",
      "category": "Product"
    }
  ]
}
{% endschema %}

<div class="discover-duo">
  <!-- Hero Section -->
  <div class="discover-duo__hero">
    <div class="discover-duo__hero-image">
      <img src="{{ section.settings.desktop_image | img_url: 'master' }}" 
           class="desktop-only" 
           alt="{{ section.settings.hero_title }}">
      <img src="{{ section.settings.mobile_image | img_url: 'master' }}" 
           class="mobile-only" 
           alt="{{ section.settings.hero_title }}">
    </div>
    <div class="discover-duo__hero-content">
      <h1>{{ section.settings.hero_title }}</h1>
      <p>{{ section.settings.hero_subtitle }}</p>
      {% if section.settings.button_link != blank %}
        <a href="{{ section.settings.button_link }}" class="button">
          {{ section.settings.button_text }}
        </a>
      {% endif %}
    </div>
  </div>

  <!-- Clinical Results Section -->
  <div class="discover-duo__clinical">
    <div class="discover-duo__clinical-content">
      <h2>{{ section.settings.clinical_title }}</h2>
      <div class="discover-duo__clinical-stats">
        {% for block in section.blocks %}
          {% if block.type == 'clinical_stat' %}
            <div class="clinical-stat">
              <span class="percentage">{{ block.settings.percentage }}</span>
              <p>{{ block.settings.description }}</p>
            </div>
          {% endif %}
        {% endfor %}
      </div>
      <div class="discover-duo__clinical-image">
        <img src="{{ section.settings.clinical_image | img_url: 'master' }}" 
             alt="Clinical Results">
      </div>
    </div>
  </div>

  <!-- Awards Section -->
  <div class="discover-duo__awards">
    <h2>{{ section.settings.awards_title }}</h2>
    <div class="discover-duo__awards-grid">
      {% for block in section.blocks %}
        {% if block.type == 'award' %}
          <div class="award-item">
            <img src="{{ block.settings.award_logo | img_url: 'master' }}" 
                 alt="Award">
            <p>{{ block.settings.award_text }}</p>
          </div>
        {% endif %}
      {% endfor %}
    </div>
  </div>

  <!-- Products Section -->
  <div class="discover-duo__products">
    <h2>{{ section.settings.products_title }}</h2>
    <div class="discover-duo__products-grid">
      {% for block in section.blocks %}
        {% if block.type == 'product' %}
          <div class="product-item">
            <img src="{{ block.settings.product_image | img_url: 'master' }}" 
                 alt="{{ block.settings.product_title }}">
            <h3>{{ block.settings.product_title }}</h3>
            <p>{{ block.settings.product_description }}</p>
            {% if block.settings.product_link != blank %}
              <a href="{{ block.settings.product_link }}" class="button">
                Learn More
              </a>
            {% endif %}
          </div>
        {% endif %}
      {% endfor %}
    </div>
  </div>
</div>

{% stylesheet %}
.discover-duo {
  width: 100%;
  max-width: 100%;
}

.discover-duo__hero {
  position: relative;
  height: 100vh;
  overflow: hidden;
}

.discover-duo__hero-image img {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.discover-duo__hero-content {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  text-align: center;
  color: #fff;
}

.desktop-only {
  display: block;
}

.mobile-only {
  display: none;
}

.discover-duo__clinical {
  padding: 80px 0;
}

.discover-duo__clinical-stats {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 30px;
  margin: 40px 0;
}

.discover-duo__awards {
  padding: 60px 0;
  background-color: #f7f7f7;
}

.discover-duo__awards-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
  gap: 40px;
  margin-top: 40px;
}

.discover-duo__products {
  padding: 80px 0;
}

.discover-duo__products-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 40px;
  margin-top: 40px;
}

@media screen and (max-width: 768px) {
  .desktop-only {
    display: none;
  }

  .mobile-only {
    display: block;
  }

  .discover-duo__clinical-stats {
    grid-template-columns: 1fr;
  }

  .discover-duo__products-grid {
    grid-template-columns: 1fr;
  }
}
{% endstylesheet %} 