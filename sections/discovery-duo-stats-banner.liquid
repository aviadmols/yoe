{{ 'discovery-duo-stats-banner.css' | asset_url | stylesheet_tag }}

<section
  class="dd-stats{% if section.settings.layout_mode == 'single' %} dd-stats--single{% endif %}{% render 'pdp-scroll-animate-class' %}"
  style="--dd-stats-padding-top: {{ section.settings.padding_top }}px; --dd-stats-padding-bottom: {{ section.settings.padding_bottom }}px;"
  aria-label="{{ section.settings.headline | default: 'Visibly transformed' | escape }}"
>
  {%- assign cta_product = section.settings.cta_product -%}
  {%- assign cta_product_secondary = section.settings.cta_product_secondary -%}
  {%- assign cta_variant = cta_product.selected_or_first_available_variant -%}

  <div class="dd-stats__inner">
    <header class="dd-stats__header">
      {%- if section.settings.headline != blank -%}
        <h2 class="dd-stats__headline">{{ section.settings.headline | escape }}</h2>
      {%- endif -%}
    </header>

    {%- if section.blocks.size > 0 -%}
      <div class="dd-stats__products">
        {%- for block in section.blocks -%}
          {%- if block.type == 'product_result' -%}
            <article class="dd-stats__product" {{ block.shopify_attributes }}>
              <div class="dd-stats__product-body">
                <div class="dd-stats__product-copy">
                  {%- if block.settings.product_name != blank -%}
                    {%- assign product_name = block.settings.product_name | escape -%}
                    {%- assign product_name = product_name | replace: ' LIGHT', ' <span class="dd-stats__product-name-light">LIGHT</span>' | replace: ' Light', ' <span class="dd-stats__product-name-light">Light</span>' -%}
                    <h3 class="dd-stats__product-name">{{ product_name }}</h3>
                  {%- endif -%}

                  <ul class="dd-stats__stats">
                    {%- for index in (1..4) -%}
                      {%- assign top_key = 'stat_' | append: index | append: '_top' -%}
                      {%- assign percent_key = 'stat_' | append: index | append: '_percentage' -%}
                      {%- assign bottom_key = 'stat_' | append: index | append: '_bottom' -%}
                      {%- if block.settings[percent_key] != blank -%}
                        <li class="dd-stats__stat">
                          {%- if block.settings[top_key] != blank -%}
                            <span class="dd-stats__stat-top">{{ block.settings[top_key] | escape }}</span>
                          {%- endif -%}
                          <span class="dd-stats__stat-percentage">{{ block.settings[percent_key] | escape }}</span>
                          {%- if block.settings[bottom_key] != blank -%}
                            <span class="dd-stats__stat-bottom">{{ block.settings[bottom_key] | escape }}</span>
                          {%- endif -%}
                        </li>
                      {%- endif -%}
                    {%- endfor -%}
                  </ul>
                </div>

                <figure class="dd-stats__media" aria-label="{{ block.settings.product_name | escape }} before and after image">
                  {%- if block.settings.before_after_image != blank -%}
                    {{ block.settings.before_after_image | image_url: width: 700 | image_tag:
                      loading: 'lazy',
                      class: 'dd-stats__media-image',
                      alt: block.settings.before_after_image.alt | default: block.settings.product_name
                    }}
                  {%- else -%}
                    <span class="dd-stats__media-placeholder" aria-hidden="true"></span>
                  {%- endif -%}
                </figure>
              </div>

              {%- if block.settings.disclaimer != blank -%}
                <p class="dd-stats__product-disclaimer">{{ block.settings.disclaimer | escape }}</p>
              {%- endif -%}
            </article>
          {%- endif -%}
        {%- endfor -%}
      </div>
    {%- endif -%}

    {%- if section.settings.cta_label != blank -%}
      <form class="dd-stats__form" method="post" action="{{ routes.cart_add_url }}"{% if section.settings.cta_go_to_checkout %} data-dd-checkout{% endif %} {% render 'dd-cta-checkout-attrs', apply_discount: section.settings.cta_apply_discount, discount_code: section.settings.cta_checkout_discount_code %}>
        {% render 'dd-cta-cart-inputs',
          primary_product: cta_product,
          secondary_product: cta_product_secondary,
          include_secondary: true
        %}
        <button class="dd-stats__cta" type="submit"{% if cta_variant == blank %} disabled{% endif %}>
          {% render 'dd-cta-offer',
            offer_display: section.settings.cta_offer_display,
            label: section.settings.cta_label,
            discount_text: section.settings.cta_discount_text,
            compare_price: section.settings.cta_compare_price,
            price: section.settings.cta_price,
            product: cta_product,
            legacy_style: 'stats',
            label_class: 'dd-stats__cta-label',
            offer_class: 'dd-stats__cta-offer',
            compare_class: 'dd-stats__cta-old',
            price_class: 'dd-stats__cta-price'
          %}
          <span class="dd-stats__cta-arrow" aria-hidden="true">›</span>
        </button>
      </form>
    {%- endif -%}

    <ul class="dd-stats__trust">
      {%- if section.settings.trust_1 != blank -%}<li>{% render 'dd-check-icon' %}{{ section.settings.trust_1 | escape }}</li>{%- endif -%}
      {%- if section.settings.trust_2 != blank -%}<li>{% render 'dd-check-icon' %}{{ section.settings.trust_2 | escape }}</li>{%- endif -%}
      {%- if section.settings.trust_3 != blank -%}<li>{% render 'dd-check-icon' %}{{ section.settings.trust_3 | escape }}</li>{%- endif -%}
    </ul>
  </div>
</section>

{% schema %}
{
  "name": "Duo – Stats banner",
  "tag": "section",
  "class": "section-dd-stats",
  "settings": [
    {
      "type": "text",
      "id": "headline",
      "label": "Headline",
      "default": "Visibly Transformed."
    },
    {
      "type": "select",
      "id": "layout_mode",
      "label": "Layout",
      "default": "duo",
      "options": [
        { "value": "duo", "label": "Two products (side by side)" },
        { "value": "single", "label": "Single product" }
      ]
    },
    {
      "type": "header",
      "content": "CTA"
    },
    {
      "type": "product",
      "id": "cta_product",
      "label": "CTA product"
    },
    {
      "type": "product",
      "id": "cta_product_secondary",
      "label": "CTA bonus product (optional)",
      "info": "When set, both products are added to cart on CTA click."
    },
    {
      "type": "checkbox",
      "id": "cta_go_to_checkout",
      "label": "Go directly to checkout",
      "default": false,
      "info": "When enabled: clears cart, adds selected product(s), then redirects to checkout. When disabled: standard add to cart."
    },
    {
      "type": "checkbox",
      "id": "cta_apply_discount",
      "label": "Apply discount code on checkout",
      "default": false
    },
    {
      "type": "text",
      "id": "cta_checkout_discount_code",
      "label": "Checkout discount code",
      "info": "Applied after products are added to cart, before redirect to checkout."
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "CTA label",
      "default": "SEE IT ON YOUR SKIN -"
    },
    {
      "type": "select",
      "id": "cta_offer_display",
      "label": "CTA offer display",
      "options": [
        { "value": "legacy", "label": "Auto (theme default)" },
        { "value": "discount", "label": "Discount text (e.g. | 15% OFF)" },
        { "value": "price", "label": "Compare + sale price" }
      ],
      "default": "legacy"
    },
    {
      "type": "text",
      "id": "cta_discount_text",
      "label": "Discount suffix",
      "default": "| 15% OFF"
    },
    {
      "type": "text",
      "id": "cta_compare_price",
      "label": "Fallback compare-at price",
      "default": "$86"
    },
    {
      "type": "text",
      "id": "cta_price",
      "label": "Fallback price",
      "default": "$48"
    },
    {
      "type": "header",
      "content": "Trust signals"
    },
    {
      "type": "text",
      "id": "trust_1",
      "label": "Trust item 1",
      "default": "30-Day Money-Back"
    },
    {
      "type": "text",
      "id": "trust_2",
      "label": "Trust item 2",
      "default": "Free Express Shipping"
    },
    {
      "type": "text",
      "id": "trust_3",
      "label": "Trust item 3",
      "default": "First-Time Offer"
    },
    {
      "type": "header",
      "content": "Section padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Top padding",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "default": 72
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Bottom padding",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "default": 72
    }
  ],
  "blocks": [
    {
      "type": "product_result",
      "name": "Product result",
      "limit": 2,
      "settings": [
        {
          "type": "text",
          "id": "product_name",
          "label": "Product name",
          "default": "Ympossible Cream"
        },
        {
          "type": "paragraph",
          "content": "Upload one composed before/after image for this product. This single image is what appears in the result area."
        },
        {
          "type": "image_picker",
          "id": "before_after_image",
          "label": "Single before / after image"
        },
        { "type": "text", "id": "stat_1_top", "label": "Stat 1 top", "default": "Fine lines and wrinkles reduced by up to" },
        { "type": "text", "id": "stat_1_percentage", "label": "Stat 1 percentage", "default": "68.9%" },
        { "type": "text", "id": "stat_1_bottom", "label": "Stat 1 bottom", "default": "in only 4 weeks" },
        { "type": "text", "id": "stat_2_top", "label": "Stat 2 top", "default": "Skin firmness improved by up to" },
        { "type": "text", "id": "stat_2_percentage", "label": "Stat 2 percentage", "default": "66.7%" },
        { "type": "text", "id": "stat_2_bottom", "label": "Stat 2 bottom", "default": "in only 4 weeks" },
        { "type": "text", "id": "stat_3_top", "label": "Stat 3 top", "default": "Frown line depth reduced by up to" },
        { "type": "text", "id": "stat_3_percentage", "label": "Stat 3 percentage", "default": "50.0%" },
        { "type": "text", "id": "stat_3_bottom", "label": "Stat 3 bottom", "default": "in only 4 weeks" },
        { "type": "text", "id": "stat_4_top", "label": "Stat 4 top", "default": "Skin barrier function improved by up to" },
        { "type": "text", "id": "stat_4_percentage", "label": "Stat 4 percentage", "default": "65.7%" },
        { "type": "text", "id": "stat_4_bottom", "label": "Stat 4 bottom", "default": "in only 4 weeks" },
        { "type": "text", "id": "disclaimer", "label": "Disclaimer", "default": "*In an instrumental clinical trial after twice-daily use." }
      ]
    }
  ],
  "presets": [
    {
      "name": "Duo – Stats banner",
      "blocks": [
        { "type": "product_result", "settings": { "product_name": "Ympossible Cream Light", "stat_1_top": "Immediate hydration boost by up to", "stat_1_percentage": "127.8%", "stat_1_bottom": "upon application", "stat_2_top": "Skin firmness improved by up to", "stat_2_percentage": "66.7%", "stat_2_bottom": "in only 4 weeks", "stat_3_top": "Fine lines and wrinkles reduced by up to", "stat_3_percentage": "65.1%", "stat_3_bottom": "in only 8 weeks", "stat_4_top": "Under-eye wrinkle depth reduced by", "stat_4_percentage": "50.0%", "stat_4_bottom": "in only 4 weeks" } },
        { "type": "product_result", "settings": { "product_name": "Ympossible Cream" } }
      ]
    }
  ]
}
{% endschema %}
