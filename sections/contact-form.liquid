    max-width: 100%;
    order: -1;
    padding-bottom: 25px!important;
}


.contact__button {
    margin-top: 25px!important;
}

.contact h2 {
    text-align: center;
    margin-top: 15px !important;
    margin-bottom: 25px !important;
}
.split-section {
    display: flex;
    flex-wrap: wrap;
    flex-direction: row-reverse;
    align-items: center;
    padding-top: 25px !important;
    padding-bottom: 25px !important;
}

.split-section__text {
    margin-bottom: 15px !important;
}
}


    .split-section {
    display: flex;
    flex-wrap: wrap;
    flex-direction: row-reverse;
    align-items: center;
    padding-top: 5rem;
    padding-bottom: 5rem;
}

.contact h2 {
    text-align: center;
    margin-bottom: 3rem;
}

.text-heading {
    font-weight: 350!important;
}

    .contact__fields {
        display: grid;
        grid-template-columns: repeat(1, 1fr)!important;
        grid-column-gap: 2rem;
    }


.split-section__contact,
.split-section__content {
  flex: 1;

}

h3.form-status__message {
    color: #666460;
    text-align: center;
    font-family: "Open Sans";
    font-size: 1.8215rem;
    font-style: normal;
    font-weight: 350;
    line-height: 2.1858rem;
    letter-spacing: 0.2732rem;
    text-transform: uppercase;
}

    .form-status__icon {
      
