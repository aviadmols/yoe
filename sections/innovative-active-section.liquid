{% schema %}
{
  "name": "Innovative Actives",
  "settings": [
      {
            "type": "text",
            "id": "custom-class",
            "label": "Custom Class"
        },
         {
            "type": "text",
            "id": "main-title",
            "label": "Title",
            "default": "INNOVATIVE ACTIVES MEET ADVANCED BIOTECHNOLOGY"
        },
        {
            "type": "header",
            "content": "Right Image Content"
        },
        {
            "type": "image_picker",
            "id": "right-bg-image",
            "label": "Right Image"
        },
         {
      "type": "video",
      "id": "video_file",
      "label": "Background Video File"
    },

        {
            "type": "richtext",
            "id": "right-title",
            "label": "Caption Text"
        },
         {
            "type": "richtext",
            "id": "main-title-cus",
            "label": "Title"
        },
         {
            "type": "richtext",
            "id": "sub-title-cus",
            "label": "Sub Title"
        },
        {
            "type": "url",
            "id": "btn-url-content",
            "label": "Button Url"
        },
        {
          "type": "header",
          "content": "Ingredients Modal Settings"
        },
        {
          "type": "richtext",
          "id": "ingredients_list",
          "label": "Full Ingredients List",
          "info": "This will appear in the modal when 'See full ingredients list' is clicked"
        }
  ],
  "blocks": [
    {
      "type": "gold_standard",
      "name": "Gold Standard Item",
      "settings": [
        {
          "type": "image_picker",
          "id": "icon",
          "label": "Icon"
        },
        {
          "type": "richtext",
          "id": "title",
          "label": "Title"
        },
        {
          "type": "text",
          "id": "description",
          "label": "Description"
        },
        {
          "type": "image_picker",
          "id": "popup_image",
          "label": "Popup Image"
        },
        {
          "type": "richtext",
          "id": "popup_text",
          "label": "Popup Text"
        }
      ]
    },
    {
      "type": "power_player",
      "name": "Power Player Item",
      "settings": [
        {
          "type": "image_picker",
          "id": "icon",
          "label": "Icon"
        },
        {
          "type": "richtext",
          "id": "title",
          "label": "Title"
        },
        {
          "type": "text",
          "id": "description",
          "label": "Description"
        },
        {
          "type": "image_picker",
          "id": "popup_image",
          "label": "Popup Image"
        },
        {
          "type": "richtext",
          "id": "popup_text",
          "label": "Popup Text"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Innovative Actives",
      "category": "Custom"
    }
  ]
}
{% endschema %}
{% assign poster_image = section.settings.right-bg-image | img_url: 'master' %}
<div class="innovative-actives {{ section.settings.custom-class }}">
    <div class="page-width">
        <div class="inner-cus-innov">
             <!-- Left section -->
            <div class="left-content-sec-innov">
 <h1>{{ section.settings.main-title }}</h1>

  <!-- Gold Standards -->
  <div class="gold-standards">
    <h3>THE GOLD STANDARDS</h3>
    <div class="grid">
      {% for block in section.blocks %}
        {% if block.type == 'gold_standard' %}
          <div class="item-section" role="button" tabindex="0"
              data-popup-trigger="{{ section.id }}"
              data-popup-image="{% if block.settings.popup_image %}{{ block.settings.popup_image | img_url: 'large' }}{% endif %}"
              data-popup-title="{{ block.settings.title | strip_html | escape }}"
              data-block-id="{{ block.id }}">
            <div class="popup-text-src" hidden data-popup-content="{{ block.id }}">
              {{ block.settings.popup_text }}
            </div>
            {% if block.settings.icon %}
              <img src="{{ block.settings.icon | image_url }}" alt="{{ block.settings.title | strip_html }}">
            {% endif %}
            {{ block.settings.title }}<br>{{ block.settings.description }}
          </div>
        {% endif %}
      {% endfor %}
    </div>
  </div>

  <!-- Power Players -->
  <div class="power-players">
    <h3>THE POWER PLAYERS</h3>
    <div class="grid">
      {% for block in section.blocks %}
        {% if block.type == 'power_player' %}
          <div class="item-section" role="button" tabindex="0"
              data-popup-trigger="{{ section.id }}"
              data-popup-image="{% if block.settings.popup_image %}{{ block.settings.popup_image | img_url: 'large' }}{% endif %}"
              data-popup-title="{{ block.settings.title | strip_html | escape }}"
              data-block-id="{{ block.id }}">
            <div class="popup-text-src" hidden data-popup-content="{{ block.id }}">
              {{ block.settings.popup_text }}
            </div>
            {% if block.settings.icon %}
              <img src="{{ block.settings.icon | image_url }}" alt="{{ block.settings.title | strip_html }}">
            {% endif %}
            {{ block.settings.title }}<br>{{ block.settings.description }}
          </div>
        {% endif %}
      {% endfor %}
    </div>
  </div>
    <!-- Hidden container for preloading popup images -->
    <div style="display: none !important;" aria-hidden="true" id="popup-preload-{{ section.id }}">
        {% for block in section.blocks %}
            {% if block.settings.popup_image %}
                <img src="{{ block.settings.popup_image | img_url: 'large' }}" alt="Preload {{ block.settings.title | strip_html }}" loading="eager">
            {% endif %}
        {% endfor %}
    </div>
    <a href="#" class="cta-btn" data-ingredients-trigger="{{ section.id }}">See full ingredients list</a>
  </div>

{% comment %} Right section {% endcomment %}
<div class="right-section-image-innov">
{% if section.settings.video_file != blank %}
     {{ section.settings.video_file | video_tag: 
    autoplay: true, 
    loop: true, 
    muted: true, 
    playsinline: true, 
    controls: false, 
    class: 'background-video', 
    preload: 'metadata', 
    aria_label: 'Background video', 
    poster: poster_image
}}
  {% elsif section.settings.right-bg-image != blank %}
    <div class="background-image" style="background-image: url('{{ section.settings.right-bg-image | img_url: 'master' }}');"></div>
  {% endif %}

  <div class="content-overlay">
    <h3>{{ section.settings.right-title }}</h3>
    <h1>{{ section.settings.main-title-cus }}</h1>
    <p class="utilizing-content">{{ section.settings.sub-title-cus }}</p>
    <a href="{{ section.settings.btn-url-content }}" class="learn-more-btn">Learn More
      <svg xmlns="http://www.w3.org/2000/svg" width="10" height="17" viewBox="0 0 10 17" fill="none">
        <path d="M1 16L8 8.5L1 1" stroke="#666460" stroke-width="2"/>
      </svg>
    </a>
  </div>
</div>



  </div>
  </div>
</div>

<div class="popup" id="yoe-popup-{{ section.id }}" style="display:none;">
  <div class="in_popup">
    <div class="popup-content">
      <div class="popup-text">
        <div class="popup-close" data-popup-close="{{ section.id }}">Close</div>
        <div>
          <h3 class="popup-title" id="yoe-popup-title-{{ section.id }}"></h3>
          <p class="popup-description" id="yoe-popup-desc-{{ section.id }}"></p>
        </div>
      </div>
      <img src="" alt="" class="popup-image" id="yoe-popup-image-{{ section.id }}">
    </div>
  </div>
</div>

<!-- Ingredients Modal -->
<div class="ingredients-modal popup" id="ingredients-modal-{{ section.id }}" style="display:none;">

    <div class="in_popup">
        <div class="popup-content">
            <div class="popup-text ingredients-modal-content">
                <button class="ingredients-modal-close popup-close" data-ingredients-close="{{ section.id }}">
                    Close
                </button>
                <div class="ingredients-modal-body">
                    <h4 class="ingredients-product-name">{{ product.title }}</h4>
                    <h3 class="ingredients-heading popup-title">Ingredients</h3>
                    <div class="ingredients-text">
                        {{ section.settings.ingredients_list }}
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

