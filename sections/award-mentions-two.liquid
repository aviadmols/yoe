{% schema %}
{
  "name": "Award Mentions Two",
  "tag": "section",
  "class": "award-mentions-section-2-wrapper",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Section Title",
      "default": "Award-Winning Ritual, Trusted by Experts"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background Color",
      "default": "#F7F6F5"
    },
    {
      "type": "header",
      "content": "Section Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Top",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Bottom",
      "default": 60
    }
  ],
  "blocks": [
    {
      "type": "award_card",
      "name": "Award Card",
      "settings": [
        {
          "type": "image_picker",
          "id": "badge_image",
          "label": "Badge Image",
          "info": "Award badge or seal image"
        },
        {
          "type": "image_picker",
          "id": "logo_image",
          "label": "Publication Logo",
          "info": "Logo of the publication (e.g., Cosmopolitan)"
        },
        {
          "type": "text",
          "id": "subheading",
          "label": "Subheading",
          "default": "Best Moisturizer 2024"
        },
        {
          "type": "textarea",
          "id": "quote",
          "label": "Quote",
          "default": "\"Behold: the rich-but-light skin-soothing cream you didn't know you were missing.\""
        }
      ]
    },
    {
      "type": "mention",
      "name": "Mention",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Publication Name",
          "default": "FORBES"
        },
        {
          "type": "textarea",
          "id": "quote",
          "label": "Quote",
          "default": "\"Luxury skincare that actually delivers on its promises.\""
        }
      ]
    }
  ],
  "max_blocks": 10,
  "presets": [
    {
      "name": "Award Mentions Two",
      "category": "Custom"
    }
  ]
}
{% endschema %}

{% comment %}
  Section: Award and Mentions Section 2
  Description: Combined section with award cards on top and simple mentions on bottom
  Top: Award cards with badge image, logo, subheading, and quote (3 columns on desktop, vertical stack on mobile)
  Bottom: Simple mentions with title and quote (3 columns with dividers on desktop, carousel on mobile)
{% endcomment %}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<section class="award-mentions-section-2 section-{{ section.id }}-padding" data-section-id="{{ section.id }}">
  <div class="page-width">
    {%- if section.settings.title != blank -%}
      <h2 class="award-mentions-2__title">{{ section.settings.title }}</h2>
    {%- endif -%}

    <!-- Award Cards Section (Top) - Vertical Stack on Mobile -->
    <div class="award-mentions-2__awards">
      {%- for block in section.blocks -%}
        {%- if block.type == 'award_card' -%}
          <div class="award-mentions-2__award-card" {{ block.shopify_attributes }}>
            {%- if block.settings.badge_image != blank -%}
              <div class="award-mentions-2__badge">
                <img
                  src="{{ block.settings.badge_image | image_url: width: 300 }}"
                  alt="{{ block.settings.badge_image.alt | escape }}"
                  loading="lazy"
                  height="auto"
                >
              </div>
            {%- endif -%}

            {%- if block.settings.logo_image != blank -%}
              <div class="award-mentions-2__logo">
                <img
                  src="{{ block.settings.logo_image | image_url: width: 400 }}"
                  alt="{{ block.settings.logo_image.alt | escape }}"
                  loading="lazy"
                  width="200"
                  height="auto"
                >
              </div>
            {%- endif -%}

            {%- if block.settings.subheading != blank -%}
              <h3 class="award-mentions-2__subheading">{{ block.settings.subheading }}</h3>
            {%- endif -%}

            {%- if block.settings.quote != blank -%}
              <p class="award-mentions-2__quote">{{ block.settings.quote }}</p>
            {%- endif -%}
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>

    <!-- Mentions Section (Bottom) - Carousel on Mobile -->
    <div class="award-mentions-2__mentions-wrapper">
      <div class="award-mentions-2__mentions" data-mentions-carousel>
        {%- assign mention_blocks = section.blocks | where: 'type', 'mention' -%}
        {%- assign visible_mention_index = 0 -%}
        {%- for block in mention_blocks -%}
          {%- if block.settings.title != blank or block.settings.quote != blank -%}
            {%- assign visible_mention_index = visible_mention_index | plus: 1 -%}
            <div class="award-mentions-2__mention{% if forloop.last != true %} has-divider{% endif %}" {{ block.shopify_attributes }}>
              {%- if block.settings.title != blank -%}
                <h4 class="award-mentions-2__mention-title">{{ block.settings.title }}</h4>
              {%- endif -%}

              {%- if block.settings.quote != blank -%}
                <p class="award-mentions-2__mention-quote">{{ block.settings.quote }}</p>
              {%- endif -%}
            </div>
          {%- endif -%}
        {%- endfor -%}
      </div>
      <!-- Mentions Dots Navigation (Mobile Only) -->
      <div class="award-mentions-2__mentions-dots" data-mentions-dots></div>
    </div>
  </div>
</section>

<style>
/* Main Section */
.award-mentions-section-2 {
  background-color: {{ section.settings.background_color }};
}

.award-mentions-2__title {
  font-family: "Open Sans Condensed", sans-serif;
  font-weight: 300;
  text-align: center;
  font-size: 2.5rem;
  color: #666460;
  letter-spacing: 0.3rem;
  text-transform: uppercase;
  margin: 0 0 3rem;
}

/* Award Cards Grid - Desktop */
.award-mentions-2__awards {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 2rem;
  margin-bottom: 4rem;
}

.award-mentions-2__award-card {
  text-align: center;
  padding: 1rem;
}

.award-mentions-2__badge {
  margin-bottom: 1.5rem;
}

.award-mentions-2__badge img {
  height: auto;
  margin: 0 auto;
    max-height: 250px;
    max-width: 100%;
}

.award-mentions-2__logo {
  margin-bottom: 1rem;
}

.award-mentions-2__logo img {
  max-width: 200px;
  height: auto;
  margin: 0 auto;
}

.award-mentions-2__subheading {
  font-family: "Open Sans Condensed", sans-serif;
    color: #666460;
    text-align: center;
    font-size: 18.247px;
    font-style: normal;
    font-weight: 650;
    line-height: 120%; /* 21.897px */
    letter-spacing: 0.05em;
    text-transform: uppercase;
    max-width: 350px;
    margin: 0 0 0.75rem;
    margin-left: auto;
    margin-right: auto;
}

.award-mentions-2__quote {
    font-family: "Open Sans", sans-serif;
    color: #666460;
    max-width: 350px;
    margin-left: auto;
    margin-right: auto;
    font-weight: 300;
    font-style: Italic;
    font-size: 30.73px;
    line-height: 120%;
    letter-spacing: 0;
    text-align: center;
}

/* Mentions Grid - Desktop */
.award-mentions-2__mentions-wrapper {
  padding-top: 2rem;
}

.award-mentions-2__mentions {
  display: flex;
  justify-content: center;
  align-items: stretch;
  gap: 2rem;
}

.award-mentions-2__mention {
  flex: 1;
  text-align: center;
  padding: 0 1.5rem;
  position: relative;
}

.award-mentions-2__mention.has-divider::after {
  content: '';
  position: absolute;
  right: 0;
  top: 0;
  height: 100%;
  width: 1px;
  background-color: rgba(102, 100, 96, 0.3);
}

.award-mentions-2__mention-title {
    font-family: "Open Sans Condensed", sans-serif;
    color: #666460;
    margin: 0 0 0.5rem;
    font-weight: 400;
    font-size: 48.02px;
    line-height: 120%;
    letter-spacing: 0;
    text-align: center;
    text-transform: uppercase;

}

.award-mentions-2__mention-quote {
    color: #666460;
    margin: 0;
    font-family: "Open Sans", sans-serif;
    font-weight: 300;
    font-style: Italic;
    font-size: 29.77px;
    line-height: 120%;
    letter-spacing: 0;
    text-align: center;


}

/* Dots Navigation - Hidden on Desktop */
.award-mentions-2__mentions-dots {
  display: none;
}

/* Tablet Styles */
@media screen and (max-width: 990px) {
  .award-mentions-2__title {
    font-size: 2rem;
    letter-spacing: 0.2rem;
  }

  .award-mentions-2__awards {
    gap: 1.5rem;
  }

  .award-mentions-2__badge img {
    max-width: 100%;
      max-height: 200px;
  }

  .award-mentions-2__logo img {
    max-width: 160px;
  }

  .award-mentions-2__subheading {
      font-size: 15px;
      letter-spacing: 0.15em;
      font-weight: 700;

  }

  .award-mentions-2__quote {
      font-size: 20px;
      line-height: 142%;
  }

  .award-mentions-2__mention-title {
      font-size: 33.89px;
  }

  .award-mentions-2__mention-quote {
      font-size: 20px;
      line-height: 142%;
  }
}

/* Mobile Styles */
@media screen and (max-width: 767px) {
  .award-mentions-2__title {
    font-size: 1.6rem;
    letter-spacing: 0.15rem;
    margin-bottom: 2rem;
    line-height: 1.3;
  }

  /* Awards - Vertical Stack on Mobile */
  .award-mentions-2__awards {
    display: flex;
    flex-direction: column;
    gap: 2.5rem;
    margin-bottom: 2.5rem;
  }

  .award-mentions-2__award-card {
    padding: 0;
  }

  .award-mentions-2__badge img {
      max-width: 100%;
      max-height: 220px;
  }

  .award-mentions-2__logo img {
    max-width: 160px;
  }

  .award-mentions-2__subheading {
      font-size: 15px;
      letter-spacing: 0.15em;
      font-weight: 700;
  }

  .award-mentions-2__quote {
      font-size: 20px;
      line-height: 142%;
  }

  /* Mentions Carousel Mobile */
  .award-mentions-2__mentions-wrapper {
    padding-top: 1.5rem;
    overflow: hidden;
  }

  .award-mentions-2__mentions {
    display: flex;
    transition: transform 0.4s ease;
      justify-content: start;
      gap: 0;
  }

  .award-mentions-2__mention {
    flex: 0 0 100%;
    min-width: 100%;
    max-width: 100%;
    padding: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
  }

  .award-mentions-2__mention.has-divider::after {
    display: none;
  }

  .award-mentions-2__mention-title {
      font-size: 33.89px;
  }

  .award-mentions-2__mention-quote {
      font-size: 20px;
      line-height: 142%;
      margin-left: auto;
    margin-right: auto;
  }

  /* Dots Navigation - Mobile (Mentions only) */
  .award-mentions-2__mentions-dots {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 10px;
    margin-top: 1.5rem;
    height: 10px;
  }

  .award-mentions-2__mentions-dots .dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background-color: rgba(102, 100, 96, 0.3);
    cursor: pointer;
    transition: background-color 0.3s ease, transform 0.3s ease;
  }

  .award-mentions-2__mentions-dots .dot.active {
    background-color: #666460;
    transform: scale(1.2);
  }

  .award-mentions-2__mentions-dots .dot:hover {
    background-color: rgba(102, 100, 96, 0.6);
  }
}
</style>

<script>
(function() {
  document.addEventListener('DOMContentLoaded', function() {
    var section = document.querySelector('.award-mentions-section-2[data-section-id="{{ section.id }}"]');
    if (!section) return;

    // Mentions Carousel only
    var mentionsCarousel = section.querySelector('[data-mentions-carousel]');
    var mentionsDots = section.querySelector('[data-mentions-dots]');
    var mentionCards = mentionsCarousel ? mentionsCarousel.querySelectorAll('.award-mentions-2__mention') : [];

    var mentionsCurrentIndex = 0;
    var isInitialized = false;
    var autoplayInterval = null;
    var autoplayDelay = 4000; // 4 seconds between slides

    function initMentionsCarousel() {
      if (!mentionsCarousel || !mentionsDots || mentionCards.length === 0) return;
      if (isInitialized) return;

      isInitialized = true;
      mentionsCurrentIndex = 0;

      // Clear existing dots
      mentionsDots.innerHTML = '';

      // Create dots only for actual slides
      for (var i = 0; i < mentionCards.length; i++) {
        var dot = document.createElement('span');
        dot.className = 'dot' + (i === 0 ? ' active' : '');
        dot.setAttribute('data-index', i);
        mentionsDots.appendChild(dot);
      }

      var dots = mentionsDots.querySelectorAll('.dot');

      function goToSlide(index) {
        // Loop back to first slide after last
        if (index >= mentionCards.length) index = 0;
        if (index < 0) index = mentionCards.length - 1;

        mentionsCarousel.style.transform = 'translateX(-' + (index * 100) + '%)';

        dots.forEach(function(dot, i) {
          dot.classList.toggle('active', i === index);
        });

        mentionsCurrentIndex = index;
      }

      // Autoplay function
      function startAutoplay() {
        stopAutoplay();
        autoplayInterval = setInterval(function() {
          goToSlide(mentionsCurrentIndex + 1);
        }, autoplayDelay);
      }

      function stopAutoplay() {
        if (autoplayInterval) {
          clearInterval(autoplayInterval);
          autoplayInterval = null;
        }
      }

      function resetAutoplay() {
        stopAutoplay();
        startAutoplay();
      }

      // Click on dots
      dots.forEach(function(dot) {
        dot.addEventListener('click', function() {
          var index = parseInt(this.getAttribute('data-index'));
          goToSlide(index);
          resetAutoplay();
        });
      });

      // Touch/Swipe support
      var touchStartX = 0;
      var touchEndX = 0;
      var isSwiping = false;

      mentionsCarousel.addEventListener('touchstart', function(e) {
        touchStartX = e.changedTouches[0].screenX;
        isSwiping = true;
        stopAutoplay();
      }, { passive: true });

      mentionsCarousel.addEventListener('touchmove', function(e) {
        // Prevent default scroll when swiping horizontally
        if (isSwiping) {
          var currentX = e.changedTouches[0].screenX;
          var diff = Math.abs(touchStartX - currentX);
          if (diff > 10) {
            // Horizontal swipe detected
          }
        }
      }, { passive: true });

      mentionsCarousel.addEventListener('touchend', function(e) {
        if (!isSwiping) return;
        touchEndX = e.changedTouches[0].screenX;
        handleSwipe();
        isSwiping = false;
        resetAutoplay();
      }, { passive: true });

      function handleSwipe() {
        var diff = touchStartX - touchEndX;
        if (Math.abs(diff) > 50) {
          if (diff > 0) {
            // Swipe left - go to next
            goToSlide(mentionsCurrentIndex + 1);
          } else if (diff < 0) {
            // Swipe right - go to previous
            goToSlide(mentionsCurrentIndex - 1);
          }
        }
      }

      // Initialize at first slide and start autoplay
      goToSlide(0);
      startAutoplay();
    }

    function destroyCarousel() {
      if (autoplayInterval) {
        clearInterval(autoplayInterval);
        autoplayInterval = null;
      }
      isInitialized = false;
      mentionsCurrentIndex = 0;
      if (mentionsCarousel) mentionsCarousel.style.transform = '';
      if (mentionsDots) mentionsDots.innerHTML = '';
    }

    function setupCarousel() {
      if (window.innerWidth <= 767) {
        if (!isInitialized) {
          initMentionsCarousel();
        }
      } else {
        // Reset on desktop
        destroyCarousel();
      }
    }

    setupCarousel();

    // Handle resize
    var resizeTimeout;
    window.addEventListener('resize', function() {
      clearTimeout(resizeTimeout);
      resizeTimeout = setTimeout(function() {
        setupCarousel();
      }, 250);
    });
  });
})();
</script>
