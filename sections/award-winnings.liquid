{% stylesheet %}
  
.section-award-winning h2 {
    font-family: Open Sans Condensed;
    font-weight: 400;
    text-align: center;
    font-size: 2.955rem;
    display: block !important;
    margin: auto;
    color: #666460;
    letter-spacing: .3rem;
}
.section-award-winning .title-wrapper-with-link {
    text-align: center!important;
    display: block;
}
.section-award-winning h3 {
    font-size: 1rem;
    font-weight: 510;
    color: #666460; 
    font-family: Open Sans Condensed;
    max-width: 500px;
    margin: auto !important;
    text-align: center;
    text-transform: uppercase;
    letter-spacing: .8px;
    line-height: 120% !important;
}
.section-award-winning p {
    font-size: 1.7rem;
    color: #666460;
    line-height: normal;
    font-style: italic;
    font-weight: 300;
    max-width: 450px;
    margin: auto!important;
    text-align: center;
     font-family: "Open Sans", sans-serif;
     line-height: 110%;
}
.section-award-winning img {
    width: 235px;
}
.multicolumn-card .multicolumn-card__image-wrapper {
    padding: 0px;
}
.multicolumn-card.content-container {
    background: transparent !IMPORTANT;
}
.multicolumn-card.content-container .media img.multicolumn-card__image {
    position: relative;
    height: 11rem;
    margin: auto;
}
.multicolumn-card.content-container .media {
    padding: 0px !important;
}

@media only screen and (max-width:992px) {
.section-award-winning h2 {
    font-size: 2.4rem;
    line-height: normal;
}

}

@media(max-width: 767px) and (min-width: 320px){
  .section-award-winning h2 {
    font-size: 29px;
}
.section-award-winning p {
    font-size: 24px;
}
}

@media(max-width: 1200px) and (min-width: 991px){
.awards-heading {
    font-size: 23px !important;
}
}

.template-page-dou-shop .section-award-winning .button--primary{
    background: #BD1E18;
    color: #fff;
    border: none;
    transition: all 0.3s ease;
    border: 0;
}

.template-page-dou-shop .section-award-winning .button--primary:hover{
    background: #BD1E18;
    border: 1px solid #BD1E18;
}


{% endstylesheet %}

<script>
    (function() {
        document.addEventListener('submit', function(e) {
            var form = e.target;

            if (!form.classList.contains('award-winning-cart-form')) return;

            e.preventDefault();
            e.stopPropagation();
            e.stopImmediatePropagation();

            var discountCode = form.getAttribute('data-discount-code');
            var variantId = form.querySelector('input[name="id"]').value;
            var submitButton = form.querySelector('button[type="submit"]');

            if (submitButton.disabled) return;

            submitButton.disabled = true;
            var originalHTML = submitButton.innerHTML;
            submitButton.textContent = 'Adding to cart...';

            function openMiniCart() {
                var miniCart = document.getElementById('rebuy-cart');
                if (miniCart) {
                    miniCart.classList.add('is-visible');
                    miniCart.setAttribute('aria-hidden', 'false');
                }
            }

            function resetButton() {
                submitButton.innerHTML = originalHTML;
                submitButton.disabled = false;
            }

            function addToCart() {
                fetch('/cart/add.js', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'Accept': 'application/json'
                    },
                    body: JSON.stringify({
                        items: [{
                            id: variantId,
                            quantity: 1
                        }]
                    })
                })
                    .then(function(response) {
                        if (!response.ok) throw new Error('Cart add failed');
                        return response.json();
                    })
                    .then(function(data) {
                        submitButton.textContent = 'Added!';

                        document.documentElement.dispatchEvent(new CustomEvent('cart:refresh', {
                            bubbles: true
                        }));

                        setTimeout(function() {
                            openMiniCart();
                            setTimeout(function() {
                                resetButton();
                            }, 2000);
                        }, 300);
                    })
                    .catch(function(error) {
                        console.error('Error:', error);
                        submitButton.textContent = 'Try Again';
                        setTimeout(resetButton, 2000);
                    });
            }

            if (discountCode && discountCode.trim() !== '') {
                var code = discountCode.trim();

                fetch('/discount/' + encodeURIComponent(code), {
                    method: 'GET',
                    redirect: 'manual'
                })
                    .then(function() {
                        setTimeout(function() {
                            addToCart();
                        }, 300);
                    })
                    .catch(function(error) {
                        console.error('Discount error:', error);
                        addToCart();
                    });
            } else {
                addToCart();
            }

            return false;
        }, true);
    })();
</script>