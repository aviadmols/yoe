{% schema %}
{
  "name": "Discover Title",
  "settings": [
    {
      "type": "richtext",
      "id": "title",
      "label": "Title"
    },
    {
      "type": "textarea",
      "id": "subtitle",
      "label": "Subtitle"
    }
  ],
  "blocks": [
    {
      "type": "benefit",
      "name": "Benefit",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Benefit Text"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Discover Title",
      "category": "Text",
      "blocks": [
        { "type": "benefit", "settings": { "text": "Instant hydration" } },
        { "type": "benefit", "settings": { "text": "Deep, long-lasting nourishment" } },
        { "type": "benefit", "settings": { "text": "Strengthens the skin barrier" } },
        { "type": "benefit", "settings": { "text": "Boosts collagen production" } },
        { "type": "benefit", "settings": { "text": "Targets fine lines and wrinkles" } },
        { "type": "benefit", "settings": { "text": "Addresses hyperpigmentation" } }
      ]
    }
  ]
}
{% endschema %}

<div class="discover-title">
  <div class="discover-title__container">
    <h2>{{ section.settings.title }}</h2>
    <div class="discover-title__subtitle">
      {{ section.settings.subtitle }}
    </div>
    <div class="discover-title__benefits">
      {% for block in section.blocks %}
        <div class="discover-title__benefit">
          <span class="check-icon"><svg xmlns="http://www.w3.org/2000/svg" width="19" height="13" viewBox="0 0 19 13" fill="none">
<path d="M1.20002 6.35002L6.70002 11.3L17.7 1.40002" stroke="#666460" stroke-width="2.2"/>
</svg></span> <span>{{ block.settings.text }}</span>
        </div>
      {% endfor %}
    </div>
  </div>
</div>

{% stylesheet %}
.discover-title {
  padding: 4rem 1.75rem;
  text-align: center;
}

.discover-title__container {
  max-width: 67rem;
  margin: 0 auto;
}

.discover-title h2 {
    font-family: Open Sans;
    font-size: 2.8rem;
    font-weight: 350;
    line-height: 3.5rem;
    letter-spacing: .199rem;
    text-align: center;
    text-transform: uppercase;
    margin-bottom: 2rem;
    font-variation-settings: "wdth" 80;
}
.discover-title h2 b {
    font-weight: 450;
}
.discover-title__subtitle {
    font-family: Open Sans;
    font-size: 1.35rem;
    font-weight: 470;
    max-width: 628px;
    margin: 0 auto 2.5rem;
    line-height: 1.7rem;
    text-align: center;
    font-variation-settings: "wdth" 80;
}
.discover-title h2 p {
    margin: 0;
}
.discover-title__benefits {
    grid-template-columns: repeat(3, 1fr);
    display: grid;
    gap: 1rem;
    justify-content: space-between;
    margin-top: 2rem;
    max-width: 900px;
    margin: 0px auto;
    text-align: left;
}
.discover-title h2 strong {
    font-weight: 500;
}
.discover-title__benefit {
    display: flex;
    align-items: center;
    font-family: Open Sans;
    font-size: 0.8rem;
    font-weight: 500;
    color: #666460;
    line-height: 1.5;
}

.check-icon {
    background: #fff;
    width: 1.8rem;
    height: 1.8rem;
    border-radius: 100%;
    display: inline-flex;
    margin-right: 0.7rem;
    justify-content: center;
    align-items: center;
}
.check-icon svg {
    width: 16px;
}

@media screen and (max-width: 992px) {
.discover-title h2 {
    font-size: 2.5rem;
}
}

@media screen and (max-width: 768px) {
  .discover-title {
    padding: 50px 30px;
  }

  .discover-title h2 {
    color: #666460;
    text-align: center;
    margin-top: 0px;
    margin-bottom: 40px;
    font-family: "Open Sans";
    font-size: 24px;
    font-style: normal;
    font-weight: 400;
    line-height: 120%;
    letter-spacing: 2.8px;
    text-transform: uppercase;
  }

  .discover-title__subtitle {
    color: #666460;
    text-align: center;
    font-family: "Open Sans";
    font-style: normal;
    line-height: 140%;
    letter-spacing: 0.14px;
  }


  .check-icon svg {
    width: 13px;
  }

  .discover-title__benefit {
    justify-content: flex-start;
max-width: 320px;
margin-left: auto;
margin-right: auto;
    font-size: 16px!important;
margin-bottom: 22px;
  }

  .check-icon {
         font-size: 1rem;
        margin-right: 8px!important;
        width: 33px;
        height: 33px;
        min-width: 33px;
        min-height: 33px;
  }
    .discover-title__benefits {
        flex-direction: column;
        margin-top: 50px;
        align-items: flex-start;
        gap: 1rem;
      }
    .discover-title__benefits {
        grid-template-columns: repeat(1, 1fr);
        gap: 0;
    }

     .discover-title__benefit {
        max-width: 100%;
        margin-left: 0!important;
        margin-bottom: 10px !important;
    }
}

@media only screen and (max-width:575px) {
.discover-title__subtitle {
        padding-left: 4rem;
        padding-right: 4rem;
    }
  }
@media only screen and (max-width:490px) {
.discover-title__subtitle {
        padding-left: 2rem;
        padding-right: 2rem;
    }
  }

{% endstylesheet %}
