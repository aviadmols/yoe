{{ 'discovery-duo-refillable.css' | asset_url | stylesheet_tag }}

<section
  class="dd-refill"
  style="--dd-refill-padding-top: {{ section.settings.padding_top }}px; --dd-refill-padding-bottom: {{ section.settings.padding_bottom }}px;"
  aria-label="{{ section.settings.alt_text | default: 'Responsive refillable banner' | escape }}"
>
  {%- assign desktop_banner = section.settings.desktop_image -%}
  {%- assign mobile_banner = section.settings.mobile_image -%}
  {%- assign fallback_banner = desktop_banner | default: mobile_banner -%}
  {%- assign banner_alt = section.settings.alt_text | default: fallback_banner.alt | default: 'Responsive refillable banner' -%}

  <div class="dd-refill__inner">
    {%- if fallback_banner != blank -%}
      <picture class="dd-refill__picture">
        {%- if mobile_banner != blank -%}
          <source
            media="(max-width: 749px)"
            srcset="
              {{ mobile_banner | image_url: width: 480 }} 480w,
              {{ mobile_banner | image_url: width: 750 }} 750w,
              {{ mobile_banner | image_url: width: 900 }} 900w
            "
            sizes="100vw"
          >
        {%- endif -%}
        {{ fallback_banner | image_url: width: 2400 | image_tag:
          loading: 'lazy',
          widths: '750, 1100, 1500, 1800, 2200, 2400',
          sizes: '100vw',
          class: 'dd-refill__image',
          alt: banner_alt
        }}
      </picture>
    {%- else -%}
      <div class="dd-refill__placeholder">
        <span>Choose desktop and mobile banners</span>
      </div>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Duo - Refillable Banner",
  "tag": "section",
  "class": "section-dd-refill",
  "settings": [
    {
      "type": "header",
      "content": "Responsive banner"
    },
    {
      "type": "image_picker",
      "id": "desktop_image",
      "label": "Desktop banner"
    },
    {
      "type": "image_picker",
      "id": "mobile_image",
      "label": "Mobile banner"
    },
    {
      "type": "text",
      "id": "alt_text",
      "label": "Image alt text",
      "default": "Refillable product banner"
    },
    {
      "type": "header",
      "content": "Section padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Top padding",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Bottom padding",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "default": 0
    }
  ],
  "presets": [
    {
      "name": "Duo - Refillable Banner"
    }
  ]
}
{% endschema %}
