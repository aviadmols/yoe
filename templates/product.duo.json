    "yoe_slider_info_7KGQyX": {
      "type": "Yoe-slider-info",
      "blocks": {
        "image_with_text_GFgafM": {
          "type": "image_with_text",
          "settings": {
            "carousel_image": "shopify://shop_images/SynerGenius_517f05e0-d942-40e9-9f23-05f038a00d7d.webp",
            "popup_image": "shopify://shop_images/SynerGenius_FULL.webp",
            "title": "SynerGenius™",
            "popup_text": "SynerGenius™ An essential element of the Ympossible Cream is the SynerGenius™ complex, a proprietary blend of botanical and bioengineered actives that works to deeply hydrate, repair, and visibly revitalize skin. Key to SynerGenius™ is the use of a highly sophisticated process of advanced encapsulation delivery system, designed to enhance the stability and effectiveness of active ingredients to deliver stable, maximally potent ingredients in a gentle, time-released manner. The actives in SynerGenius™ range from the gold standards of skincare (vitamin C, hyaluronic acid, ceramides, panthenol) to less familiar ingredients, including calming chebula seed extract; anti-inflammatory diosmin; red algae, a potent antioxidant; Squalene an effective emollient, and a vegan epidermal growth factor that is biocompatible with the growth factors found naturally in skin. In a nod to founder Hazel Guo’s Japanese heritage, the ingredients in SynerGenius™ are solubilized in mineral-rich rice water, a longstanding facet of Japanese beauty culture."
          }
        },
        "image_with_text_PqPnzn": {
          "type": "image_with_text",
          "settings": {
            "carousel_image": "shopify://shop_images/Chebula.webp",
            "popup_image": "shopify://shop_images/Chebula_FULL.webp",
            "title": "Chebula",
            "popup_text": "Chebula, a powerful antioxidant, helps protect skin against environmental damage, calms visible redness, and promotes a more balanced complexion."
          }
        },
        "image_with_text_Wtm8pY": {
          "type": "image_with_text",
          "settings": {
            "carousel_image": "shopify://shop_images/Timut_pepper.webp",
            "popup_image": "shopify://shop_images/Timut_pepper_FULL.webp",
            "title": "Timut pepper",
            "popup_text": "Timut pepper, native to the southern Himalayan region, contains a diverse profile of bioactive alkaloids—phytochemicals that are shown to improve skin tone. Timut pepper extract also activates the cellular signaling pathways, thereby supporting skin renewal for a healthy epidermis."
          }
        },
        "image_with_text_qAxVw7": {
          "type": "image_with_text",
          "settings": {
            "carousel_image": "shopify://shop_images/Hyaluronic_Acid.webp",
            "popup_image": "shopify://shop_images/Hyaluronic_Acid_FULL.webp",
            "title": "Hyaluronic acid",
            "popup_text": "Hyaluronic acid is naturally found in the body where it is responsible for hydration, lubrication, and tissue stability. Hyaluronic acid attracts and holds up to 500 times its weight in water, which serves to plump skin and minimize the appearance of fine lines."
          }
        },
        "image_with_text_T3aVj3": {
          "type": "image_with_text",
