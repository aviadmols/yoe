{% schema %}
{
  "name": "Discover Add to Cart",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Title"
    },
    {
      "type": "text",
      "id": "sub_title",
      "label": "Sub Title"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description"
    },
    {
      "type": "product",
      "id": "product",
      "label": "Product"
    },
    {
      "type": "text",
      "id": "discount_code",
      "label": "Discount Code",
      "info": "Optional: Enter a discount code to apply when adding to cart"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button Text",
      "default": "Add to Cart"
    }
  ],
  "presets": [
    {
      "name": "Discover Add to Cart",
      "category": "Product"
    }
  ]
}
{% endschema %}

<div class="discover-add-to-cart">
    <div class="discover-add-to-cart__container">
        <h2>{{ section.settings.title }} <span>{{ section.settings.sub_title }}</span></h2>
        <div class="description">{{ section.settings.description }}</div>
        <div class="add-to-cart-action">
            <form method="post" action="/cart/add" class="discover-cart-form" data-discover-form="true" data-discount-code="{{ section.settings.discount_code }}">
                <input type="hidden" name="id" value="{{ section.settings.product.selected_or_first_available_variant.id }}">
                <input type="hidden" name="quantity" value="1">
                <button type="submit" class="product-form__submit button button--primary" data-discover-submit="true">
                    {{ section.settings.button_text }}
                </button>
            </form>
        </div>
    </div>
</div>

{% stylesheet %}
.discover-add-to-cart {
    padding: 6rem 1.75rem;
    text-align: center;
    background-color: #f7f7f7;
}

.discover-add-to-cart .description {
    margin-top: 0;
    margin-bottom: 0;
    width: fit-content;
    font-variation-settings: 'wdth' 80;
    margin-right: auto;
    margin-left: auto;
}

.discover-add-to-cart__container {
    /* max-width: 80.55rem; */
    margin: 0 auto;
}

.discover-add-to-cart h2 {
    font-variation-settings: "wdth" 80;
    color: #666460;
    text-align: center;
    font-family: Open Sans Condensed;
    font-size: 2.7rem;
    font-style: normal;
    margin-top: 0;
    margin-bottom: 2rem;
    font-weight: 600;
    line-height: 134%;
    letter-spacing: .2475rem;
    text-transform: uppercase;
}

.discover-add-to-cart h2 span {
    width: 100%;
    display: block;
    font-weight: normal;
}

.discover-add-to-cart .description {
    color: #bd1e18;
    text-align: center;
    font-family: Open Sans Condensed;
    font-size: 1.8rem;
    font-style: normal;
    font-weight: 400;
    line-height: 2.3009rem;
}

.add-to-cart-action {
    margin-top: 3rem;
}

body #insta-feed {
    padding-top: 40px;
}

.add-to-cart-action button.product-form__submit.button.button--primary {
    max-width: fit-content;
    width: 100%;
    font-weight: 700;
    padding: 10px 30px;
    font-family: 'Open Sans Condensed', sans-serif;
    font-size: 18px;
    letter-spacing: 0.09em;
    line-height: 140%;
    text-transform: uppercase;
    margin: 0 auto;
    text-align: center;
    height: auto;
    opacity: 1 !important;
}

@media screen and (min-width: 768px) {
    /* .discover-add-to-cart .description {
        max-width: 29rem;
    } */

    .discover-add-to-cart h2 br {
        display: none;
    }
}

@media screen and (max-width: 1190px) {
    .discover-add-to-cart {
        padding: 3.6rem 1.75rem;
    }
}

@media screen and (max-width: 992px) {
    .discover-add-to-cart h2 {
        font-size: 2.2rem;
        line-height: normal;
    }
}

@media screen and (max-width: 768px) {
    .discover-add-to-cart .description {
        color: #BD1E18 !important;
        text-align: center !important;
        font-size: 24px !important;
        font-style: normal !important;
        font-weight: 400 !important;
        line-height: 121% !important;
    }

    .discover-add-to-cart h2 {
        color: #666460;
        text-align: center;
        font-style: normal;
        font-weight: 700;
        line-height: normal;
        letter-spacing: 3.253px;
        text-transform: uppercase;
        margin-left: auto;
        margin-right: auto;
    }

    .discover-add-to-cart .description {
        font-size: 24px;
        line-height: 36px;
    }

    .discover-add-to-cart__container {
        max-width: 100%;
        margin: 0 auto;
    }
}
{% endstylesheet %}

<script>
    (function() {
        // Use a more specific event handler with capture phase
        document.addEventListener('submit', function(e) {
            var form = e.target;

            // Only handle our specific form
            if (!form.classList.contains('discover-cart-form')) return;

            // Stop all propagation to prevent other scripts from handling this
            e.preventDefault();
            e.stopPropagation();
            e.stopImmediatePropagation();

            var discountCode = form.getAttribute('data-discount-code');
            var variantId = form.querySelector('input[name="id"]').value;
            var submitButton = form.querySelector('button[type="submit"]');

            // Prevent multiple submissions
            if (submitButton.disabled) return;

            submitButton.disabled = true;
            var originalText = submitButton.textContent;
            submitButton.textContent = 'Adding to cart...';

            function openMiniCart() {
                var miniCart = document.getElementById('rebuy-cart');
                if (miniCart) {
                    miniCart.classList.add('is-visible');
                    miniCart.setAttribute('aria-hidden', 'false');
                }
            }

            function resetButton(text) {
                submitButton.textContent = text || originalText;
                submitButton.disabled = false;
            }

            function addToCart() {
                fetch('/cart/add.js', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'Accept': 'application/json'
                    },
                    body: JSON.stringify({
                        items: [{
                            id: variantId,
                            quantity: 1
                        }]
                    })
                })
                    .then(function(response) {
                        if (!response.ok) throw new Error('Cart add failed');
                        return response.json();
                    })
                    .then(function(data) {
                        submitButton.textContent = 'Added!';

                        // Trigger cart update event for theme
                        document.documentElement.dispatchEvent(new CustomEvent('cart:refresh', {
                            bubbles: true
                        }));

                        // Open mini cart after brief delay
                        setTimeout(function() {
                            openMiniCart();
                            // Reset button after a moment
                            setTimeout(function() {
                                resetButton(originalText);
                            }, 2000);
                        }, 300);
                    })
                    .catch(function(error) {
                        console.error('Error:', error);
                        resetButton('Try Again');
                        alert('Failed to add to cart. Please try again.');
                    });
            }

            // Apply discount if provided
            if (discountCode && discountCode.trim() !== '') {
                var code = discountCode.trim();

                // Method 1: Navigate to discount URL then add to cart
                fetch('/discount/' + encodeURIComponent(code), {
                    method: 'GET',
                    redirect: 'manual'
                })
                    .then(function() {
                        // Wait a moment for discount to apply
                        setTimeout(function() {
                            addToCart();
                        }, 300);
                    })
                    .catch(function(error) {
                        console.error('Discount error:', error);
                        // Add to cart even if discount fails
                        addToCart();
                    });
            } else {
                addToCart();
            }

            return false;
        }, true); // Use capture phase to intercept before other handlers
    })();
</script>