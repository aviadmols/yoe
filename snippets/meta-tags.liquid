  {% if request.path == '/pages/faqs' %}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "How much does shipping cost?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "You can enjoy free shipping in the USA. We provide shipping at no cost at all. Other countries may vary; please see the checkout to find shipping costs."
      }
    },
    {
      "@type": "Question",
      "name": "Where do you ship?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "We ship to the U.S., UK, and parts of the EU (excluding Alaska and Hawaii)."
      }
    },
    {
      "@type": "Question",
      "name": "What forms of payment do you accept?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "We accept Visa, MasterCard, American Express, Discover, Apple Pay, and PayPal."
      }
    },
    {
      "@type": "Question",
      "name": "How do I cancel my order?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "You can cancel your order by opening your confirmation email. Additionally, you can reach out to our customer service team at support@yoeandco.com. Please let us know the reason for the cancellation. If your order has already been processed or shipped, please review our return policy."
      }
    },
    {
      "@type": "Question",
      "name": "How do I track my order?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Once you place an order, you should receive a confirmation email which will include a custom order tracking number and a link to our tracking page on our website. Tracking information can be delayed after your order is placed. It can take up to 24-48 hours for you to get the order number. If you do not see any updates right away, feel free to reach our support team."
      }
    },
    {
      "@type": "Question",
      "name": "How do I update/skip my subscription items?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "1. Log in to your account. 2. Click 'Subscriptions'. 3. Locate your subscription and click 'Manage'. 4. Click 'Change Items'. Proceed to complete the steps to successfully update your subscription."
      }
    },
    {
      "@type": "Question",
      "name": "What do I do if my item(s) arrives damaged?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "We’re sorry your item(s) have damage! Not to worry! All of our products come with a complete guarantee. Email us at support@yoeandco.com with images and an explanation, and we will do our best to accommodate and get you a replacement for you to enjoy. While we may not be able to guarantee your exact order is replaced due to potential stock issues, we’ll be sure to resolve the situation as best we can!"
      }
    },
    {
      "@type": "Question",
      "name": "When will I get my refund?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Once your return has been processed, you will be notified through email when the refund has been issued. It typically takes 7-10 business days for the refund to reflect in your account."
      }
    },
    {
      "@type": "Question",
      "name": "How do I cancel my subscription?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "1. Log in to your account. 2. Click 'Subscriptions'. 3. Locate your subscription and click 'Manage'. 4. Click 'Cancel'. Proceed to complete the steps to successfully cancel your subscription."
      }
    },
    {
      "@type": "Question",
      "name": "How do I make a return?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Reach out to our customer support team at support@yoeandco.com to understand the return process with your order number and details about the item you wish to return. Print the shipping label and drop off your return at a FedEx shipping center location."
      }
    },
    {
      "@type": "Question",
      "name": "Can I use Ympossible Cream or Ympossible Cream Light morning and night?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes. We recommend using our products morning and night."
      }
    },
    {
      "@type": "Question",
      "name": "Can I use the product while I'm pregnant or nursing?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes, Yoé products are clinically and dermatologist tested. However, we always recommend consulting with your healthcare provider before introducing new skincare products during pregnancy or nursing."
      }
    }
  ]
