<!-- Section Template -->
{% schema %}
{
  "name": "Yoe Video Banner",
  "settings": [
    {
      "type": "image_picker",
      "id": "desktop_placeholder_image",
      "label": "Desktop Placeholder Image"
    },
    {
      "type": "image_picker",
      "id": "mobile_placeholder_image",
      "label": "Mobile Placeholder Image"
    },
    {
      "type": "url",
      "id": "video_url",
      "label": "Video URL"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading"
    },
    {
      "type": "text",
      "id": "text",
      "label": "Text"
    }
  ],
  "presets": [
    {
      "name": "Yoe Video Banner",
      "category": "Custom"
    }
  ]
}
{% endschema %}
<div class="position_mobile">
<div style="max-width: 100vw;">
  <div class="padding-top-bottom-70 page-width padding-right-left  custom-video-banner scroll-trigger animate--slide-in" onmouseover="showCursor()" onmouseout="hideCursor()" onclick="toggleVideo(this)">
    <div class="custom-video-banner__placeholder">
      <div class="text_on_video">
        <h3 class="image-with-text__heading">{{ section.settings.heading }}</h3>
        <p class="image-with-text__text">{{ section.settings.text }}</p>
      </div>
      <img class="desktop-only" src="{{ section.settings.desktop_placeholder_image | img_url: 'master' }}" alt="Desktop Placeholder Image">
      <img class="mobile-only" src="{{ section.settings.mobile_placeholder_image | img_url: '' }}" alt="Mobile Placeholder Image">
      <div class="custom-video-banner__play-btn " onclick="toggleVideo2(this)">
        <video class="custom-video-banner__video" src="{{ section.settings.video_url }}" ></video>
      </div>
    </div>
  </div>
  <div class="custom-cursor play" id="customCursor">
<svg xmlns="http://www.w3.org/2000/svg" width="129" height="129" viewBox="0 0 129 129" fill="none">
<path d="M58.2829 0.459412C26.0209 3.77785 0.878601 31.0892 0.878601 64.2736C0.878601 99.6966 29.5413 128.43 64.8771 128.43C100.213 128.43 128.876 99.6966 128.876 64.2736C128.876 52.0006 125.434 40.5441 119.47 30.7995C119.497 30.7995 58.2829 0.459412 58.2829 0.459412Z" fill="#666460" style="fill:#666460;fill:color(display-p3 0.4000 0.3922 0.3765);fill-opacity:1;"/>
</svg>
<span>PLAY</span></div>
</div>
</div>
<style>

 .playing .custom-video-banner__video {

    height: auto !important;
}

 .playing   .custom-video-banner__placeholder {
    overflow: hidden!important;
}

  .playing  .custom-video-banner__play-btn {
position: absolute;
    width: 100% !important;
    top: 0px;
    bottom: 0px;
    left: 0px;
    right: 0px;
}
  .playing .custom-video-banner__video {
    display: block;
width: 100%!important;
  }
 .playing  img {
   opacity: 0;
     transition: opacity 0.5s ease;
 }
 .playing   .text_on_video {
    opacity: 0;
  transition: opacity 0.5s ease;
  }


.playing img {
 
   transition: opacity 0.5s ease;
}

.playing .text_on_video {

   transition: opacity 0.5s ease;
}
</style>
<script>
document.addEventListener('mousemove', function(e) {

    // Check if the user is on a mobile device
    if (window.innerWidth <= 768) {
        // Select the video element
        var videoElement = document.querySelector('.custom-video-banner__video');
        
        // Set the source URL for the video
        videoElement.src = 'https://cdn.shopify.com/videos/c/o/v/b356a2f3793749d0ab2caa9f18e953d4.mp4';
        
        // Ensure the video loads the new source
        videoElement.load();
    }

    var cursor = document.getElementById('customCursor');
    var cursorCirclelearnmore = document.getElementById('cursorCirclelearnmore');
    var cursorCircleclose = document.getElementById('cursorCircleclose');
    var banner = document.querySelector('.custom-video-banner');
    var cards = document.querySelectorAll('.cards_block .swiper-slide');
    var popups = document.querySelectorAll('.popup-image, .popup');
    var rect = banner.getBoundingClientRect();

    // Update cursor position for custom-video-banner
    if (e.clientX >= rect.left && e.clientX <= rect.right && e.clientY >= rect.top && e.clientY <= rect.bottom) {
        cursor.style.top = e.pageY + 'px';
        cursor.style.left = e.pageX + 'px';
        showCursor();
    } else {
        hideCursor();
    }

    // Check if cursor is over any .cards_block .swiper-slide
    let cursorInCard = false;
    cards.forEach(function(card) {
        var cardRect = card.getBoundingClientRect();
        if (e.clientX >= cardRect.left && e.clientX <= cardRect.right && e.clientY >= cardRect.top && e.clientY <= cardRect.bottom) {
            cursorCirclelearnmore.style.top = e.pageY + 'px';
            cursorCirclelearnmore.style.left = e.pageX + 'px';
            showLearnMoreCursor();
            cursorInCard = true;
        }
    });

    // Hide the learnmore circle if not over any .cards_block .swiper-slide
    if (!cursorInCard) {
        hideLearnMoreCursor();
    }

    // Check if cursor is over any popup elements
    let cursorInPopup = false;
    popups.forEach(function(popup) {
        var popupRect = popup.getBoundingClientRect();
        if (e.clientX >= popupRect.left && e.clientX <= popupRect.right && e.clientY >= popupRect.top && e.clientY <= popupRect.bottom) {
            cursorCircleclose.style.top = e.pageY + 'px';
            cursorCircleclose.style.left = e.pageX + 'px';
            showCloseCursor();
            cursorInPopup = true;
        }
    });

    // Hide the close circle if not over any popup elements
    if (!cursorInPopup) {
        hideCloseCursor();
    }
});


function toggleVideo(button) {
    var video = button.querySelector('.custom-video-banner__video');
    var cursor = document.getElementById('customCursor');
   var cursorText = cursor.querySelector('span');
    var banner = document.querySelector('.custom-video-banner');

   if (video.paused) {
        video.play();
        
        setTimeout(function() {
            cursor.classList.add('pause');
            cursor.classList.remove('play');
            cursorText.innerHTML = 'PAUSE'; 
            banner.classList.add('playing');
        }, 200); 

    } else {
        video.pause();

        setTimeout(function() {
            cursor.classList.add('play');
            cursor.classList.remove('pause');
            cursorText.innerHTML = 'PLAY';
            banner.classList.remove('playing');
        }, 200); 
    }
}

function showCursor() {
    var cursor = document.getElementById('customCursor');
    cursor.classList.add('show');
}

function hideCursor() {
    var cursor = document.getElementById('customCursor');
    cursor.classList.remove('show');
}

function showLearnMoreCursor() {
    var cursorCirclelearnmore = document.getElementById('cursorCirclelearnmore');
    cursorCirclelearnmore.classList.add('show');
}

function hideLearnMoreCursor() {
    var cursorCirclelearnmore = document.getElementById('cursorCirclelearnmore');
    cursorCirclelearnmore.classList.remove('show');
}

function showCloseCursor() {
    var cursorCircleclose = document.getElementById('cursorCircleclose');
    cursorCircleclose.classList.add('show');
}

function hideCloseCursor() {
    var cursorCircleclose = document.getElementById('cursorCircleclose');
    cursorCircleclose.classList.remove('show');
}
</script>
