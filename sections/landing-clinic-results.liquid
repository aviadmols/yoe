{% comment %}
  Landing Clinical Results – Figma 2499-482.
  Full-width: content left (69px padding desktop), image right (touches edge).
  Mobile: content on top, image below.
  Content: title + category blocks (heading + 2 stat lines) + disclaimer.
{% endcomment %}

{% schema %}
{
  "name": "Landing Clinical Results",
  "tag": "section",
  "class": "lp-clinic-results-section",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Clinical Image"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "CLINICAL RESULTS"
    },
    {
      "type": "text",
      "id": "disclaimer",
      "label": "Disclaimer (desktop only)",
      "default": "*Clinical study, 26 participants aged 35-63, 8-week period"
    }
  ],
  "blocks": [
    {
      "type": "category",
      "name": "Result Category",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Category heading"
        },
        {
          "type": "text",
          "id": "percentage_1",
          "label": "Percentage 1"
        },
        {
          "type": "text",
          "id": "description_1",
          "label": "Description 1"
        },
        {
          "type": "text",
          "id": "percentage_2",
          "label": "Percentage 2"
        },
        {
          "type": "text",
          "id": "description_2",
          "label": "Description 2"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Landing Clinical Results",
      "category": "Landing",
      "blocks": [
        {
          "type": "category",
          "settings": {
            "heading": "TEXTURE & BALANCE",
            "percentage_1": "96%",
            "description_1": "Agree complexion looks balanced",
            "percentage_2": "92%",
            "description_2": "Agree skin texture is improved"
          }
        },
        {
          "type": "category",
          "settings": {
            "heading": "HEALTH & VITALITY",
            "percentage_1": "85%",
            "description_1": "Agree skin looks healthier",
            "percentage_2": "88%",
            "description_2": "Agree skin looks revitalized"
          }
        },
        {
          "type": "category",
          "settings": {
            "heading": "FIRMNESS & YOUTHFULNESS",
            "percentage_1": "88%",
            "description_1": "Agree skin looks firmer",
            "percentage_2": "90%",
            "description_2": "Agree skin looks younger"
          }
        }
      ]
    }
  ]
}
{% endschema %}

<section
  class="lp-clinic-results-section w-full overflow-hidden"
  style="background-color: var(--lp-clinic-results-bg, #F9F8F5);"
  aria-label="{{ section.settings.title | default: 'Clinical Results' }}"
>
  {%- comment -%} No outer horizontal padding – 100% width. Content has left padding; image bleeds right. {%- endcomment -%}
  <div class="lp-clinic-results-container flex flex-col md:flex-row w-full min-h-0">
    {%- comment -%} Content left – 69px padding on desktop; mobile: top, with horizontal padding {%- endcomment -%}
    <div class="lp-clinic-results-content order-1 w-full md:flex-shrink-0 md:min-w-0 flex flex-col px-5 py-10 md:pl-[69px] justify-between md:pr-8 md:py-14 lg:py-16">
      {% if section.settings.title != blank %}
        <h2 class="lp-clinic-results-title">
          {{ section.settings.title }}
        </h2>
      {% endif %}

      <ul class="lp-clinic-results-list list-none m-0 p-0 flex flex-col">
        {%- assign category_blocks = section.blocks | where: 'type', 'category' -%}
        {%- if category_blocks.size > 0 -%}
          {%- for block in category_blocks -%}
            <li class="lp-clinic-results-category flex flex-col md:flex-row md:items-center md:gap-6" {{ block.shopify_attributes }}>
              {%- if block.settings.heading != blank -%}
                <h3 class="lp-clinic-results-category-heading md:mb-0 shrink-0">{{ block.settings.heading }}</h3>
              {%- endif -%}
              <div class="lp-clinic-results-stats flex flex-col md:flex-1 md:min-w-0">
                <div class="lp-clinic-results-stat flex items-center gap-3">
                  <span class="lp-clinic-results-percent">{{ block.settings.percentage_1 }}</span>
                  <span class="lp-clinic-results-desc">{{ block.settings.description_1 }}</span>
                </div>
                <div class="lp-clinic-results-stat flex items-center gap-3">
                  <span class="lp-clinic-results-percent">{{ block.settings.percentage_2 }}</span>
                  <span class="lp-clinic-results-desc">{{ block.settings.description_2 }}</span>
                </div>
              </div>
            </li>
          {%- endfor -%}
        {%- else -%}
          {%- comment -%} Default result categories (Figma content) when no blocks added {%- endcomment -%}
          <li class="lp-clinic-results-category flex flex-col md:flex-row md:items-center md:gap-6">
            <h3 class="lp-clinic-results-category-heading md:mb-0 shrink-0">TEXTURE & BALANCE</h3>
            <div class="lp-clinic-results-stats flex flex-col md:flex-1 md:min-w-0">
              <div class="lp-clinic-results-stat flex items-baseline gap-3">
                <span class="lp-clinic-results-percent">96%</span>
                <span class="lp-clinic-results-desc">Agree complexion looks balanced</span>
              </div>
              <div class="lp-clinic-results-stat flex items-baseline gap-3">
                <span class="lp-clinic-results-percent">92%</span>
                <span class="lp-clinic-results-desc">Agree skin texture is improved</span>
              </div>
            </div>
          </li>
          <li class="lp-clinic-results-category flex flex-col md:flex-row md:items-center md:gap-6">
            <h3 class="lp-clinic-results-category-heading md:mb-0 shrink-0">HEALTH & VITALITY</h3>
            <div class="lp-clinic-results-stats flex flex-col md:flex-1 md:min-w-0">
              <div class="lp-clinic-results-stat flex items-baseline gap-3">
                <span class="lp-clinic-results-percent">85%</span>
                <span class="lp-clinic-results-desc">Agree skin looks healthier</span>
              </div>
              <div class="lp-clinic-results-stat flex items-baseline gap-3">
                <span class="lp-clinic-results-percent">88%</span>
                <span class="lp-clinic-results-desc">Agree skin looks revitalized</span>
              </div>
            </div>
          </li>
          <li class="lp-clinic-results-category flex flex-col md:flex-row md:items-center md:gap-6">
            <h3 class="lp-clinic-results-category-heading md:mb-0 shrink-0">FIRMNESS & YOUTHFULNESS</h3>
            <div class="lp-clinic-results-stats flex flex-col md:flex-1 md:min-w-0">
              <div class="lp-clinic-results-stat flex items-baseline gap-3">
                <span class="lp-clinic-results-percent">88%</span>
                <span class="lp-clinic-results-desc">Agree skin looks firmer</span>
              </div>
              <div class="lp-clinic-results-stat flex items-baseline gap-3">
                <span class="lp-clinic-results-percent">90%</span>
                <span class="lp-clinic-results-desc">Agree skin looks younger</span>
              </div>
            </div>
          </li>
        {%- endif -%}
      </ul>

      {% if section.settings.disclaimer != blank %}
        <p class="lp-clinic-results-disclaimer">
          {{ section.settings.disclaimer }}
        </p>
      {% endif %}
    </div>

    {%- comment -%} Image right – full-bleed to viewport edge on desktop; below content on mobile {%- endcomment -%}
    <div class="lp-clinic-results-image order-2 w-full md:flex-1 md:min-w-0">
      {% if section.settings.image != blank %}
        <img
          src="{{ section.settings.image | image_url: width: 1200 }}"
          alt="{{ section.settings.title | default: 'Clinical Results' }}"
          class="lp-clinic-results-image__img w-full h-full object-cover object-left md:object-center"
          loading="lazy"
          width="1200"
          height="600"
        >
      {% endif %}
    </div>
  </div>
</section>
