    <div class="button-group hide-pc">
      {% for button in section.blocks %}
        {% assign is_active = false %}
        {% if button.settings.link == page.url or button.settings.link == page.handle %}
          {% assign is_active = true %}
        {% endif %}
        <a href="{{ button.settings.link }}" class="btn {% if is_active %}active{% endif %}">
          {{ button.settings.button_text }}
        </a>
      {% endfor %}
    </div>

<div class="custom-section page_title">
  <div class="in_block_title">
    <h1>
      {% if section.settings.title != blank %}
        {{ section.settings.title }}
      {% else %}
        {{ page.title }}
      {% endif %}
    </h1>

    <div class="button-group hide-mobile">
      {% for button in section.blocks %}
        {% assign is_active = false %}
        {% if button.settings.link == page.url or button.settings.link == page.handle %}
          {% assign is_active = true %}
        {% endif %}
        <a href="{{ button.settings.link }}" class="btn {% if is_active %}active{% endif %}">
          {{ button.settings.button_text }}
        </a>
      {% endfor %}
    </div>
  </div>
</div>



