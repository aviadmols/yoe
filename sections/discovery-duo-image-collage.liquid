{{ 'discovery-duo-image-collage.css' | asset_url | stylesheet_tag }}

<section
  class="dd-collage"
  style="--dd-collage-padding-top: {{ section.settings.padding_top }}px; --dd-collage-padding-bottom: {{ section.settings.padding_bottom }}px;"
  aria-label="{{ section.settings.accessibility_label | default: 'Discovery Duo image collage' | escape }}"
>
  <div class="dd-collage__inner" data-collage-slider>
    <div class="dd-collage__viewport">
      <div class="dd-collage__track" data-collage-track>
        {%- for block in section.blocks -%}
          {%- if block.type == 'image' -%}
            {%- assign fallback_image = block.settings.desktop_image | default: block.settings.mobile_image -%}
            <figure class="dd-collage__item dd-collage__item--{{ forloop.index }}" {{ block.shopify_attributes }}>
              {%- if fallback_image != blank -%}
                <picture>
                  {%- if block.settings.mobile_image != blank -%}
                    <source media="(max-width: 749px)" srcset="{{ block.settings.mobile_image | image_url: width: 750 }}">
                  {%- endif -%}
                  {{ fallback_image | image_url: width: 1100 | image_tag:
                    loading: 'lazy',
                    class: 'dd-collage__image',
                    alt: block.settings.alt | default: block.settings.caption
                  }}
                </picture>
              {%- else -%}
                <span class="dd-collage__placeholder" aria-hidden="true"></span>
              {%- endif -%}
              {%- if block.settings.caption != blank -%}
                <figcaption>{{ block.settings.caption | escape }}</figcaption>
              {%- endif -%}
            </figure>
          {%- endif -%}
        {%- endfor -%}
      </div>
    </div>

    {%- if section.blocks.size > 1 -%}
      <button class="dd-collage__slider-button dd-collage__slider-button--prev" type="button" data-collage-prev aria-label="Previous image">
        <span aria-hidden="true">‹</span>
      </button>
      <button class="dd-collage__slider-button dd-collage__slider-button--next" type="button" data-collage-next aria-label="Next image">
        <span aria-hidden="true">›</span>
      </button>
    {%- endif -%}
  </div>
</section>

<script>
  (() => {
    const initCollageSlider = (slider) => {
      const track = slider.querySelector('[data-collage-track]');
      const prev = slider.querySelector('[data-collage-prev]');
      const next = slider.querySelector('[data-collage-next]');

      if (!track || !prev || !next || slider.dataset.sliderReady === 'true') return;

      const getStep = () => {
        const slide = track.querySelector('.dd-collage__item');
        if (!slide) return track.clientWidth;

        const styles = window.getComputedStyle(track);
        const gap = parseFloat(styles.columnGap || styles.gap || 0);
        return slide.getBoundingClientRect().width + gap;
      };

      prev.addEventListener('click', () => {
        track.scrollBy({ left: -getStep(), behavior: 'smooth' });
      });

      next.addEventListener('click', () => {
        track.scrollBy({ left: getStep(), behavior: 'smooth' });
      });

      slider.dataset.sliderReady = 'true';
    };

    document.querySelectorAll('[data-collage-slider]').forEach(initCollageSlider);

    document.addEventListener('shopify:section:load', (event) => {
      event.target.querySelectorAll('[data-collage-slider]').forEach(initCollageSlider);
    });
  })();
</script>

{% schema %}
{
  "name": "Duo – Image collage",
  "tag": "section",
  "class": "section-dd-collage",
  "settings": [
    { "type": "text", "id": "accessibility_label", "label": "Accessibility label", "default": "Discovery Duo image collage" },
    { "type": "range", "id": "padding_top", "label": "Top padding", "min": 0, "max": 200, "step": 4, "unit": "px", "default": 48 },
    { "type": "range", "id": "padding_bottom", "label": "Bottom padding", "min": 0, "max": 200, "step": 4, "unit": "px", "default": 48 }
  ],
  "blocks": [
    {
      "type": "image",
      "name": "Image",
      "settings": [
        { "type": "image_picker", "id": "desktop_image", "label": "Desktop image" },
        { "type": "image_picker", "id": "mobile_image", "label": "Mobile image" },
        { "type": "text", "id": "caption", "label": "Caption" },
        { "type": "text", "id": "alt", "label": "Alt text" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Duo – Image collage",
      "blocks": [
        { "type": "image" },
        { "type": "image" },
        { "type": "image" }
      ]
    }
  ]
}
{% endschema %}
