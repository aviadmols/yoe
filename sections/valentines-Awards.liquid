{% schema %}
{
  "name": "Awards & Mentions Section",
  "class": "awards-mentions-section",
  "settings": [
    {
      "type": "image_picker",
      "id": "award_logo",
      "label": "Award Logo"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "YMPOSSIBLE CREAM WAS JUST AWARDED OPRAH DAILY BEAUTY O-WARD’S BEST NIGHT CREAM OF 2024"
    },
    {
      "type": "textarea",
      "id": "award_text",
      "label": "Award Text",
      "default": "\"It’s so hard to find a rich, luxurious anti-aging cream for sensitive skin—but this is it!\""
    }
  ],
  "blocks": [
    {
      "type": "mention",
      "name": "Mention",
      "settings": [
         {
          "type": "image_picker",
          "id": "img",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "source",
          "label": "Source",
          "default": "Forbes"
        },
        {
          "type": "textarea",
          "id": "mention_text",
          "label": "Mention Text",
          "default": "\"With its lightweight, fast-absorbing texture, it’s perfect for quick applications, delivering a dewy finish without any heaviness.\""
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Awards & Mentions Section",
      "category": "Custom Sections",
      "blocks": [
        { "type": "mention" },
        { "type": "mention" },
        { "type": "mention" }
      ]
    }
  ]
}
{% endschema %}

<div class="awards-mentions">
  <div class="award-section">
    <img src="{{ section.settings.award_logo | img_url: 'medium' }}" alt="Award Logo">
<div class="title_section">
  <svg xmlns="http://www.w3.org/2000/svg" xmlns:xlink="http://www.w3.org/1999/xlink" width="288" height="103" viewBox="0 0 288 103" fill="none">
<rect x="0.837891" y="0.740234" width="286.429" height="102.189" fill="url(#pattern0_0_291)"/>
<defs>
<pattern id="pattern0_0_291" patternContentUnits="objectBoundingBox" width="1" height="1">
<use xlink:href="#image0_0_291" transform="scale(0.00116592 0.00326797)"/>
</pattern>
<image id="image0_0_291" width="858" height="306" xlink:href="data:image/png;base64,"/>
</defs>
</svg>
    <h2>{{ section.settings.heading }}</h2>
    <p class="award-text">{{ section.settings.award_text }}</p>
  </div>
  </div>
  <div class="mentions">
    {% for block in section.blocks %}
      <div class="mention">
   <img src="{{ block.settings.img  | img_url: '' }}" >
        <h3>{{ block.settings.source }}</h3>
        <p>{{ block.settings.mention_text }}</p>
      </div>
    {% endfor %}
  </div>
</div>

<style>

.award-section {
    display: flex;
    gap: 5rem;
    margin-bottom: 30px;
    align-items: center;
    justify-content: center;
}

  .awards-mentions {
    text-align: center;
    padding: 6rem 1.75rem;
  }
  .award-section {
    margin-bottom: 8rem;
  }
  .award-section img {
width: 11.06rem;
height: 11.05rem;
    
  }

.award-section {
    flex-flow: wrap;
}

  .mention img {
    height: 2.72rem;
  }
  .award-section h2 {

font-size: 1.43rem;
font-weight: 400;
line-height: 1.71rem;
letter-spacing: 0.15em;
text-align: left;
text-underline-position: from-font;
text-decoration-skip-ink: none;
font-variation-settings: 'wdth' 80;

  }
  .award-text {
width: 24.1rem;
font-size: 1.4rem;
font-weight: 350;
line-height: 2.1rem;
text-align: left;
text-underline-position: from-font;
text-decoration-skip-ink: none;
font-variation-settings: 'wdth' 78;


  }
  .mentions {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 3rem;
  }
  .mention {
     width: 26rem;
    max-width: 26rem;
    text-align: center;
  }
  .mention h3 {
margin-bottom: 0.5rem;
margin-top: 2rem;
text-transform: uppercase;
font-size: 1.1rem;
font-weight: 700;
line-height: 1.32rem;
letter-spacing: 0.15em;
text-align: center;
text-underline-position: from-font;
text-decoration-skip-ink: none;
font-variation-settings: 'wdth' 80;

  }

  .title_section svg{
    width: 14.32rem;
height: 5.11rem;
  }
  .mention p {
font-family: "Open Sans";
font-size: 1.4rem;
        margin: 0px;
font-weight: 350;
line-height: 2.1rem;
text-align: center;
text-underline-position: from-font;
text-decoration-skip-ink: none;
font-variation-settings: 'wdth' 78;


  }

.title_section {
    width: 41.25rem;
    text-align: left;
}


@media (max-width: 768px) {
  .title_section {
    width: 310px !important;
    text-align: center !important;
    max-width: 100% !important;
  }

  .mention h3 {
    margin-bottom: 10px !important;
    margin-top: 20px !important;
    font-family: "Open Sans" !important;
    text-transform: uppercase !important;
    font-size: 12px !important;
  }

  .mentions {
    display: flex !important;
    flex-wrap: wrap !important;
    justify-content: center !important;
    gap: 40px !important;
  }

  .mention p {
    font-size: 14.376px !important;
    line-height: 1.4 !important;
    margin-left: auto !important;
    margin-right: auto !important;
  }

  .award-section img {
    width: 196.154px !important;
    height: 195.979px !important;
  }

  .award-section h2 { 
    font-size: 21.489px !important;
    text-align: center !important;
    font-style: normal !important;
    font-weight: 400 !important;
    line-height: 120% !important; /* 25.787px */
    letter-spacing: 3.223px !important;
  }

  .award-section {
    gap: 40px !important;
  }
}

</style>
