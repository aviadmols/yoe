{%- comment -%}
  Mobile sticky bottom CTA bar.
  Params: scroll_vh, cta_product, cta_product_secondary, cta_label, cta_go_to_checkout, preload_cart_on_load,
  cta_offer_display, cta_discount_text, cta_compare_price, cta_price
{%- endcomment -%}

{%- assign cta_product = cta_product -%}
{%- assign cta_variant = cta_product.selected_or_first_available_variant -%}
{%- assign enable_preload_cart = false -%}
{%- if preload_cart_on_load and cta_go_to_checkout -%}
  {%- assign enable_preload_cart = true -%}
{%- endif -%}

<aside
  class="dd-sticky-cta"
  data-dd-sticky-cta
  data-scroll-vh="{{ scroll_vh | default: 100 }}"
  {% if enable_preload_cart %}
    data-dd-preload-cart="true"
  {% endif %}
  aria-hidden="true"
  aria-label="{{ cta_label | default: 'Add to cart' | escape }}"
>
  {%- if cta_label != blank -%}
    <form
      class="dd-sticky-cta__form"
      method="post"
      action="{{ routes.cart_add_url }}"
      {% if cta_go_to_checkout %}
        data-dd-checkout
      {% endif %}
    >
      {% render 'dd-cta-cart-inputs',
        primary_product: cta_product,
        secondary_product: cta_product_secondary,
        include_secondary: true
      %}
      <button class="dd-sticky-cta__btn" type="submit"{% if cta_variant == blank %} disabled{% endif %}>
        {% render 'dd-cta-offer',
          offer_display: cta_offer_display,
          label: cta_label,
          discount_text: cta_discount_text,
          compare_price: cta_compare_price,
          price: cta_price,
          product: cta_product,
          legacy_style: 'stats',
          label_class: 'dd-sticky-cta__label',
          offer_class: 'dd-sticky-cta__offer',
          compare_class: 'dd-sticky-cta__compare',
          price_class: 'dd-sticky-cta__price'
        %}
        <span class="dd-sticky-cta__arrow" aria-hidden="true">
          <svg width="8" height="22" viewBox="0 0 8 22" fill="none">
            <path d="M1 1L7 11L1 21" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </span>
      </button>
    </form>
  {%- endif -%}
</aside>
