{{ 'discovery-duo-buy-box.css' | asset_url | stylesheet_tag }}

<section
  class="dd-buy"
  style="--dd-buy-padding-top: {{ section.settings.padding_top }}px; --dd-buy-padding-bottom: {{ section.settings.padding_bottom }}px;"
  aria-label="{{ section.settings.product_name | default: 'Buy Discovery Duo' | escape }}"
>
  {%- assign cta_product = section.settings.cta_product -%}
  {%- assign cta_variant = cta_product.selected_or_first_available_variant -%}

  <div class="dd-buy__inner">
    <div class="dd-buy__info">
      {%- if section.settings.eyebrow != blank -%}
        <span class="dd-buy__eyebrow">{{ section.settings.eyebrow }}</span>
      {%- endif -%}

      {%- if section.settings.product_name != blank -%}
        <h2 class="dd-buy__title">{{ section.settings.product_name }}</h2>
      {%- endif -%}

      {%- if section.settings.product_description != blank -%}
        <div class="dd-buy__description">{{ section.settings.product_description }}</div>
      {%- endif -%}

      {%- assign price_lines = section.blocks | where: 'type', 'price_line' -%}
      {%- if price_lines.size > 0 -%}
        <dl class="dd-buy__lines">
          {%- for block in price_lines -%}
            <div class="dd-buy__line" {{ block.shopify_attributes }}>
              <dt>{{ block.settings.label | escape }}</dt>
              <dd>{{ block.settings.value | escape }}</dd>
            </div>
          {%- endfor -%}
        </dl>
      {%- endif -%}

      <div class="dd-buy__totals">
        {%- if section.settings.total_label != blank or section.settings.compare_price != blank -%}
          <div class="dd-buy__total-row">
            <span>{{ section.settings.total_label | escape }}</span>
            <span class="dd-buy__compare-price">{{ section.settings.compare_price | escape }}</span>
          </div>
        {%- endif -%}
        {%- if section.settings.savings_label != blank or section.settings.price != blank -%}
          <div class="dd-buy__total-row dd-buy__total-row--final">
            <span>{{ section.settings.savings_label | escape }}</span>
            <span class="dd-buy__price">
              {%- if cta_product != blank -%}
                {{ cta_product.price | money_without_trailing_zeros }}
              {%- else -%}
                {{ section.settings.price | escape }}
              {%- endif -%}
            </span>
          </div>
        {%- endif -%}
      </div>

      {%- if section.settings.cta_text != blank -%}
        {%- assign cta_offer_mode = section.settings.cta_offer_display | default: 'legacy' -%}
        {%- assign cta_strike_price = section.settings.cta_strike_price | default: section.settings.compare_price | strip -%}
        <form class="dd-buy__form" method="post" action="{{ routes.cart_add_url }}"{% if section.settings.cta_go_to_checkout %} data-dd-checkout{% endif %}>
          {%- if cta_variant != blank -%}
            <input type="hidden" name="id" value="{{ cta_variant.id }}">
          {%- endif -%}
          <button class="dd-buy__cta" type="submit"{% if cta_variant == blank %} disabled{% endif %}>
            {%- if cta_offer_mode == 'discount' or cta_offer_mode == 'price' -%}
              {% render 'dd-cta-offer',
                offer_display: cta_offer_mode,
                label: section.settings.cta_text,
                discount_text: section.settings.cta_discount_text,
                compare_price: cta_strike_price,
                price: section.settings.price,
                product: cta_product,
                legacy_style: 'buy',
                label_class: 'dd-buy__cta-label',
                offer_class: 'dd-buy__cta-offer',
                compare_class: 'dd-buy__cta-compare',
                price_class: 'dd-buy__cta-price'
              %}
            {%- else -%}
              {%- assign cta_button_text = section.settings.cta_text | escape -%}
              {%- if cta_strike_price != blank -%}
                {%- assign cta_strike_escaped = cta_strike_price | escape -%}
                {%- capture cta_strike_markup -%}<span class="dd-buy__cta-compare">{{ cta_strike_escaped }}</span>{%- endcapture -%}
                {%- assign cta_button_text = cta_button_text | replace: cta_strike_escaped, cta_strike_markup -%}
              {%- endif -%}
              {{ cta_button_text }}
            {%- endif -%}
            <svg class="dd-buy__cta-arrow" width="8" height="22" viewBox="0 0 8 22" fill="none" aria-hidden="true">
              <path d="M1 1L7 11L1 21" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </button>
        </form>
      {%- endif -%}

      {%- assign trust_blocks = section.blocks | where: 'type', 'trust' -%}
      {%- if trust_blocks.size > 0 -%}
        <ul class="dd-buy__trust">
          {%- for block in trust_blocks -%}
            <li class="dd-buy__trust-item" {{ block.shopify_attributes }}>
              {%- if block.settings.icon != blank -%}
                <span class="dd-buy__trust-icon">
                  {{ block.settings.icon | image_url: width: 80 | image_tag:
                    loading: 'lazy',
                    alt: ''
                  }}
                </span>
              {%- else -%}
                <span class="dd-buy__trust-check" aria-hidden="true">{% render 'dd-check-icon' %}</span>
              {%- endif -%}
              <span class="dd-buy__trust-text">{{ block.settings.text }}</span>
            </li>
          {%- endfor -%}
        </ul>
      {%- endif -%}

      {%- if section.settings.disclaimer != blank -%}
        <p class="dd-buy__disclaimer">{{ section.settings.disclaimer }}</p>
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Duo – Buy box",
  "tag": "section",
  "class": "section-dd-buy",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "The Discovery Duo"
    },
    {
      "type": "text",
      "id": "product_name",
      "label": "Product name",
      "default": "Discovery Duo"
    },
    {
      "type": "richtext",
      "id": "product_description",
      "label": "Product description",
      "default": "<p>HA + Retinol Active and Cream Booster — your complete daily routine.</p>"
    },
    {
      "type": "header",
      "content": "Pricing"
    },
    {
      "type": "text",
      "id": "compare_price",
      "label": "Compare-at price",
      "default": "$86"
    },
    {
      "type": "text",
      "id": "price",
      "label": "Price",
      "default": "$48"
    },
    {
      "type": "text",
      "id": "price_suffix",
      "label": "Price suffix",
      "default": "USD"
    },
    {
      "type": "text",
      "id": "total_label",
      "label": "Total label",
      "default": "Total Value"
    },
    {
      "type": "text",
      "id": "savings_label",
      "label": "Final price label",
      "default": "Your Price — First-Time Customers"
    },
    {
      "type": "header",
      "content": "Call to action"
    },
    {
      "type": "product",
      "id": "cta_product",
      "label": "CTA product"
    },
    {
      "type": "checkbox",
      "id": "cta_go_to_checkout",
      "label": "Go directly to checkout",
      "default": false,
      "info": "When enabled: clears cart, adds only this product (qty 1), then redirects to checkout. When disabled: standard add to cart."
    },
    {
      "type": "text",
      "id": "cta_text",
      "label": "Button text",
      "default": "TRY DISCOVERY DUO"
    },
    {
      "type": "select",
      "id": "cta_offer_display",
      "label": "CTA offer display",
      "options": [
        { "value": "legacy", "label": "Auto (theme default)" },
        { "value": "discount", "label": "Discount text (e.g. | 15% OFF)" },
        { "value": "price", "label": "Compare + sale price" }
      ],
      "default": "legacy"
    },
    {
      "type": "text",
      "id": "cta_discount_text",
      "label": "Discount suffix",
      "default": "| 15% OFF"
    },
    {
      "type": "text",
      "id": "cta_strike_price",
      "label": "Button strikethrough price",
      "default": "$86",
      "info": "Must match the price shown in the button text (e.g. $86)."
    },
    {
      "type": "text",
      "id": "disclaimer",
      "label": "Disclaimer",
      "default": "*For First-Time Customers Only"
    },
    {
      "type": "header",
      "content": "Main image"
    },
    {
      "type": "image_picker",
      "id": "main_image",
      "label": "Main product image"
    },
    {
      "type": "header",
      "content": "Section padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Top padding",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Bottom padding",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "default": 80
    }
  ],
  "blocks": [
    {
      "type": "price_line",
      "name": "Price line",
      "limit": 6,
      "settings": [
        {
          "type": "text",
          "id": "label",
          "label": "Label",
          "default": "Ympossible Cream 8ml"
        },
        {
          "type": "text",
          "id": "value",
          "label": "Value",
          "default": "$43"
        }
      ]
    },
    {
      "type": "thumb",
      "name": "Gallery thumbnail",
      "limit": 8,
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Thumbnail image"
        }
      ]
    },
    {
      "type": "trust",
      "name": "Trust badge",
      "limit": 6,
      "settings": [
        {
          "type": "image_picker",
          "id": "icon",
          "label": "Icon (optional – falls back to check)"
        },
        {
          "type": "text",
          "id": "text",
          "label": "Text",
          "default": "Free Express Shipping"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Duo – Buy box",
      "blocks": [
        { "type": "thumb" },
        { "type": "thumb" },
        { "type": "thumb" },
        { "type": "thumb" },
        { "type": "thumb" },
        { "type": "trust", "settings": { "text": "Free Express Shipping" } },
        { "type": "trust", "settings": { "text": "30-Day Money-Back" } },
        { "type": "trust", "settings": { "text": "First-Time Offer" } }
      ]
    }
  ]
}
{% endschema %}
