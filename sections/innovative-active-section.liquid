<script>
(function() {
  var sid = '{{ section.id }}';
  var popup = document.getElementById('yoe-popup-' + sid);
  if (!popup) return;
  var imgEl = document.getElementById('yoe-popup-image-' + sid);
  var titleEl = document.getElementById('yoe-popup-title-' + sid);
  var descEl = document.getElementById('yoe-popup-desc-' + sid);

  function openPopup(image, title, description) {
    if (imgEl) {
      imgEl.src = image || '';
      imgEl.style.display = image ? 'block' : 'none';
    }
    if (titleEl) titleEl.textContent = title || '';
    if (descEl) descEl.innerHTML = description || '';
    popup.style.display = 'block';
  }
  
  function closePopup() { 
    popup.style.display = 'none'; 
  }

  document.addEventListener('click', function(e) {
    var trigger = e.target.closest('[data-popup-trigger="' + sid + '"]');
    if (trigger) {
      var image = trigger.getAttribute('data-popup-image') || '';
      var title = trigger.getAttribute('data-popup-title') || '';
      var blockId = trigger.getAttribute('data-block-id') || '';
      
      // Find the popup text content by block ID
      var textNode = trigger.querySelector('.popup-text-src[data-popup-content="' + blockId + '"]');
      var text = textNode ? textNode.innerHTML.trim() : '';
      
      console.log('Popup Debug:', {
        image: image,
        title: title,
        blockId: blockId,
        hasTextNode: !!textNode,
        text: text
      });
      
      openPopup(image, title, text);
    }
    if (e.target.matches('[data-popup-close="' + sid + '"]') || e.target.closest('[data-popup-close="' + sid + '"]')) {
      closePopup();
    }
    if (e.target === popup) { closePopup(); }
  });

  document.addEventListener('keydown', function(e) { if (e.key === 'Escape') closePopup(); });
})();

// Ingredients Modal Handler
(function() {
    var sid = '{{ section.id }}';
    var ingredientsModal = document.getElementById('ingredients-modal-' + sid);
    if (!ingredientsModal) return;

    function openIngredientsModal(e) {
        e.preventDefault();
        ingredientsModal.style.display = 'flex';
        document.body.style.overflow = 'hidden';
    }

    function closeIngredientsModal() {
        ingredientsModal.style.display = 'none';
        document.body.style.overflow = '';
    }

    // Open modal on trigger click
    document.addEventListener('click', function(e) {
        var trigger = e.target.closest('[data-ingredients-trigger="' + sid + '"]');
        if (trigger) {
            openIngredientsModal(e);
        }

        // Close on close button
        var closeBtn = e.target.closest('[data-ingredients-close="' + sid + '"]');
        if (closeBtn) {
            closeIngredientsModal();
        }

        // Close on overlay click
        if (e.target.classList.contains('ingredients-modal-overlay')) {
            closeIngredientsModal();
        }
    });

    // Close on Escape key
    document.addEventListener('keydown', function(e) {
        if (e.key === 'Escape' && ingredientsModal.style.display === 'flex') {
            closeIngredientsModal();
        }
    });
})();
</script>
