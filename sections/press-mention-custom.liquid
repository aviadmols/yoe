<section class="press-mentions">
  <div class="page-width">
    <div class="press-mentions-wrapper">
      {% for block in section.blocks %}
        <div class="press-mention-item">
          <h4>{{ block.settings.title }}</h4>
          <p>{{ block.settings.quote }}</p>
        </div>
      {% endfor %}
    </div>
  </div>
</section>


<style>
  .template-product-ympossible_cream_light .press-mentions-wrapper {
    width: 100%;
    max-width: 1308px;
    margin: auto;
}
.press-mention-item h4 {
    font-size: 1.5rem;
    margin: 0px;
    letter-spacing: 0px;
    text-transform: uppercase;
    font-weight: 500;
    color: rgba(102, 100, 96, 1);
}
.press-mention-item p {
    font-size: 1.02rem;
    color:#666460;
    font-style: italic;
    line-height: 116%;
    font-weight: 100;
    width: 100%;
    margin: auto;
    padding-top: 6px;
    font-family: "Open Sans", sans-serif;
}
.press-mentions {
    padding: 18px 0 22px;
    background: #fff;
}
.press-mentions-wrapper {
  display: flex;
  justify-content: space-between;
  flex-wrap: wrap;
  gap: 20px;
}
.press-mention-item {
  flex: 1;
  text-align: center;
  padding: 10px;
}
@media (max-width: 767px) {
  .press-mentions-wrapper {
    display: block;
  }
  .press-mention-item {
    width: 100%;
  }
.press-mention-item h4 {
    font-size: 32px;
}
.press-mention-item p {
    font-size: 19px;
    line-height: 27px;
}
.press-mentions {
    background: #ffffff;
}
.press-mentions {
    padding: 42px 0 22px;
}
section.press-mentions ul.slick-dots {
    display: flex;
    justify-content: center;
}
section.press-mentions ul.slick-dots  li {
    margin: 0px;
}
}

@media(max-width: 991px) and (min-width: 768px){
.press-mention-item h4 {
    font-size: 22px;
}
.press-mention-item p {
    font-size: 18px;
}
}

@media (min-width: 768px) and (max-width: 990px){
.press-mention-item h4 {
    font-size: 1.2rem;
}
}
@media (min-width: 991px) and (max-width: 1200px){
.press-mention-item h4 {
    font-size: 20px;
}
}
@media (min-width: 1201px) and (max-width: 1496px){
.press-mention-item h4 {
    font-size: 23px;
}
}
</style>
<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>

<link rel="stylesheet" type="text/css" href="https://cdn.jsdelivr.net/npm/slick-carousel@1.8.1/slick/slick.css"/>
<link rel="stylesheet" type="text/css" href="https://cdn.jsdelivr.net/npm/slick-carousel@1.8.1/slick/slick-theme.css"/>

<script type="text/javascript" src="https://cdn.jsdelivr.net/npm/slick-carousel@1.8.1/slick/slick.min.js"></script>


<script>
$(document).ready(function() {
  $('.press-mentions-wrapper').slick({
    dots: true,
    arrows: false,
    autoplay: true,
    autoplaySpeed: 3000,
    adaptiveHeight: true,
    responsive: [
      {
        breakpoint: 768,
        settings: {
          dots: true,
          arrows: false,
          autoplay: true,
          autoplaySpeed: 3000,
          adaptiveHeight: true
        }
      },
      {
        breakpoint: 9999, 
        settings: "unslick"
      }
    ]
  });
});

</script>


{% schema %}
{
  "name": "Press Mentions",
  "settings": [
    {
      "type": "header",
      "content": "Press Mentions Section"
    }
  ],
  "blocks": [
    {
      "type": "quote",
      "name": "Press Item",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Publication Name",
          "default": "COSMOPOLITAN"
        },
        {
          "type": "textarea",
          "id": "quote",
          "label": "Quote",
          "default": "\"Behold: the rich-but-light skin-soothing cream you didn’t know you were missing.\""
        }
      ]
    }
  ],
  "max_blocks": 10,
  "presets": [
    {
      "name": "Press Mentions",
      "category": "Text"
    }
  ]
}
{% endschema %}
