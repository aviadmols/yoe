{% comment %}
  Section: Clinical Results
  Description: Responsive section for showcasing skincare product clinical results.
{% endcomment %}

{%- assign is_pdp_layout = false -%}
{%- if section.settings.layout_mode == 'pdp' -%}
  {%- assign is_pdp_layout = true -%}
{%- endif -%}

{%- assign section_variant = section.settings.section_variant | default: 'clinical' -%}

{%- if is_pdp_layout -%}
  {{ 'clinic-result-section.css' | asset_url | stylesheet_tag }}
{%- endif -%}

<section class="clinical-results-section{% if is_pdp_layout %} clinical-results-section--pdp clinical-results-section--{{ section_variant }}{% endif %}">
  <div class="page-width">
    <div class="clinical-results-container{% if is_pdp_layout %} clinical-results-container--pdp{% endif %}">
      {%- if is_pdp_layout -%}
        <div class="clinical-results-content">
          {%- if section.settings.badge_text != blank -%}
            <span class="clinical-results-badge">{{ section.settings.badge_text | escape }}</span>
          {%- endif -%}

          {%- if section.settings.main_headline != blank -%}
            <h2 class="clinical-results-main-headline">{{ section.settings.main_headline | escape }}</h2>
          {%- endif -%}

          {%- if section_variant == 'clinical' -%}
            <div class="clinical-results-ba-grid" aria-label="Before and after results">
              {%- assign ba_labels = 'Before,After,Before,After' | split: ',' -%}
              {%- for i in (1..4) -%}
                {%- capture ba_key -%}ba_image_{{ i }}{%- endcapture -%}
                {%- assign ba_image = section.settings[ba_key] | default: section.settings.image -%}
                {%- if ba_image != blank -%}
                  <div class="clinical-results-ba-cell">
                    <span class="clinical-results-ba-label">{{ ba_labels[forloop.index0] }}</span>
                    <img
                      class="clinical-results-ba-image"
                      src="{{ ba_image | image_url: width: 400 }}"
                      alt="{{ ba_labels[forloop.index0] }} — {{ section.settings.badge_text | escape }}"
                      loading="lazy"
                      width="156"
                      height="129"
                    >
                  </div>
                {%- endif -%}
              {%- endfor -%}
            </div>
          {%- endif -%}

          <div class="clinical-results-stats-panel">
            {%- if section.settings.headline != blank -%}
              <p class="clinical-results-side-label">{{ section.settings.headline | escape }}</p>
            {%- endif -%}

            <ul class="clinical-results-grid results-list">
              {%- for block in section.blocks -%}
                <li class="result-item" {{ block.shopify_attributes }}>
                  {%- if block.settings.stat_top != blank -%}
                    <span class="result-top">{{ block.settings.stat_top | escape }}</span>
                  {%- elsif block.settings.description != blank -%}
                    <span class="result-top">{{ block.settings.description | escape }}</span>
                  {%- endif -%}
                  <span class="percent">{{ block.settings.percentage | escape }}</span>
                  {%- if block.settings.stat_bottom != blank -%}
                    <span class="result-bottom">{{ block.settings.stat_bottom | escape }}</span>
                  {%- endif -%}
                </li>
              {%- endfor -%}
            </ul>
          </div>

          {%- if section.settings.button_label != blank -%}
            <a class="clinic-button" href="{{ section.settings.button_link }}">
              {{ section.settings.button_label | escape }}
            </a>
          {%- endif -%}
        </div>

        <div class="image-side">
          {% if section.settings.image %}
            <img class="desktop-image-clinic clinical-image"
              src="{{ section.settings.image | image_url: width: 900 }}"
              alt="{{ section.settings.image.alt | escape }}"
              loading="lazy"
            >
            <img class="mobile-image-clinic clinical-image"
              src="{{ section.settings.image_mobile | default: section.settings.image | image_url: width: 750 }}"
              alt="{{ section.settings.image_mobile.alt | default: section.settings.image.alt | escape }}"
              loading="lazy"
            >
          {% endif %}
        </div>
      {%- else -%}
        <div class="image-side">
          {% if section.settings.image %}
            <img class="desktop-image-clinic"
              src="{{ section.settings.image | image_url: width: 800 }}"
              alt="{{ section.settings.image.alt | escape }}"
              class="clinical-image"
              loading="lazy"
            >
            <img class="mobile-image-clinic"
              src="{{ section.settings.image_mobile | image_url: width: 800 }}"
              alt="{{ section.settings.image_mobile.alt | escape }}"
              class="clinical-image"
              loading="lazy"
            >
          {% endif %}
        </div>

        <div class="results-side">
          {% if section.settings.headline != blank %}
            <h2 class="results-title">{{ section.settings.headline }}</h2>
          {% endif %}

          <ul class="results-list">
            {% for block in section.blocks %}
              <li class="result-item">
                <span class="percent">{{ block.settings.percentage }}</span>
                <span class="description">{{ block.settings.description }}</span>
              </li>
            {% endfor %}
          </ul>

          <a class="clinic-button" href="{{ section.settings.button_link }}" class="results-button">
            {{ section.settings.button_label }}
          </a>
        </div>
      {%- endif -%}
    </div>
  </div>
</section>

<style>
a.clinic-button {
    display: flex;
    border: 1px solid #666460;
    width: 100%;
    max-width: 244px;
    justify-content: center;
    font-size: 15px;
    color: #666460;
    text-transform: uppercase;
    margin-top: 4rem;
    line-height: 52px;
    letter-spacing: 0.06rem;
    text-decoration: none;
}
img.desktop-image-clinic {
    mix-blend-mode: multiply;
}
.clinical-results-section {
    background-color: #F7F6F5;
}
.clinical-results-container {
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: 100%;
    max-width: 1188px;
    margin: auto;
}
.clinical-results-container .image-side img.desktop-image-clinic {
    height: 37rem;
}
.image-side {
    flex: 1 1 55%;
    padding: 0rem;
    line-height: 0;
}
  .clinical-image {
    width: 100%;
    height: auto;
    border-radius: 10px;
  }

  .results-side {
    flex: 1 1 45%;
    padding: 0rem;
  }
.results-title {
    font-size: 2rem;
    font-weight: 300;
    letter-spacing: 0.3rem;
    color: #666460;
    text-transform: uppercase;
    margin: 0px 0px 30px;
}

  .results-list {
    list-style: none;
    padding: 0;
    margin-bottom: 0rem;
  }
.result-item {
    display: flex;
    align-items: center;
    margin-bottom: 0.3rem;
}
.percent {
    font-size: 2.6rem;
    font-weight: 200;
    color: #666460;
    margin-right: 0.5rem;
    width: 120px;
}
.results-side .description {
    font-size: 1rem;
    color: #666460;
    text-transform: uppercase;
    letter-spacing: 0.08rem;
    font-weight: 400;
}
  .results-button {
    display: inline-block;
    padding: 0.75rem 1.5rem;
    border: 1px solid #000;
    background-color: transparent;
    text-transform: uppercase;
    text-decoration: none;
    font-size: 0.95rem;
    color: #000;
    transition: all 0.3s ease;
  }

  .results-button:hover {
    background-color: #000;
    color: #fff;
  }
  img.mobile-image-clinic {
    display: none;
}

  @media screen and (max-width: 767px) {
    section.clinical-results-section:not(.clinical-results-section--pdp) .page-width {
    padding: 0px;
}
    section.clinical-results-section:not(.clinical-results-section--pdp) img.desktop-image-clinic {
    display: none;
}
section.clinical-results-section:not(.clinical-results-section--pdp) img.mobile-image-clinic {
    display: block;
    width: 100%;
    mix-blend-mode: multiply;
}
.clinical-results-section:not(.clinical-results-section--pdp) .clinical-results-container {
    flex-direction: column-reverse;
    row-gap: 30px;
}
.clinical-results-section:not(.clinical-results-section--pdp) a.clinic-button {
  font-family: "Open Sans Condensed", sans-serif;
  font-weight: 500;
    line-height: 53px;
    width: 100%;
    max-width: 100%;
    font-size: 14px;
    margin: 0px;
    margin-top:30px;
    border: 1.17px solid #666460;
    color: #666460;
    letter-spacing: 0.05em;
}
.clinical-results-section:not(.clinical-results-section--pdp) .results-title {
  font-family: "Open Sans Condensed", sans-serif;
    font-size: 30px;
    font-weight: 300;
    letter-spacing: 0.15em;
    font-weight: uppercase;
    line-height: 1.2em;
}

    .clinical-results-section:not(.clinical-results-section--pdp) .image-side,
    .clinical-results-section:not(.clinical-results-section--pdp) .results-side {
      flex: 1 1 100%;
      text-align: center;
    }
.clinical-results-section:not(.clinical-results-section--pdp) {
    padding: 3rem 0rem 0rem;
    background: #F7F6F5;
}
.clinical-results-section:not(.clinical-results-section--pdp) .percent {
    font-size: 27px;
    width: 97px;
}
   .clinical-results-section:not(.clinical-results-section--pdp) .results-side .description {
    font-family: "Open Sans Condensed", sans-serif;
    font-weight: 500;
    line-height: 1.2em;
    letter-spacing: 0.1em;
    font-size: 13px;
}
  }

  @media(max-width: 991px) and (min-width: 768px){
.results-title {
    font-size: 28px;
}
    img.desktop-image-clinic {
        width: 100%;
    }
    .percent {
    font-size: 30px;
    width: 120px;
}
.header_sections:not(.homepageheader) .cart-count-bubble {
    background: #666460;
}
}

  @media(max-width: 1200px) and (min-width: 992px){
    img.desktop-image-clinic {
        width: 100%;
    }
    .results-title {
    font-size: 28px;
}
.percent {
    font-size: 35px;
}
}
</style>

{% schema %}
{
  "name": "Clinical Results",
  "tag": "section",
  "class": "clinical-results",
  "settings": [
    {
      "type": "select",
      "id": "layout_mode",
      "label": "Layout mode",
      "options": [
        { "value": "classic", "label": "Classic" },
        { "value": "pdp", "label": "Product page (Figma panel)" }
      ],
      "default": "classic"
    },
    {
      "type": "select",
      "id": "section_variant",
      "label": "Section variant",
      "options": [
        { "value": "clinical", "label": "Clinical trial" },
        { "value": "consumer", "label": "Consumer perception" }
      ],
      "default": "clinical",
      "info": "PDP layout only"
    },
    {
      "type": "text",
      "id": "badge_text",
      "label": "Badge text",
      "default": "Clinically proven",
      "info": "PDP layout only"
    },
    {
      "type": "text",
      "id": "main_headline",
      "label": "Main headline",
      "info": "PDP layout only — large headline above stats"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Upload Image"
    },
    {
      "type": "image_picker",
      "id": "image_mobile",
      "label": "Mobile image"
    },
    {
      "type": "image_picker",
      "id": "ba_image_1",
      "label": "Before/after grid image 1",
      "info": "PDP clinical — top left (falls back to main image)"
    },
    {
      "type": "image_picker",
      "id": "ba_image_2",
      "label": "Before/after grid image 2",
      "info": "PDP clinical — top right"
    },
    {
      "type": "image_picker",
      "id": "ba_image_3",
      "label": "Before/after grid image 3",
      "info": "PDP clinical — bottom left"
    },
    {
      "type": "image_picker",
      "id": "ba_image_4",
      "label": "Before/after grid image 4",
      "info": "PDP clinical — bottom right"
    },
    {
      "type": "text",
      "id": "headline",
      "label": "Side label / headline",
      "default": "Clinical Results",
      "info": "PDP: vertical side strip. Classic: section title."
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button Label",
      "default": "Discover More Results"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link"
    }
  ],
  "blocks": [
    {
      "type": "result",
      "name": "Result Line",
      "settings": [
        {
          "type": "text",
          "id": "stat_top",
          "label": "Stat line (top)",
          "info": "PDP layout — text above percentage"
        },
        {
          "type": "text",
          "id": "percentage",
          "label": "Percentage",
          "default": "123%"
        },
        {
          "type": "text",
          "id": "stat_bottom",
          "label": "Stat line (bottom)",
          "info": "PDP layout — text below percentage"
        },
        {
          "type": "text",
          "id": "description",
          "label": "Description",
          "default": "Reduced Fine Lines",
          "info": "Classic layout — shown beside percentage"
        }
      ]
    }
  ],
  "max_blocks": 5,
  "presets": [
    {
      "name": "Clinical Results",
      "category": "Custom",
      "blocks": [
        {
          "type": "result",
          "settings": {
            "percentage": "123%",
            "description": "Reduced Fine Lines"
          }
        },
        {
          "type": "result",
          "settings": {
            "percentage": "94%",
            "description": "Improved Hydration"
          }
        },
        {
          "type": "result",
          "settings": {
            "percentage": "57%",
            "description": "Firmness Feel of Skin"
          }
        }
      ]
    }
  ]
}
{% endschema %}
