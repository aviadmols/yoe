<div class="image-with-text-section-cus {{ section.settings.custom-class }}">
    <div class="page-width">
        <div class="inner-section-cus">
            {% comment %} Left section {% endcomment %}
            <div class="left-section-content">
                <h1 class="main-title">{{ section.settings.main-title }}<sup>®</sup></h1>
                <h3 class="caption-title">{{ section.settings.title-caption }}</h3>
                <p>{{ section.settings.sub-title }}</p>
                <div class="left-button">
                    <a href="{{ section.settings.btn-url }}">
                    <button type="text">{{ section.settings.discover-btn }}</button>
                    </a>
                </div>
            </div>
            {% comment %} Right section {% endcomment %}
             <div class="right-section-cus">
                {% if section.settings.right-image != blank %}
                <img class="desktop-image" src="{{ section.settings.right-image |  img_url: 'master' }}">
                <img class="mobile-image" src="{{ section.settings.right-image-2 |  img_url: 'master' }}">
                {% endif %}
             </div>
        </div>
    </div>
</div>

{%  schema  %} 

{
    "name": "image with text section",
    "settings": [
        {
            "type": "text",
            "id": "custom-class",
            "label": "Custom Class"
        },
        {
            "type": "text",
            "id": "main-title",
            "label": "Title"
        },
        {
            "type": "text",
            "id": "title-caption",
            "label": "Caption Title"
        },
        {
            "type": "text",
            "id": "sub-title",
            "label": "Sub Title"
        },
        {
        "type": "text",
        "id": "discover-btn",
        "label": "Button Text",
        "default": "Discover"
        },
         {
        "type": "url",
        "id": "btn-url",
        "label": "Button Url"
        },
        {
            "type": "image_picker",
            "id": "right-image",
            "label": "Image Section"
        },
         {
            "type": "image_picker",
            "id": "right-image-2",
            "label": "Image Section"
        }
    ],
    "presets": [
        {
            "name": "image with text section",
        }
    ]
}


 {% endschema %}

 {% stylesheet %}
 h1.main-title sup {
    font-size: 23px;
}
.inner-section-cus {
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: 100%;
    max-width: 1400px;
    margin: auto;
}
img.desktop-image {
    width: 100%;
    height: 100%;
    max-width: 700px;
    mix-blend-mode: multiply;
}
.left-button button {
    width: 100%;
    height: 100%;
    line-height: 56px;
    font-size: .98rem;
    background: #ab2920;
    color: #fff;
    max-width: 14.5rem;
    border: 0px;
    font-family: Open Sans Condensed;
    cursor: pointer;
    z-index: 2;
    position: relative;
    overflow: hidden;
    text-transform: uppercase;
    font-weight: 500;
    letter-spacing: 1px;
    min-width: 220px;
    max-width: 250px;
}

h3.caption-title {
    font-size: 0.9rem;
    color: #666460;
    text-transform: uppercase;
    letter-spacing: .18rem;
    font-weight: 700;
    margin: 0;
    font-family: Open Sans, sans-serif !important;
}
.left-section-content p {
    font-size: 1.1rem;
    line-height: 135%;
    letter-spacing: .04rem;
    font-weight: 360;
    margin-bottom: 40px;
    margin-top: 7px;
    width: 100%;
    max-width: 20rem;
}
img.mobile-image {
    display: none;
}
.right-section-cus {
    width: 60%;
    max-width: 60%;
    line-height: 0px;
    padding-left: 3rem;
}
.left-section-content {
    width: 36%;
    max-width: 36%;
}
h1.main-title {
    text-align: left;
    font-size: 2.3rem;
    font-weight: 350;
    margin: 0 0 16px;
    line-height: 34px;
    min-height: 70px;
}
.image-with-text-section-cus .page-width {
    padding: 0px 8rem;
}
.image-with-text-section-cus {
    background: #fff;
    margin: 0 auto;
    width: auto;
    margin-left:0px;
    margin-right: 0px;
}
@media(max-width: 767px){
    img.desktop-image {
    display: none;
}
    h3.caption-title {
        font-size: 14px;
        margin: 0;
        letter-spacing: 1px;
    }
h1.main-title {
    font-size: 30px;
}
.left-section-content {
    padding-left: 0rem !important;
}
.image-with-text-section-cus {
    margin: 0 20px;
}
/* .image-with-text-section-cus {
    padding: 3rem 0rem 0rem;
    background: #fff;
    width: 90%;
    margin: 20px auto 19px;
} */
.image-with-text-section-cus .page-width {
    padding: 0px;
}
h1.main-title {
    margin-bottom: 10px !IMPORTANT;
}
    .right-section-cus {
    width: 100%;
    padding-left: 0rem;
    max-width: 100%;
}
.left-section-content {
    width: 100%;
    max-width: 100%;
    padding-left: 22px !important;
    padding-right: 22px !important;
}
.inner-section-cus {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-direction: column;
}
/* img.desktop-image {
    display: none;
} */
img.mobile-image {
    display: block!important;
    width: 100%;
}
.left-section-content p {
    font-size: 13px;
    line-height: 22px;
    margin-bottom: 20px;
    letter-spacing: 0.3px;
}
.left-button button {
    line-height: 52px;
    font-size: 14px;
    max-width: 100%;
}
}

@media(min-width: 768px) and (max-width: 991px){
h1.main-title {
    font-size: 26px;
}
h3.caption-title {
    font-size: 14px;
}
.left-section-content p {
    font-size: 14px;
    line-height: 27px;
    width: 100%;
    max-width: 100%;
}
}
 {% endstylesheet %}