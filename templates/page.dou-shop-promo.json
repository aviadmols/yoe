      "blocks": {
        "collapsible_row_YnjJFF": {
          "type": "collapsible_row",
          "disabled": true,
          "settings": {
            "heading": "How will my Valentine receive the products?",
            "icon": "check_mark",
            "row_content": "<ul><li>Your Valentine will receive an email containing a voucher to redeem their complimentary product, with your name included to let them know the gift is from you. We make it super easy!</li></ul>",
            "page": ""
          }
        },
        "collapsible_row_FVErz7": {
          "type": "collapsible_row",
          "settings": {
            "heading": "What are the benefits of the Ympossible Cream?",
            "icon": "none",
            "row_content": "<ul><li>Instantly hydrates and replenishes the skin.  </li><li>Provides deep, long-lasting nourishment.  </li><li>Strengthens the skin's moisture barrier.  </li><li>Targets visible signs of aging for a youthful complexion.  </li><li>Boosts collagen production for firmer, healthier skin.  </li><li>Improves skin tone and texture while addressing hyperpigmentation.  </li><li>Protects against environmental damage from pollution, UV and blue light. </li></ul>",
            "page": ""
          }
        },
        "collapsible_row_AmMdnc": {
          "type": "collapsible_row",
          "settings": {
            "heading": "What are the differences between Yoé’s two hero products?",
            "icon": "none",
            "row_content": "<ul><li>Ympossible Cream: A rich, ultra-nourishing formula designed to deeply hydrate, rejuvenate and protect your skin.  </li><li>Ympossible Cream Light: A lightweight version of our multi-action cream that delivers hydration, radiance and a youthful glow. </li></ul>",
            "page": ""
          }
        },
        "collapsible_row_Vy7cJp": {
          "type": "collapsible_row",
          "settings": {
            "heading": "What are the benefits of the Ympossible Cream Light?",
            "icon": "none",
            "row_content": "<ul><li>Supplies instant and long-lasting hydration.  </li><li>Delivers a radiant, luminous glow.  </li><li>Strengthens the moisture barrier for lasting hydration.  </li><li>Smooths texture and plumps skin for a youthful look.  </li><li>Reduces fine lines, wrinkles, and redness.  </li><li>Protects against environmental damage from pollution, UV, and blue light. </li></ul>",
            "page": ""
          }
        },
        "collapsible_row_PcGW8w": {
          "type": "collapsible_row",
          "settings": {
            "heading": "How do I use the Ympossible Cream and Ympossible Cream Light?",
            "icon": "none",
            "row_content": "<ul><li>Ympossible Cream: Apply to cleansed, dry skin on the face, neck and décolletage, both morning and evening. It can also be used as an overnight mask for stressed or parched skin. Best for normal to dry skin types or as a rich nighttime treatment.  </li><li>Ympossible Cream Light: Apply to cleansed, dry skin on the face, neck, and décolletage, both morning and evening. Ideal for normal to oily and combination skin types, or as a makeup base for a glowy finish. </li></ul><p><em><strong>Both products can also be used together as a moisture cocktail to tailor hydration to your skin's specific needs. Mix them in your palm to balance nourishment and radiance, addressing multiple skin concerns at once.  </strong></em></p>",
            "page": ""
          }
        },
        "collapsible_row_eh7cEb": {
          "type": "collapsible_row",
          "settings": {
            "heading": "Are these products suitable for sensitive skin or those who are pregnant or breastfeeding?",
            "icon": "none",
            "row_content": "<p>Yes! Both the Ympossible Cream and Ympossible Cream Light are:  </p><ul><li>Dermatologist-tested and hypoallergenic.  </li><li>Safe for all skin types, including sensitive skin.  </li><li>Suitable for individuals who are pregnant or breastfeeding. </li></ul>",
            "page": ""
          }
        },
        "collapsible_row_eApfx3": {
          "type": "collapsible_row",
          "settings": {
            "heading": "Are these products clean and safe?",
            "icon": "none",
            "row_content": "<p>Absolutely. Yoé’s products are:  </p><ul><li>Clinically and dermatologically tested.  </li><li>Hypoallergenic and safe for pregnant or breastfeeding individuals.  </li><li>Formulated without parabens, phthalates, synthetic fragrances and other harmful substances.  </li><li>EWG verified, Leaping Bunny Certified and vegan.</li></ul>",
            "page": ""
          }
        },
        "collapsible_row_cKwLqf": {
          "type": "collapsible_row",
          "settings": {
            "heading": "Are these products vegan and cruelty-free?",
            "icon": "none",
            "row_content": "<ul><li>Yes, both products are 100% vegan and cruelty-free, and they are Leaping Bunny certified.</li></ul>",
            "page": ""
          }
        }
      },
