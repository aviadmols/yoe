
<h2 class="text-headingsection ">
Meet Skincare’s Best-Kept Secret</h2>


<div class="custom-section-slider padding-top-bottom-70">
  <div class="text-area scroll-trigger animate--slide-in">
<div class="in_text-area ">
    <h2 class="text-heading">{{ section.settings.heading }}</h2>
    <div class="text-description">{{ section.settings.description }}</div>
  </div>
</div>
  <div class="carousel-area scroll-trigger animate--slide-in">
    <div class="swiper-container-info swiper-container">
      <div class="swiper-wrapper cards_block">
        {% for block in section.blocks %}
          <div class="swiper-slide" data-title="{{ block.settings.title }}" data-popup-image="{{ block.settings.popup_image | img_url: 'large' }}" data-popup-text="{{ block.settings.popup_text }}">
        
            <img src="{{ block.settings.carousel_image | img_url: 'large' }}" alt="{{ block.settings.title }}">
            <div class="slide-title">{{ block.settings.title }}</div>

          </div>
        {% endfor %}
      </div>
    </div>
  </div>
</div>

<style>
  .custom-section-slider .cards_block img {
    filter: none !important;
  }

  .text-headingsection {
    color: #666460;
text-align: center;
        padding-top: 6rem;
    padding-bottom: 3rem;
font-size: 2.75rem;
font-style: normal;
font-weight: 700;
line-height: 120%;
letter-spacing: 0.4125rem;
text-transform: uppercase;

  }



@media (max-width: 768px) {
  .text-headingsection {
    font-size: 29.392px !important;
    font-style: normal !important;
    font-weight: 700 !important;
    margin: 0px !important;
    padding-bottom: 60px !important;
    padding-top: 60px !important;
    line-height: 120% !important;
    letter-spacing: 4.409px !important;
  }

  .custom-section-slider .text-heading {
    font-size: 21.489px !important;
    font-style: normal !important;
    font-weight: 400 !important;
    line-height: 120% !important;
    letter-spacing: 3.223px !important;
  }

  .custom-section-slider {
    max-width: 100vw !important;
    padding: 0px !important;
  }

  .in_text-area {
    text-align: center !important;
    max-width: 100% !important;
    width: 300px !important;
    margin-left: auto !important;
    margin-right: auto !important;
  }

  .cards_block .swiper-slide {
    display: grid;
    overflow: hidden;
    max-width: 100% !important;
    width: 105px !important;
}

  .custom-section-slider .cards_block img {
        max-width: 107px;
    height: 243px;
  }
  .custom-section-slider .text-description {
    font-size: 18px !important;
    font-style: normal !important;
    font-weight: 350 !important;
    line-height: 140% !important;
  }

  .custom-section-slider .in_text-area * {
    text-align: center !important;
  }
}

</style>

<script> 

  document.addEventListener('DOMContentLoaded', function() {
    new Swiper('.swiper-container-info', {
     
     slidesPerView: 'auto',
          spaceBetween: 13 / 20,
      
      pagination: {
        el: '.swiper-pagination',
        clickable: true,
      },
      navigation: {
        nextEl: '.swiper-button-next',
        prevEl: '.swiper-button-prev',
      },
    });
  });

  document.querySelectorAll('.swiper-slide').forEach(function(slide) {
    slide.addEventListener('click', function() {
      openPopup(this.getAttribute('data-popup-image'), this.getAttribute('data-title'), this.getAttribute('data-popup-text'));
    });
 
  });

  function openPopup(image, title, description) {
    document.getElementById('popup').style.display = 'block';
    document.querySelector('.popup-image').src = image;
    document.querySelector('.popup-title').textContent = title;
    document.querySelector('.popup-description').textContent = description;
  }

  function closePopup() {
    document.getElementById('popup').style.display = 'none';
  }

document.addEventListener('DOMContentLoaded', function() {
    var popups = document.querySelectorAll('.popup-image, .popup');

    function closePopup() {
        popups.forEach(function(popup) {
            popup.style.display = 'none';
        });
    }

    popups.forEach(function(popup) {
        popup.addEventListener('click', closePopup);
    });
});
  
</script>



{% schema %}
{
  "name": "Custom Section Slider",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Default Heading"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Default description text goes here."
    }
  ],
  "blocks": [
    {
      "type": "image_with_text",
      "name": "Image with Text",
      "settings": [
        {
          "type": "image_picker",
          "id": "carousel_image",
          "label": "Carousel Image"
        }
      ]
    }
  ],

  "presets": [
    {
      "name": "image Section Slider",
      "blocks": [
        {
          "type": "image_with_text"
        },
        {
          "type": "image_with_text"
        }
      ]
    }
  ]
}
{% endschema %}