{{ 'discovery-duo-stubborn-stats.css' | asset_url | stylesheet_tag }}

<section
  class="dd-stubborn"
  aria-label="{{ section.settings.headline | default: 'Formulated without' | escape }}"
>
  <div class="dd-stubborn__inner">
    <div class="dd-stubborn__content">
      {%- if section.settings.eyebrow != blank -%}
        <span class="dd-stubborn__eyebrow">{{ section.settings.eyebrow | escape }}</span>
      {%- endif -%}
      {%- if section.settings.headline != blank -%}
        <h2 class="dd-stubborn__headline">{{ section.settings.headline | escape }}</h2>
      {%- endif -%}
      {%- if section.settings.subheadline != blank -%}
        <div class="dd-stubborn__subheadline">{{ section.settings.subheadline }}</div>
      {%- endif -%}

      <ul class="dd-stubborn__icons">
        {%- for block in section.blocks -%}
          {%- if block.type == 'icon' -%}
            <li {{ block.shopify_attributes }}>
              {%- if block.settings.icon != blank -%}
                {{ block.settings.icon | image_url: width: 120 | image_tag: loading: 'lazy', class: 'dd-stubborn__icon-image', alt: block.settings.label }}
              {%- else -%}
                <span class="dd-stubborn__icon-placeholder" aria-hidden="true"></span>
              {%- endif -%}
              <span>{{ block.settings.label | escape }}</span>
            </li>
          {%- endif -%}
        {%- endfor -%}
      </ul>

      {%- if section.settings.without_heading != blank -%}
        <p class="dd-stubborn__without-heading">{{ section.settings.without_heading | escape }}</p>
      {%- endif -%}

      <ul class="dd-stubborn__without">
        {%- for block in section.blocks -%}
          {%- if block.type == 'without' -%}
            <li {{ block.shopify_attributes }}>{{ block.settings.text | escape }}</li>
          {%- endif -%}
        {%- endfor -%}
      </ul>
    </div>

    <div class="dd-stubborn__media-card">
      {%- if section.settings.image_heading != blank -%}
        <h3 class="dd-stubborn__media-heading">{{ section.settings.image_heading | escape }}</h3>
      {%- endif -%}
      <div class="dd-stubborn__media">
        {%- if section.settings.desktop_image != blank or section.settings.mobile_image != blank -%}
          <picture>
            {%- if section.settings.mobile_image != blank -%}
              <source media="(max-width: 749px)" srcset="{{ section.settings.mobile_image | image_url: width: 750 }}">
            {%- endif -%}
            {%- if section.settings.desktop_image != blank -%}
              {{ section.settings.desktop_image | image_url: width: 900 | image_tag:
                loading: 'lazy',
                class: 'dd-stubborn__image',
                alt: section.settings.desktop_image.alt | default: section.settings.image_heading
              }}
            {%- endif -%}
          </picture>
        {%- else -%}
          <span class="dd-stubborn__image-placeholder" aria-hidden="true"></span>
        {%- endif -%}
      </div>

      <ul class="dd-stubborn__stats">
        {%- for block in section.blocks -%}
          {%- if block.type == 'stat' -%}
            <li class="dd-stubborn__stat" {{ block.shopify_attributes }}>
              <span class="dd-stubborn__stat-percentage">{{ block.settings.percentage | escape }}</span>
              <span class="dd-stubborn__stat-description">{{ block.settings.description | escape }}</span>
            </li>
          {%- endif -%}
        {%- endfor -%}
      </ul>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Duo – Clean results",
  "tag": "section",
  "class": "section-dd-stubborn",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Clean, clinical, uncompromising" },
    { "type": "text", "id": "headline", "label": "Headline", "default": "Formulated without" },
    { "type": "richtext", "id": "subheadline", "label": "Subheadline", "default": "<p>Free from more than 3,000 questionable ingredients while delivering visible clinical performance.</p>" },
    { "type": "text", "id": "without_heading", "label": "Without list heading", "default": "Formulated without" },
    { "type": "image_picker", "id": "desktop_image", "label": "Desktop image" },
    { "type": "image_picker", "id": "mobile_image", "label": "Mobile image" },
    { "type": "text", "id": "image_heading", "label": "Image heading", "default": "Visible results" },
    { "type": "range", "id": "padding_top", "label": "Top padding", "min": 0, "max": 200, "step": 4, "unit": "px", "default": 72 },
    { "type": "range", "id": "padding_bottom", "label": "Bottom padding", "min": 0, "max": 200, "step": 4, "unit": "px", "default": 72 }
  ],
  "blocks": [
    {
      "type": "without",
      "name": "Without item",
      "limit": 16,
      "settings": [
        { "type": "text", "id": "text", "label": "Text", "default": "Parabens" }
      ]
    },
    {
      "type": "icon",
      "name": "Certification icon",
      "limit": 10,
      "settings": [
        { "type": "image_picker", "id": "icon", "label": "Icon" },
        { "type": "text", "id": "label", "label": "Label", "default": "Vegan" }
      ]
    },
    {
      "type": "stat",
      "name": "Result stat",
      "limit": 4,
      "settings": [
        { "type": "text", "id": "percentage", "label": "Percentage", "default": "95%" },
        { "type": "text", "id": "description", "label": "Description", "default": "reported softer, smoother skin" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Duo – Clean results",
      "blocks": [
        { "type": "without", "settings": { "text": "Parabens" } },
        { "type": "without", "settings": { "text": "Phthalates" } },
        { "type": "without", "settings": { "text": "Fragrance" } },
        { "type": "without", "settings": { "text": "Silicones" } },
        { "type": "icon", "settings": { "label": "EWG Verified" } },
        { "type": "icon", "settings": { "label": "Vegan" } },
        { "type": "stat", "settings": { "percentage": "95%", "description": "reported softer, smoother skin" } },
        { "type": "stat", "settings": { "percentage": "68.9%", "description": "saw visible wrinkle reduction" } }
      ]
    }
  ]
}
{% endschema %}
