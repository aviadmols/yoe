{% schema %}
{
  "name": "Grid Product slider",
  "settings": [
    {
      "type": "text",
      "id": "custom-class",
      "label": "Custom Class"
    },
    {
      "type": "text",
      "id": "product-grid-heading",
      "label": "Title"
    },
    {
      "type": "text",
      "id": "product-grid-sub-heading",
      "label": "Sub Title"
    },
    {
      "type": "url",
      "id": "shop-btn-url",
      "label": "Shop Button Url"
    },
    {
      "type": "checkbox",
      "id": "show_snippets_overlay",
      "label": "Show award overlays (snippets-overlay)",
      "default": true,
      "info": "When disabled, no award badges appear on product images in this section."
    }
  ],
  "blocks": [
    {
      "type": "product",
      "name": "Product",
      "settings": [
        {
          "type": "product",
          "id": "product",
          "label": "Select product"
        },
        {
          "type": "text",
          "id": "tagline",
          "label": "Tagline",
          "default": "Enter tagline here"
        },
        {
          "type": "text",
          "id": "size",
          "label": "Product Size",
          "default": "Enter size here"
        },
        {
          "type": "image_picker",
          "id": "background_image",
          "label": "Background Image"
        },
        {
          "type": "checkbox",
          "id": "show_cosmopolitan_icon",
          "label": "Show Cosmopolitan icon",
          "default": false
        },
        {
          "type": "checkbox",
          "id": "show_beauty_awards",
          "label": "Show Beauty Awards",
          "default": true
        },
        {
          "type": "checkbox",
          "id": "show_snippets",
          "label": "Show Awards",
          "default": false
        },
        {
          "type": "checkbox",
          "id": "show_snippets_right",
          "label": "Show Awards Right",
          "default": false
        },
        {
          "type": "checkbox",
          "id": "show_snippets01",
          "label": "Red Beauty Icon Left",
          "default": false
        },
        {
          "type": "checkbox",
          "id": "show_snippets01_right",
          "label": "Show Awards 01 Right",
          "default": false
        },
        {
          "type": "checkbox",
          "id": "show_snippets02",
          "label": "Grey Beauty Icon Left",
          "default": false
        },
        {
          "type": "checkbox",
          "id": "show_snippets02_right",
          "label": "Show Awards 02 Right",
          "default": false
        },
        {
          "type": "image_picker",
          "id": "hover_image",
          "label": "Hover Image"
        },
        {
          "type": "richtext",
          "id": "custom_text",
          "label": "Custom Text",
          "default": "<p>Enter your text here</p>"
        },
        {
          "type": "url",
          "id": "custom_url",
          "label": "Custom URL"
        },
        {
          "type": "select",
          "id": "price_type",
          "label": "Price Type",
          "options": [
            {
              "value": "lowest",
              "label": "Lowest Price"
            },
            {
              "value": "highest",
              "label": "Highest Price"
            }
          ],
          "default": "lowest"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Grid Product slider",
      "category": "Custom"
    }
  ]
}
{% endschema %}


<div class="main-product-grid-cus {{ section.settings.custom-class }}">
    <div class="product-grid-main">
        <div class="page-width">
            <div class="product-top-heading-section">
                <div class="content-sec-cu">
                    <h1 class="product-grid-title">{{ section.settings.product-grid-heading }}</h1>
                    <p class="product-grid-sub-title">{{ section.settings.product-grid-sub-heading }}</p>
                </div>
                <div class="shop-now-button">
                    <a href="{{ section.settings.shop-btn-url }}">
                        <button type="text">SHop All</button>
                    </a>
                </div>
            </div>
        </div>
    </div>
    <div class="product-slider">
        <div class="page-width">
            <div class="product-grid">
                {% for block in section.blocks %}
                    {% assign product = block.settings.product %}

                    {% if product %}
                        {% assign product_url = block.settings.custom_url | default: product.url %}
                        {% assign product_variants = product.variants %}

                        {% if product_variants.size > 1 %}
                            {% assign price_list = product_variants | map: 'price' %}
                            {% assign lowest_price = price_list | sort | first %}
                            {% assign highest_price = price_list | sort | last %}

                            {% case block.settings.price_type %}
                                {% when 'lowest' %}
                                    {% assign final_price = lowest_price %}
                                    {% comment %} Find the variant with lowest price and check if IT has a sale {% endcomment %}
                                    {% assign original_price = nil %}
                                    {% for variant in product_variants %}
                                        {% if variant.price == lowest_price %}
                                            {% if variant.compare_at_price and variant.compare_at_price > variant.price %}
                                                {% assign original_price = variant.compare_at_price %}
                                            {% endif %}
                                            {% break %}
                                        {% endif %}
                                    {% endfor %}
                                {% when 'highest' %}
                                    {% assign final_price = highest_price %}
                                    {% comment %} Find the variant with highest price and check if IT has a sale {% endcomment %}
                                    {% assign original_price = nil %}
                                    {% for variant in product_variants %}
                                        {% if variant.price == highest_price %}
                                            {% if variant.compare_at_price and variant.compare_at_price > variant.price %}
                                                {% assign original_price = variant.compare_at_price %}
                                            {% endif %}
                                            {% break %}
                                        {% endif %}
                                    {% endfor %}
                            {% endcase %}
                        {% else %}
                            {% assign final_price = product.price %}
                            {% assign original_price = product.compare_at_price %}
                        {% endif %}

                        {%- assign background_image = block.settings.background_image | default: product.featured_image -%}
                        {%- assign hover_image = block.settings.hover_image | default: product.featured_image -%}
                        {%- assign custom_text = block.settings.custom_text | default: product.title -%}

                        <a href="{{ product_url }}" class="product-item">
                            <div class="product-image-container">

                                {% if section.settings.show_snippets_overlay != false and block.settings.show_snippets %}
                                    <div class="snippets-overlay {% if block.settings.show_snippets_right %}right-badge{% endif %}">
                                        {% if block.settings.show_cosmopolitan_icon %}
                                            <img class="cosmopolitan-icon"
                                                 src="https://cdn.shopify.com/s/files/1/0691/9959/3720/files/cosmopolitan.png"
                                                 alt="Cosmopolitan">
                                        {% endif %}
                                    </div>
                                {% endif %}



                                {% if section.settings.show_snippets_overlay != false and block.settings.show_snippets02 %}
                                    <div class="snippets-overlay {% if block.settings.show_snippets02_right %} right-badge{% endif %}">
                                        <img src="https://cdn.shopify.com/s/files/1/0691/9959/3720/files/beauty_icon_587c0b11-84ff-4d4c-bc0a-854917ca8872.svg?v=1756928214"
                                             style="object-fit: contain; min-width: 100%;">
                                    </div>
                                {% endif %}

                                {% if section.settings.show_snippets_overlay != false and block.settings.show_snippets01 %}

                                    <div class="snippets-overlay {% if block.settings.show_snippets01_right %} right-badge{% endif %}">
                                        <img src="https://cdn.shopify.com/s/files/1/0691/9959/3720/files/image002_1_1.png?v=1745347709"
                                             style="object-fit: contain; min-width: 100%;">
                                    </div>
                                {% endif %}

                                {% comment %} <div class="black-friday-badge">
                                    Black Friday Event
                                </div> {% endcomment %}

                                <div class="product-name">
                                    {{ custom_text }}
                                    <span class="product-size">{{ block.settings.size }}</span>
                                </div>

                                <img src="{{ background_image | img_url: 'master' }}" alt="{{ product.title }}"
                                     class="background-image">
                                <img src="{{ hover_image | img_url: 'master' }}" alt="{{ product.title }}"
                                     class="hover-image">

                                <div class="hover-content">
                                    <div class="tagline">{{ block.settings.tagline }}</div>
                                    <div class="learn-more">LEARN MORE</div>
                                </div>
                            </div>

                            <div class="product-price">
                                FROM
                                {% if original_price and original_price > final_price %}
                                    <span class="sale-price">{{ final_price | money_without_trailing_zeros }}</span>
                                    <span class="regular-price">{{ original_price | money_without_trailing_zeros }}</span>
                                {% else %}
                                    {{ final_price | money_without_trailing_zeros }}
                                {% endif %}
                            </div>

                            <div class="info_product_mobile hide-pc">
                                <div class="product-name-mobile">
                                    {{ custom_text }}
                                    <span class="product-size">{{ block.settings.size }}</span>
                                </div>
                                <div class="tagline-mobile">{{ block.settings.tagline }}</div>
                                <div class="button-btn">
                                    <div class="product-price-mobile">
                                        FROM
                                        {% if original_price and original_price > final_price %}
                                            <span class="sale-price">{{ final_price | money_without_trailing_zeros }}</span>
                                            <span class="regular-price">{{ original_price | money_without_trailing_zeros }}</span>
                                        {% else %}
                                            {{ final_price | money_without_trailing_zeros }}
                                        {% endif %}
                                    </div>
                                    <div class="button_product_grid">LEARN MORE</div>
                                </div>
                            </div>
                        </a>
                    {% endif %}
                {% endfor %}
            </div>
        </div>
    </div>
</div>


