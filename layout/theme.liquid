<script>
  document.addEventListener('DOMContentLoaded', function () {
    if (typeof window.jQuery === 'undefined' || !window.jQuery.fn || !window.jQuery.fn.slick) return;
    var $ = window.jQuery;
    function initSlickSlider() {
      var $grids = $('.product-slider .product-grid');
      if (!$grids.length) return;

      if ($(window).width() >= 768) {
        $grids.each(function () {
          var $grid = $(this);
          if (!$grid.hasClass('slick-initialized')) {
            $grid.slick({
              slidesToShow: 3,
              slidesToScroll: 1,
              arrows: true,
              dots: true
            });
          }
        });
      } else {
        $grids.each(function () {
          var $grid = $(this);
          if ($grid.hasClass('slick-initialized')) {
            $grid.slick('unslick');
          }
        });
      }
    }
    initSlickSlider();
    $(window).on('resize', initSlickSlider);
  });
</script>


