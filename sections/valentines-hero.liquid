    {
      "type": "richtext",
      "id": "description",
      "label": "Description",
      "default": "<p>Spread the love this Valentine's Day with Yoé. Purchase a full-size Yoé product, and we’ll gift a second one to your loved one—our treat. You choose the person, we’ll take care of the rest.</p>"
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "CTA Link"
    },
    {
      "type": "text",
      "id": "cta_text",
      "label": "CTA Text",
      "default": "Shop Now"
    }
  ],
  "blocks": [
    {
      "type": "step",
      "name": "Step",
      "settings": [
        {
          "type": "text",
          "id": "step_number",
          "label": "Step Number",
          "default": "1"
        },
        {
          "type": "text",
          "id": "step_title",
          "label": "Step Title",
          "default": "Purchase Now"
        },
        {
          "type": "textarea",
          "id": "step_description",
          "label": "Step Description",
          "default": "Any full-size Yoé product."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Valentine's Promo",
      "category": "Custom Sections",
      "blocks": [
        { "type": "step" },
        { "type": "step" },
        { "type": "step" }
      ]
    }
  ]
}
