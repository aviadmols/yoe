  <script>
    document.addEventListener('DOMContentLoaded', function () {
      // Scope everything to this section instance
      const gallery = document.getElementById('GalleryViewer-{{ section.id }}{{ id_append }}');
      if (!gallery) return;

      const list = document.getElementById('Slider-Gallery-{{ section.id }}{{ id_append }}');
      if (!list) return;

      const slides = Array.from(list.querySelectorAll('.slider__slide')).filter((slide) => slide.offsetParent !== null);
      const dotsWrap = gallery.querySelector('.dot-gallery');
      if (!dotsWrap || slides.length === 0) return;

      // Build dots dynamically to match slides
      dotsWrap.innerHTML = '';
      slides.forEach((_, i) => {
        const dot = document.createElement('span');
        dot.className = 'dot-line';
        dot.setAttribute('role', 'button');
        dot.setAttribute('tabindex', '0');
        dot.setAttribute('aria-label', `Go to slide ${i + 1}`);
        dot.addEventListener('click', () => {
          // Scroll the target slide into view within the slider
          slides[i].scrollIntoView({ behavior: 'smooth', inline: 'start', block: 'nearest' });
          setActive(i);
        });
        dot.addEventListener('keydown', (e) => {
          if (e.key === 'Enter' || e.key === ' ') {
            e.preventDefault();
            slides[i].scrollIntoView({ behavior: 'smooth', inline: 'start', block: 'nearest' });
            setActive(i);
          }
        });
        dotsWrap.appendChild(dot);
      });

      const dots = Array.from(dotsWrap.querySelectorAll('.dot-line'));

      function setActive(index) {
        dots.forEach((d, j) => d.classList.toggle('active', j === index));
      }

      // Observe which slide is centered/mostly visible to keep dots in sync
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              const idx = slides.indexOf(entry.target);
              if (idx !== -1) setActive(idx);
            }
          });
        },
        { root: list, threshold: 0.6 }
      );

      slides.forEach((slide) => observer.observe(slide));

      // Initial active state
      setActive(0);
    });
  </script>
