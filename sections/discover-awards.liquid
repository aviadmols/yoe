{% schema %}
{
  "name": "Discover Awards",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Section Title"
    }
  ],
  "blocks": [
    {
      "type": "highlight",
      "name": "Highlight Box",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Highlight Image"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title"
        },
        {
          "type": "textarea",
          "id": "subtitle",
          "label": "Subtitle"
        }
      ]
    },
    {
      "type": "mention",
      "name": "Press Mention",
      "settings": [
        {
          "type": "image_picker",
          "id": "logo",
          "label": "Publication Logo"
        },
        {
          "type": "text",
          "id": "source",
          "label": "Source Name"
        },
        {
          "type": "textarea",
          "id": "quote",
          "label": "Quote"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Discover Awards",
      "category": "Awards"
    }
  ]
}
{% endschema %}



<div class="discover-awards padding-right-left">
  <h2 class="section-title">{{ section.settings.title }}</h2>

  <div class="award-highlights">
    {% for block in section.blocks %}
      {% if block.type == 'highlight' %}
        <div class="highlight-box">
          {% if block.settings.image != blank %}
            <img src="{{ block.settings.image | img_url: 'master' }}" alt="{{ block.settings.title }}">
          {% endif %}
          <h3>{{ block.settings.title }}</h3>
          <p>{{ block.settings.subtitle }}</p>
        </div>
      {% endif %}
    {% endfor %}
  </div>

  <div class="mentions">
    {% for block in section.blocks %}
      {% if block.type == 'mention' %}
        <div class="mention">
          {% if block.settings.logo != blank %}
          <img src="{{ block.settings.logo | img_url: 'master' }}" alt="{{ block.settings.source }}">
          {% endif %}
          <h3>{{ block.settings.source }}</h3>
          <p>{{ block.settings.quote }}</p>
        </div>
      {% endif %}
    {% endfor %}
  </div>
</div>


{% stylesheet %}
.discover-awards {
  padding: 6rem 1.75rem;
  text-align: center;
}

.section-title {
  color: #666460;
  text-align: center;
  font-family: "Open Sans";
  font-size: 2.75rem;
  font-style: normal;
      margin-top: 0px;
  font-weight: 400;
margin-bottom: 5rem;
  line-height: 3.3275rem; /* 66.55px */
  letter-spacing: 0.2475rem;
  text-transform: uppercase;

}

.section-title {
    max-width: 41rem;
    margin-left: auto;
    margin-right: auto;
}

.award-highlights {
  display: flex;
  flex-wrap: wrap;
justify-content: center;
  gap: 3rem;
  margin-bottom: 0rem;
}

.highlight-box {
  width: 33rem;
  max-width: 100%;
  text-align: center;
}

.highlight-box img {
  width: 27.55rem;
    height: 8rem;
  max-width: 100%;
  max-height: 7rem;
  margin-bottom: 1rem;
  object-fit: contain;
}

