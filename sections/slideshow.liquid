    if (sliderArea) {
      // Touch Events
      sliderArea.addEventListener('touchstart', (e) => {
        startX = e.touches[0].clientX;
        isDragging = true;
      });

      sliderArea.addEventListener('touchend', (e) => {
        if (!isDragging) return;
        const endX = e.changedTouches[0].clientX;
        handleSwipe(startX, endX);
        isDragging = false;
      });

      // Mouse Events
      sliderArea.addEventListener('mousedown', (e) => {
        startX = e.clientX;
        isDragging = true;
      });

      sliderArea.addEventListener('mouseup', (e) => {
        if (!isDragging) return;
        const endX = e.clientX;
        handleSwipe(startX, endX);
        isDragging = false;
      });

      const handleSwipe = (start, end) => {
        const delta = end - start;
        const swipeThreshold = 50;
        if (delta > swipeThreshold && currentSlide > 0) {
          showSlide(currentSlide - 1); // Swipe right (previous)
        } else if (delta < -swipeThreshold && currentSlide < slides.length - 1) {
          showSlide(currentSlide + 1); // Swipe left (next)
        }
      };
    }

    // Auto-rotate support
    const autoplay = slideshow.dataset.autoplay === 'true';
    const speed = parseInt(slideshow.dataset.speed || '5000', 10);
    if (autoplay) {
      setInterval(() => {
        if (currentSlide < slides.length - 1) {
          showSlide(currentSlide + 1);
        }
      }, speed);
    }

    // Init
    slides.forEach((slide, index) => {
      slide.classList.toggle('is-active', index === currentSlide);
    });
    showSlide(currentSlide);
  });
}); {% endcomment %}






