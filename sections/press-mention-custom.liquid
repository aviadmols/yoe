{{ 'slick.css' | asset_url | stylesheet_tag }}
<script src="{{ 'slick.min.js' | asset_url }}"></script>

<section class="press-mentions" id="press-mentions-{{ section.id }}">
  <div class="page-width">
    <div class="press-mentions-wrapper" data-press-mentions-slider>
      {% for block in section.blocks %}
        <div class="press-mention-item" {{ block.shopify_attributes }}>
          <h4>{{ block.settings.title }}</h4>
          <p>{{ block.settings.quote }}</p>
        </div>
      {% endfor %}
    </div>
  </div>
</section>

<style>
  #press-mentions-{{ section.id }} .press-mentions-wrapper {
    width: 100%;
    max-width: 81.9rem;
    margin: 0 auto;
  }

  #press-mentions-{{ section.id }} .press-mention-item h4 {
    margin: 0;
    font-family: "Open Sans", sans-serif;
    font-size: 1.5rem;
    font-weight: 500;
    line-height: 1.16;
    letter-spacing: 0;
    text-transform: uppercase;
    color: #666460;
  }

  #press-mentions-{{ section.id }} .press-mention-item p {
    width: 100%;
    max-width: 20rem;
    margin: 0 auto;
    padding-top: 0.375rem;
    font-family: "Open Sans", sans-serif;
    font-size: 1.02rem;
    font-style: italic;
    font-weight: 300;
    line-height: 1.16;
    color: #666460;
  }

  #press-mentions-{{ section.id }}.press-mentions {
    padding: 1.125rem 0 1.375rem;
    background: #fff;
  }

  #press-mentions-{{ section.id }} .press-mentions-wrapper {
    display: flex;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 1.25rem;
  }

  #press-mentions-{{ section.id }} .press-mention-item {
    flex: 1;
    min-width: 0;
    text-align: center;
    padding: 0.625rem;
  }

  @media screen and (max-width: 990px) and (min-width: 768px) {
    #press-mentions-{{ section.id }} .press-mention-item h4 {
      font-size: 1.375rem;
    }

    #press-mentions-{{ section.id }} .press-mention-item p {
      font-size: 1.125rem;
    }
  }

  @media screen and (max-width: 749px) {
    #press-mentions-{{ section.id }}.press-mentions {
      padding: 2.625rem 0 1.75rem;
      background: #fff;
    }

    #press-mentions-{{ section.id }} .press-mentions-wrapper {
      display: block;
    }

    #press-mentions-{{ section.id }} .press-mention-item {
      width: 100%;
      padding: 0 1.125rem;
      box-sizing: border-box;
    }

    #press-mentions-{{ section.id }} .press-mention-item h4 {
      font-family: "Open Sans Condensed", sans-serif;
      font-size: 2rem;
      font-weight: 500;
      line-height: 1.2;
    }

    #press-mentions-{{ section.id }} .press-mention-item p {
      max-width: 18.5rem;
      font-size: 1.1875rem;
      line-height: 1.42;
    }

    #press-mentions-{{ section.id }} .press-mentions-wrapper.slick-slider {
      margin-bottom: 0;
    }

    #press-mentions-{{ section.id }} .press-mentions-wrapper .slick-list {
      overflow: hidden;
    }

    #press-mentions-{{ section.id }} .press-mentions-wrapper .slick-slide {
      float: none;
    }

    #press-mentions-{{ section.id }} ul.slick-dots {
      position: relative;
      bottom: auto;
      display: flex !important;
      justify-content: center;
      align-items: center;
      gap: 0.5rem;
      margin: 1.5rem 0 0;
      padding: 0;
      list-style: none;
    }

    #press-mentions-{{ section.id }} ul.slick-dots li {
      width: auto;
      height: auto;
      margin: 0;
    }

    #press-mentions-{{ section.id }} ul.slick-dots li button {
      width: 0.5rem;
      height: 0.5rem;
      padding: 0;
    }

    #press-mentions-{{ section.id }} ul.slick-dots li button::before {
      content: "";
      position: absolute;
      top: 50%;
      left: 50%;
      width: 0.5rem;
      height: 0.5rem;
      border-radius: 50%;
      background: #d4d3d1;
      opacity: 1;
      transform: translate(-50%, -50%);
    }

    #press-mentions-{{ section.id }} ul.slick-dots li.slick-active button::before {
      background: #666460;
    }
  }

  @media screen and (min-width: 991px) and (max-width: 1200px) {
    #press-mentions-{{ section.id }} .press-mention-item h4 {
      font-size: 1.25rem;
    }
  }

  @media screen and (min-width: 1201px) and (max-width: 1496px) {
    #press-mentions-{{ section.id }} .press-mention-item h4 {
      font-size: 1.4375rem;
    }
  }
</style>

<script>
  (function () {
    var sectionId = '{{ section.id }}';
    var selector = '#press-mentions-' + sectionId + ' [data-press-mentions-slider]';
    var MOBILE_MAX = 749;
    var resizeTimer;

    function slickReady() {
      return typeof jQuery !== 'undefined' && jQuery.fn && typeof jQuery.fn.slick === 'function';
    }

    function whenSlickReady(callback) {
      if (slickReady()) {
        callback();
        return;
      }

      var attempts = 0;
      var timer = setInterval(function () {
        if (slickReady()) {
          clearInterval(timer);
          callback();
        } else if (++attempts > 100) {
          clearInterval(timer);
        }
      }, 50);
    }

    function initPressMentionsSlider() {
      if (!slickReady()) return;

      var $wrapper = jQuery(selector);
      if (!$wrapper.length || $wrapper.children().length < 2) return;

      if (window.innerWidth <= MOBILE_MAX) {
        if (!$wrapper.hasClass('slick-initialized')) {
          $wrapper.slick({
            dots: true,
            arrows: false,
            infinite: true,
            slidesToShow: 1,
            slidesToScroll: 1,
            autoplay: true,
            autoplaySpeed: 4000,
            adaptiveHeight: true,
            pauseOnHover: true
          });
        }
      } else if ($wrapper.hasClass('slick-initialized')) {
        $wrapper.slick('unslick');
      }
    }

    function scheduleInit() {
      clearTimeout(resizeTimer);
      resizeTimer = setTimeout(function () {
        whenSlickReady(initPressMentionsSlider);
      }, 150);
    }

    whenSlickReady(function () {
      jQuery(document).ready(initPressMentionsSlider);
      jQuery(window).on('resize', scheduleInit);
    });

    document.addEventListener('shopify:section:load', function (event) {
      if (event.detail.sectionId === sectionId) {
        scheduleInit();
      }
    });
  })();
</script>

{% schema %}
{
  "name": "Press Mentions",
  "settings": [
    {
      "type": "header",
      "content": "Press Mentions Section"
    }
  ],
  "blocks": [
    {
      "type": "quote",
      "name": "Press Item",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Publication Name",
          "default": "COSMOPOLITAN"
        },
        {
          "type": "textarea",
          "id": "quote",
          "label": "Quote",
          "default": "\"Behold: the rich-but-light skin-soothing cream you didn't know you were missing.\""
        }
      ]
    }
  ],
  "max_blocks": 10,
  "presets": [
    {
      "name": "Press Mentions",
      "category": "Text"
    }
  ]
}
{% endschema %}
